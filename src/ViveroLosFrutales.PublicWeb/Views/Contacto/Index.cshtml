@model ContactoViewModel
@inject IConfiguration Configuration
@{ ViewData["Title"] = "Contacto"; var whatsapp = Configuration["PublicSite:WhatsAppUrl"] ?? "#"; }
<section class="page-hero contact-hero"><div class="container"><span class="eyebrow">Contacto</span><h1>Tu proyecto puede empezar hoy</h1><p>Déjanos tus datos o escríbenos directamente. Estamos listos para orientarte.</p></div></section>
<section class="section"><div class="container contact-grid"><div class="contact-info"><span class="eyebrow green">Conversemos</span><h2>Cuéntanos qué necesitas</h2><p>Te responderemos con información sobre productos, disponibilidad, servicios o una propuesta personalizada.</p><div class="contact-item"><strong>Ubicación</strong><span>@Model.Empresa.Direccion</span></div><div class="contact-item"><strong>Teléfono</strong><span>@Model.Empresa.Telefono</span></div><div class="contact-item"><strong>Correo</strong><span>@Model.Empresa.Email</span></div><a class="btn btn-outline" href="@whatsapp" target="_blank" rel="noopener">Escribir por WhatsApp</a></div><div class="contact-form-wrap">
@if (TempData["ContactoEnviado"] is string mensaje) { <div class="alert-success">@mensaje</div> }
<form asp-action="Index" method="post" class="contact-form"><div asp-validation-summary="ModelOnly" class="validation"></div><label asp-for="Nombre"></label><input asp-for="Nombre" placeholder="Tu nombre completo" /><span asp-validation-for="Nombre"></span><div class="form-row"><div><label asp-for="Telefono"></label><input asp-for="Telefono" placeholder="999 999 999" /><span asp-validation-for="Telefono"></span></div><div><label asp-for="Email"></label><input asp-for="Email" placeholder="correo@ejemplo.com" /><span asp-validation-for="Email"></span></div></div><label asp-for="Mensaje"></label><textarea asp-for="Mensaje" rows="5" placeholder="Cuéntanos sobre tu proyecto"></textarea><span asp-validation-for="Mensaje"></span><button class="btn btn-primary" type="submit">Enviar consulta</button></form></div></div></section>
