@inject IConfiguration Configuration
@{
    var siteName = Configuration["PublicSite:Nombre"] ?? "Vivero Los Frutales";
    var whatsapp = Configuration["PublicSite:WhatsAppUrl"] ?? "#";
    var erpPath = Configuration["PublicSite:ErpPath"] ?? "/app/login";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Vivero Los Frutales: plantas frutales y ornamentales, asesoría agrícola, injertos, riego y fumigación en Huaral." />
    <title>@ViewData["Title"] - @siteName</title>
    <link rel="icon" type="image/png" href="~/images/logo.png" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/logo.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <div class="container nav-wrap">
            <a class="brand" asp-controller="Home" asp-action="Index" aria-label="Ir al inicio">
                <img src="~/images/logo.png" asp-append-version="true" alt="Logo Vivero Los Frutales" />
                <span><strong>Vivero</strong> Los Frutales</span>
            </a>
            <button class="nav-toggle" type="button" aria-label="Abrir menú" aria-expanded="false"><span></span><span></span><span></span></button>
            <nav class="main-nav" aria-label="Navegación principal">
                <a asp-controller="Home" asp-action="Index">Inicio</a>
                <a asp-controller="Nosotros" asp-action="Index">Nosotros</a>
                <a asp-controller="Productos" asp-action="Index">Productos</a>
                <a asp-controller="Servicios" asp-action="Index">Servicios</a>
                <a asp-controller="Contacto" asp-action="Index">Contacto</a>
                <a class="nav-erp" href="@erpPath">Acceso ERP</a>
            </nav>
        </div>
    </header>

    <main>@RenderBody()</main>

    <footer class="site-footer">
        <div class="container footer-grid">
            <div>
                <a class="brand brand-footer" asp-controller="Home" asp-action="Index">
                    <img src="~/images/logo.png" asp-append-version="true" alt="Logo Vivero Los Frutales" /><span><strong>Vivero</strong> Los Frutales</span>
                </a>
                <p>Plantas sanas, asesoría experta y soluciones agrícolas para hacer crecer tus proyectos.</p>
            </div>
            <div><h3>Explora</h3><a asp-controller="Productos" asp-action="Index">Productos</a><a asp-controller="Servicios" asp-action="Index">Servicios</a><a asp-controller="Nosotros" asp-action="Index">Nosotros</a></div>
            <div><h3>Contacto</h3><a asp-controller="Contacto" asp-action="Index">Solicitar asesoría</a><a href="@whatsapp" target="_blank" rel="noopener">Escríbenos por WhatsApp</a><span>Huaral, Lima - Perú</span></div>
        </div>
        <div class="container footer-bottom"><span>© @PeruDateTime.Now.Year @siteName</span><a href="@erpPath">Acceso colaboradores</a></div>
    </footer>
    <a class="whatsapp-float" href="@whatsapp" target="_blank" rel="noopener" aria-label="Contactar por WhatsApp">✆</a>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
