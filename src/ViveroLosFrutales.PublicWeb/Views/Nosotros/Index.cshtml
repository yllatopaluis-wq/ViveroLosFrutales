@model PublicPageViewModel
@{ ViewData["Title"] = "Nosotros"; }
<section class="page-hero"><div class="container"><span class="eyebrow">Quiénes somos</span><h1>Raíces firmes, crecimiento compartido</h1><p>Somos un vivero de Huaral comprometido con plantas de calidad y relaciones que perduran.</p></div></section>
<section class="section"><div class="container story-grid"><div class="story-image"></div><div><span class="eyebrow green">Nuestra historia</span><h2>Conocemos el campo porque crecemos con él</h2><p>Vivero Los Frutales nace del trabajo cercano con agricultores, familias y empresas que buscan plantas sanas y acompañamiento confiable.</p><p>Seleccionamos cuidadosamente cada planta y compartimos recomendaciones prácticas para que su adaptación, desarrollo y producción sean exitosos.</p><div class="facts"><div><strong>Calidad</strong><span>en cada planta</span></div><div><strong>Cercanía</strong><span>en cada atención</span></div><div><strong>Experiencia</strong><span>puesta a tu servicio</span></div></div></div></div></section>
<section class="section section-soft"><div class="container values-grid"><article><span>01</span><h3>Nuestra misión</h3><p>Brindar plantas y soluciones agrícolas que generen valor sostenible para nuestros clientes.</p></article><article><span>02</span><h3>Nuestra visión</h3><p>Ser un vivero referente por calidad, innovación, responsabilidad y servicio especializado.</p></article><article><span>03</span><h3>Nuestros valores</h3><p>Honestidad, compromiso, respeto por la naturaleza y mejora continua.</p></article></div></section>
<section class="cta-band"><div class="container"><div><h2>Visítanos y encuentra la planta ideal</h2><p>@Model.Empresa?.Direccion</p></div><a class="btn btn-light" asp-controller="Contacto" asp-action="Index">Cómo contactarnos</a></div></section>
