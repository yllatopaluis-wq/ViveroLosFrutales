@model CorrelativosEmpresaDto
@{
    ViewData["Title"] = "Correlativos";
}

<div class="toolbar">
    <h1>Correlativos</h1>
    <a class="btn btn-sm btn-outline-secondary" asp-action="Index">Volver</a>
</div>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success py-2">@success</div>
}

<form method="post" class="dense-form">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <table class="table table-sm data-grid">
        <thead>
            <tr>
                <th>Comprobante</th>
                <th>Serie</th>
                <th>Clave</th>
                <th class="text-end">Siguiente correlativo</th>
            </tr>
        </thead>
        <tbody>
        @for (var i = 0; i < Model.Items.Count; i++)
        {
            <tr>
                <td>
                    @Model.Items[i].Nombre
                    <input asp-for="Items[i].TipoComprobante" type="hidden" />
                    <input asp-for="Items[i].Nombre" type="hidden" />
                </td>
                <td>
                    @Model.Items[i].Serie
                    <input asp-for="Items[i].Serie" type="hidden" />
                </td>
                <td>
                    @Model.Items[i].Clave
                    <input asp-for="Items[i].Clave" type="hidden" />
                </td>
                <td>
                    <input asp-for="Items[i].SiguienteCorrelativo" class="form-control form-control-sm text-end" type="number" min="1" />
                </td>
            </tr>
        }
        </tbody>
    </table>
    <div class="form-actions">
        <button class="btn btn-sm btn-primary">Guardar</button>
    </div>
</form>
