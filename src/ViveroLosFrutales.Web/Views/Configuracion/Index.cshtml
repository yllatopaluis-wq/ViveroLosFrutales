@model PagedResult<ConfiguracionEmpresaListDto>
@{ ViewData["Title"] = "Configuración"; var search = Context.Request.Query["Search"].FirstOrDefault();
    var pageSize = Context.Request.Query["PageSize"].FirstOrDefault() ?? Model.PageSize.ToString(); }
<section class="comprobantes-page admin-docs-page"><form method="get" class="comprobantes-toolbar admin-docs-toolbar compact">
<label class="comprobantes-search"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7" /><path d="m20 20-4-4" /></svg><input name="Search" value="@search" placeholder="Buscar clave o descripción..." autocomplete="off" />@if (!string.IsNullOrWhiteSpace(search)) { <a class="search-clear" asp-action="Index" asp-route-PageSize="@pageSize" aria-label="Limpiar búsqueda">&times;</a> }</label>

<input type="hidden" name="PageSize" value="@pageSize" />
<button class="btn-search" type="submit"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7" /><path d="m20 20-4-4" /></svg>Buscar</button>
<button class="btn-export" type="button" id="exportConfiguracionCsv"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3v12" /><path d="m8 11 4 4 4-4" /><path d="M5 20h14" /></svg>Exportar</button><a class="btn-export" asp-action="Correlativos">Correlativos</a>
</form><div class="comprobantes-list admin-docs-list"><div class="comprobantes-head admin-docs-head"><span>Clave</span><span>Valor</span><span>Descripción</span><span></span><span></span><span>Acciones</span></div>
@if (!Model.Items.Any()) { <div class="comprobantes-empty"><strong>No hay configuraciones</strong><span>Ajusta la búsqueda o registra una nueva configuración.</span></div> } else { @foreach (var item in Model.Items) { <article class="comprobante-row admin-docs-row" data-csv="@item.Clave|@item.Valor|@item.Descripcion"><div class="comprobante-main"><span class="comprobante-icon success"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="3" /><path d="M19.4 15a1.7 1.7 0 0 0 .3 1.9l.1.1-2.8 2.8-.1-.1a1.7 1.7 0 0 0-1.9-.3 1.7 1.7 0 0 0-1 1.6v.2h-4V21a1.7 1.7 0 0 0-1-1.6 1.7 1.7 0 0 0-1.9.3l-.1.1L4.2 17l.1-.1a1.7 1.7 0 0 0 .3-1.9A1.7 1.7 0 0 0 3 14H2.8v-4H3a1.7 1.7 0 0 0 1.6-1 1.7 1.7 0 0 0-.3-1.9L4.2 7 7 4.2l.1.1A1.7 1.7 0 0 0 9 4.6 1.7 1.7 0 0 0 10 3V2.8h4V3a1.7 1.7 0 0 0 1 1.6 1.7 1.7 0 0 0 1.9-.3l.1-.1L19.8 7l-.1.1a1.7 1.7 0 0 0-.3 1.9 1.7 1.7 0 0 0 1.6 1h.2v4H21a1.7 1.7 0 0 0-1.6 1Z" /></svg></span><span class="comprobante-copy"><strong>@item.Clave</strong><small>Configuración</small></span></div><div class="comprobante-client"><strong>@item.Valor</strong><small>Valor</small></div><div class="comprobante-client"><strong>@item.Descripcion</strong><small>Descripción</small></div><div></div><div></div><div class="comprobante-actions"><details class="row-actions-menu"><summary aria-label="Abrir acciones"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="5" r="1.5" /><circle cx="12" cy="12" r="1.5" /><circle cx="12" cy="19" r="1.5" /></svg></summary><div class="row-actions-panel"><a asp-action="Edit" asp-route-id="@item.ConfiguracionEmpresaId"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 20h9" /><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z" /></svg> Editar</a></div></details></div></article> } }</div>@await Html.PartialAsync("_Pager", Model)</section><script>
document.querySelectorAll('.row-actions-menu').forEach(menu => { menu.addEventListener('toggle', () => { if (!menu.open) return; document.querySelectorAll('.row-actions-menu[open]').forEach(other => { if (other !== menu) other.removeAttribute('open'); }); }); });
document.addEventListener('click', event => { if (event.target.closest('.row-actions-menu')) return; document.querySelectorAll('.row-actions-menu[open]').forEach(menu => menu.removeAttribute('open')); });
document.getElementById('exportConfiguracionCsv')?.addEventListener('click', () => { const rows = Array.from(document.querySelectorAll('.admin-docs-row[data-csv]')); const header = ["Clave","Valor","Descripcion"]; const csvRows = [header, ...rows.map(row => row.dataset.csv.split('|'))].map(cols => cols.map(value => '"' + String(value ?? '').replaceAll('"', '""') + '"').join(',')); const blob = new Blob([csvRows.join('\n')], { type: 'text/csv;charset=utf-8;' }); const url = URL.createObjectURL(blob); const link = document.createElement('a'); link.href = url; link.download = 'configuracion.csv'; link.click(); URL.revokeObjectURL(url); });
</script>