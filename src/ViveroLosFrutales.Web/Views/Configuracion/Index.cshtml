@model PagedResult<ConfiguracionEmpresaListDto>
@{
    ViewData["Title"] = "Configuracion";
}

<div class="toolbar">
    <form method="get" class="search-form">
        <input name="Search" class="form-control form-control-sm" placeholder="Buscar clave o descripcion" />
        <button class="btn btn-sm btn-primary">Buscar</button>
    </form>
    <div class="inline-actions">
        <a class="btn btn-sm btn-outline-primary" asp-action="Correlativos">Correlativos</a>
        <a class="btn btn-sm btn-success" asp-action="Edit">Crear</a>
    </div>
</div>

<table class="table table-sm table-striped data-grid">
    <thead><tr><th>Clave</th><th>Valor</th><th>Descripcion</th><th></th></tr></thead>
    <tbody>
    @foreach (var item in Model.Items)
    {
        <tr>
            <td>@item.Clave</td>
            <td>@item.Valor</td>
            <td>@item.Descripcion</td>
            <td class="text-end"><a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.ConfiguracionEmpresaId">Editar</a></td>
        </tr>
    }
    </tbody>
</table>
