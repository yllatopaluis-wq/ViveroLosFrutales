@model PagedResult<IngresoListDto>
@{
    ViewData["Title"] = "Lista Ingresos";
    var today = DateTime.Today;
    var firstDay = new DateTime(today.Year, today.Month, 1).ToString("yyyy-MM-dd");
    var currentDay = today.ToString("yyyy-MM-dd");
    var fechaDesde = Context.Request.Query["FechaDesde"].FirstOrDefault() ?? firstDay;
    var fechaHasta = Context.Request.Query["FechaHasta"].FirstOrDefault() ?? currentDay;
    var search = Context.Request.Query["Search"].FirstOrDefault();

    static string EstadoRegistroTexto(EstadoRegistro estado) =>
        estado == EstadoRegistro.Activo ? "ACTIVO" : "ANULADO";
}

<div class="toolbar">
    <form method="get" class="search-form">
        <input name="FechaDesde" class="form-control form-control-sm" type="date" value="@fechaDesde" />
        <input name="FechaHasta" class="form-control form-control-sm" type="date" value="@fechaHasta" />
        <input name="Search" class="form-control form-control-sm" value="@search" placeholder="Tipo o descripcion" />
        <button class="btn btn-sm btn-primary">Buscar</button>
    </form>
    <a class="btn btn-sm btn-success" asp-action="Create">Registrar Ingreso</a>
</div>

<table class="table table-sm table-striped data-grid">
    <thead><tr><th>Fecha</th><th>Tipo Ingreso</th><th>Descripcion</th><th>Medio Pago</th><th class="text-end">Importe</th><th>Estado</th><th class="text-end actions-heading">Acciones</th></tr></thead>
    <tbody>
    @foreach (var item in Model.Items)
    {
        <tr>
            <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
            <td>@item.TipoIngreso</td>
            <td>@item.Descripcion</td>
            <td>@item.MedioPago</td>
            <td class="text-end">S/ @item.Importe.ToString("N2")</td>
            <td><span class="status-badge @(item.Estado == EstadoRegistro.Activo ? "active" : "danger")">@EstadoRegistroTexto(item.Estado)</span></td>
            <td class="actions-cell">
                <div class="quote-actions">
                    <a class="icon-btn" asp-action="Visualizar" asp-route-id="@item.IngresoId" title="Visualizar" aria-label="Visualizar">
                        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6Z" /><path d="M12 9a3 3 0 1 1 0 6 3 3 0 0 1 0-6Z" /></svg>
                    </a>
                    @if (item.Estado == EstadoRegistro.Activo)
                    {
                        <a class="icon-btn" asp-action="Edit" asp-route-id="@item.IngresoId" title="Editar" aria-label="Editar">
                            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 20h9" /><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z" /></svg>
                        </a>
                        <form asp-action="Anular" method="post" class="icon-form" onsubmit="return solicitarMotivoAnulacionIngreso(this);">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.IngresoId" />
                            <input type="hidden" name="motivo" value="" />
                            <button type="submit" class="icon-btn danger" title="Anular" aria-label="Anular">
                                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18 6 6 18" /><path d="m6 6 12 12" /></svg>
                            </button>
                        </form>
                    }
                </div>
            </td>
        </tr>
    }
    </tbody>
</table>

@await Html.PartialAsync("_Pager", Model)

<script>
    function solicitarMotivoAnulacionIngreso(form) {
        const motivo = prompt("Ingrese el motivo de anulacion del ingreso:");
        if (motivo === null) return false;
        const limpio = motivo.trim();
        if (!limpio) {
            alert("Debe ingresar el motivo de anulacion.");
            return false;
        }

        form.querySelector("input[name='motivo']").value = limpio;
        return confirm("Confirmar anulacion del ingreso?");
    }
</script>
