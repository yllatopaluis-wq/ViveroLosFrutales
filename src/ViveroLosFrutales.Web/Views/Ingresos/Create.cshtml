@model IngresoEditDto
@using System.Text.Json
@{
    var readOnly = ViewData["ReadOnly"] as bool? == true;
    ViewData["Title"] = readOnly ? "Visualizar Ingreso" : Model.IngresoId == 0 ? "Registrar Ingreso" : "Editar Ingreso";
    var tiposIngreso = ViewBag.CategoriasIngreso as IReadOnlyList<CategoriaIngresoOptionDto> ?? Array.Empty<CategoriaIngresoOptionDto>();
    var tipoActual = (Model.TipoIngreso ?? string.Empty).Trim().ToUpperInvariant();
    var proveedorSeleccionado = Model.Proveedores.FirstOrDefault(x => x.ProveedorId == Model.ProveedorId);
    var proveedorTexto = proveedorSeleccionado is null ? string.Empty : $"{proveedorSeleccionado.RazonSocial} - {proveedorSeleccionado.NumeroDocumento}";
    var proveedoresJson = JsonSerializer.Serialize(Model.Proveedores.Select(x => new
    {
        id = x.ProveedorId,
        tipoDocumento = x.TipoDocumento.ToString(),
        documento = x.NumeroDocumento,
        nombre = x.RazonSocial,
        razonSocial = x.RazonSocial,
        nombreComercial = x.NombreComercial,
        telefono = x.Telefono,
        direccion = x.Direccion,
        texto = $"{x.RazonSocial} - {x.NumeroDocumento}"
    }));
    var bloques = Model.FormularioConfiguracion.Bloques.ToDictionary(x => x.Bloque, x => x, StringComparer.OrdinalIgnoreCase);
    var campos = Model.FormularioConfiguracion.Campos.ToDictionary(x => $"{x.Bloque}:{x.Campo}", x => x, StringComparer.OrdinalIgnoreCase);
    bool BloqueVisible(string bloque) => !bloques.TryGetValue(bloque, out var config) || config.Visible;
    FormularioCampoDto Campo(string bloque, string campo, string etiquetaDefault, int ordenDefault = 999, string anchoDefault = "2") =>
        campos.TryGetValue($"{bloque}:{campo}", out var config)
            ? config
            : new FormularioCampoDto(bloque, campo, etiquetaDefault, true, false, false, ordenDefault, anchoDefault, null);
    bool CampoVisible(string bloque, string campo) => Campo(bloque, campo, campo).Visible;
    string Etiqueta(string bloque, string campo, string fallback) => Campo(bloque, campo, fallback).Etiqueta;
    bool Obligatorio(string bloque, string campo) => Campo(bloque, campo, campo).Obligatorio;
    bool SoloLectura(string bloque, string campo) => Campo(bloque, campo, campo).SoloLectura || readOnly;
    int Ancho(string bloque, string campo, string fallback = "2")
    {
        var raw = Campo(bloque, campo, campo, 999, fallback).Ancho;
        return int.TryParse(raw, out var ancho) && ancho is >= 1 and <= 12 ? ancho : int.Parse(fallback);
    }
    string ColClass(string bloque, string campo, string fallback = "2") => $"col-12 col-md-{Ancho(bloque, campo, fallback)}";
    string RequiredMark(string bloque, string campo) => Obligatorio(bloque, campo) ? " *" : string.Empty;
    var generalFields = Model.FormularioConfiguracion.Campos
        .Where(x => string.Equals(x.Bloque, "GENERAL", StringComparison.OrdinalIgnoreCase) && x.Visible)
        .OrderBy(x => x.Orden)
        .ToList();
    var totalEtiqueta = Etiqueta("TOTALES", "Total", "Total");
}

<form asp-action="Create" method="post" class="document-form comprobante-form quote-form compra-form">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger"></div>
    <input asp-for="IngresoId" type="hidden" />
    <input asp-for="TipoIngreso" type="hidden" id="tipoIngresoNombre" />

    <section class="quote-panel quote-header-panel @(BloqueVisible("GENERAL") ? "" : "d-none")">
        <div class="quote-panel-title">
            <span class="document-section-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M6 3h9l4 4v14H6z" /><path d="M14 3v5h5M9 12h6M9 16h4" /></svg></span>
            <strong>@(bloques.TryGetValue("GENERAL", out var generalBlock) ? generalBlock.Titulo : "Informacion general")</strong>
        </div>
        <div class="row g-2 quote-general-row">
            @foreach (var field in generalFields)
            {
                switch (field.Campo)
                {
                    case "Fecha":
                        <label class="@ColClass("GENERAL", "Fecha", "2")"><span>@field.Etiqueta@RequiredMark("GENERAL", "Fecha")</span><input asp-for="Fecha" class="form-control" type="date" readonly="@(SoloLectura("GENERAL", "Fecha"))" required="@(field.Obligatorio)" /></label>
                        break;
                    case "TipoIngreso":
                        <label class="@ColClass("GENERAL", "TipoIngreso", "2")"><span>@field.Etiqueta@RequiredMark("GENERAL", "TipoIngreso")</span><select asp-for="CategoriaIngresoId" class="form-select" id="categoriaIngresoId" disabled="@(SoloLectura("GENERAL", "TipoIngreso"))" required="@(field.Obligatorio)"><option value="">Seleccione tipo</option>@foreach (var tipo in tiposIngreso) { <option value="@tipo.CategoriaIngresoId" data-nombre="@tipo.Nombre" selected="@(Model.CategoriaIngresoId == tipo.CategoriaIngresoId || tipoActual == tipo.Nombre)">@tipo.Nombre</option> }</select></label>
                        if (SoloLectura("GENERAL", "TipoIngreso")) { <input asp-for="CategoriaIngresoId" type="hidden" /> }
                        break;
                    case "MedioPago":
                        <label class="@ColClass("GENERAL", "MedioPago", "2")"><span>@field.Etiqueta@RequiredMark("GENERAL", "MedioPago")</span><select asp-for="MedioPago" class="form-select" id="medioPagoFinanza" disabled="@(SoloLectura("GENERAL", "MedioPago"))" required="@(field.Obligatorio)"><option value="EFECTIVO">Efectivo</option><option value="TRANSFERENCIA">Transferencia</option><option value="YAPE">Yape</option><option value="TARJETA DEBITO">Tarjeta debito</option><option value="TARJETA CREDITO">Tarjeta credito</option></select></label>
                        if (SoloLectura("GENERAL", "MedioPago")) { <input asp-for="MedioPago" type="hidden" /> }
                        break;
                    case "CuentaOrigen":
                        <label class="@ColClass("GENERAL", "CuentaOrigen", "2")"><span>@field.Etiqueta@RequiredMark("GENERAL", "CuentaOrigen")</span><select asp-for="CuentaFinancieraId" class="form-select" id="cuentaFinancieraFinanza" disabled="@(SoloLectura("GENERAL", "CuentaOrigen"))"><option value="">Caja principal</option>@foreach (var cuenta in Model.CuentasFinancieras) { <option value="@cuenta.CuentaFinancieraId" data-tipo="@cuenta.Tipo" selected="@(Model.CuentaFinancieraId == cuenta.CuentaFinancieraId)">@cuenta.Nombre</option> }</select></label>
                        if (SoloLectura("GENERAL", "CuentaOrigen")) { <input asp-for="CuentaFinancieraId" type="hidden" /> }
                        break;
                    case "Importe":
                        <label class="@ColClass("GENERAL", "Importe", "2")"><span>@field.Etiqueta@RequiredMark("GENERAL", "Importe")</span><input asp-for="Importe" class="form-control text-end" id="importeFinanza" type="number" step="0.01" min="0.01" readonly="@(SoloLectura("GENERAL", "Importe"))" required="@(field.Obligatorio)" /></label>
                        break;
                    case "Descripcion":
                        <label class="@ColClass("GENERAL", "Descripcion", "2")"><span>@field.Etiqueta@RequiredMark("GENERAL", "Descripcion")</span><input asp-for="Descripcion" class="form-control" readonly="@(SoloLectura("GENERAL", "Descripcion"))" required="@(field.Obligatorio)" /></label>
                        break;
                    case "DocumentoReferencia":
                        <label class="@ColClass("GENERAL", "DocumentoReferencia", "2")"><span>@field.Etiqueta@RequiredMark("GENERAL", "DocumentoReferencia")</span><input asp-for="DocumentoReferencia" class="form-control" readonly="@(SoloLectura("GENERAL", "DocumentoReferencia"))" /></label>
                        break;
                }
            }
        </div>
    </section>

    <section class="quote-panel @(BloqueVisible("PROVEEDOR") ? "" : "d-none")">
        <div class="quote-panel-title">
            <span class="document-section-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M20 21a8 8 0 0 0-16 0" /><path d="M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z" /></svg></span>
            <strong>@(bloques.TryGetValue("PROVEEDOR", out var proveedorBlock) ? proveedorBlock.Titulo : "Proveedor")</strong>
        </div>
        @if (CampoVisible("PROVEEDOR", "ProveedorBuscador"))
        {
            <div class="quote-client-search">
                <input class="form-control" id="proveedorSearch" value="@proveedorTexto" placeholder="Buscar proveedor por razon social, documento o telefono..." autocomplete="off" disabled="@readOnly" required="@(Obligatorio("PROVEEDOR", "ProveedorBuscador"))" />
                <div class="producto-search-results proveedor-search-results" id="proveedorSearchResults" hidden></div>
                <input asp-for="ProveedorId" type="hidden" id="proveedorId" />
            </div>
        }
        else
        {
            <input asp-for="ProveedorId" type="hidden" id="proveedorId" />
        }
        <div class="quote-client-summary quote-client-summary-line">
            @if (CampoVisible("PROVEEDOR", "ProveedorRazonSocial")) { <div class="client-name-block"><span>@Etiqueta("PROVEEDOR", "ProveedorRazonSocial", "Razon social")</span><strong id="proveedorResumenNombre">@(proveedorSeleccionado?.RazonSocial ?? "Seleccione proveedor")</strong></div> }
            @if (CampoVisible("PROVEEDOR", "ProveedorTipoDocumento")) { <div><span>@Etiqueta("PROVEEDOR", "ProveedorTipoDocumento", "Tipo documento")</span><strong id="proveedorResumenTipoDocumento">@(proveedorSeleccionado is null ? "-" : proveedorSeleccionado.TipoDocumento.ToString())</strong></div> }
            @if (CampoVisible("PROVEEDOR", "ProveedorNumeroDocumento")) { <div><span>@Etiqueta("PROVEEDOR", "ProveedorNumeroDocumento", "Numero documento")</span><strong id="proveedorResumenDocumento">@(proveedorSeleccionado?.NumeroDocumento ?? "-")</strong></div> }
            @if (CampoVisible("PROVEEDOR", "ProveedorDireccion")) { <div><span>@Etiqueta("PROVEEDOR", "ProveedorDireccion", "Direccion")</span><strong id="proveedorResumenDireccion">@(string.IsNullOrWhiteSpace(proveedorSeleccionado?.Direccion) ? "-" : proveedorSeleccionado.Direccion)</strong></div> }
        </div>
    </section>

    <section class="quote-panel quote-observations-panel @(BloqueVisible("OBSERVACIONES") && CampoVisible("OBSERVACIONES", "Observacion") ? "" : "d-none")">
        <div class="quote-panel-title">
            <span class="document-section-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M5 4h14v16H5z" /><path d="M8 8h8M8 12h8M8 16h5" /></svg></span>
            <strong>@(bloques.TryGetValue("OBSERVACIONES", out var observacionesBlock) ? observacionesBlock.Titulo : "Observaciones")</strong>
        </div>
        <textarea asp-for="Observacion" class="form-control quote-observations-input" rows="2" readonly="@(SoloLectura("OBSERVACIONES", "Observacion"))" placeholder="@Etiqueta("OBSERVACIONES", "Observacion", "Observaciones")"></textarea>
    </section>

    <div class="document-total-strip quote-total-strip @(BloqueVisible("TOTALES") && CampoVisible("TOTALES", "Total") ? "" : "d-none")" aria-label="Totales">
        <div class="grand-total"><span>@totalEtiqueta</span><strong id="finanzaTotal">S/ @Model.Importe.ToString("N2")</strong></div>
    </div>

    <div class="document-bottom-actions quote-bottom-actions @(BloqueVisible("ACCIONES") ? "" : "d-none")">
        @if (!readOnly && CampoVisible("ACCIONES", "Guardar"))
        {
            <button class="document-save-btn" type="submit">@Etiqueta("ACCIONES", "Guardar", "Guardar ingreso")</button>
        }
        @if (CampoVisible("ACCIONES", "Volver"))
        {
            <a class="document-more-btn" asp-action="Index">@Etiqueta("ACCIONES", "Volver", "Volver")</a>
        }
    </div>
</form>

@section Scripts {
    <script>
        (() => {
            const proveedores = @Html.Raw(proveedoresJson);
            const search = document.getElementById('proveedorSearch');
            const results = document.getElementById('proveedorSearchResults');
            const proveedorId = document.getElementById('proveedorId');
            const resumenNombre = document.getElementById('proveedorResumenNombre');
            const resumenTipo = document.getElementById('proveedorResumenTipoDocumento');
            const resumenDocumento = document.getElementById('proveedorResumenDocumento');
            const resumenDireccion = document.getElementById('proveedorResumenDireccion');

            if (search && results && proveedorId) {
                if (results.parentElement !== document.body) document.body.appendChild(results);
                let activeIndex = -1;
                let currentItems = [];
                let pointerInResults = false;
                const normalizar = (value) => String(value || '').normalize('NFD').replace(/[\u0300-\u036f]/g, '').trim().toUpperCase();
                const escapeHtml = (value) => String(value ?? '').replaceAll('&', '&amp;').replaceAll('<', '&lt;').replaceAll('>', '&gt;').replaceAll('"', '&quot;').replaceAll("'", '&#039;');
                const filtrar = () => {
                    const term = normalizar(search.value);
                    return proveedores.filter((proveedor) => !term
                        || normalizar(proveedor.texto).includes(term)
                        || normalizar(proveedor.nombre).includes(term)
                        || normalizar(proveedor.documento).includes(term)
                        || normalizar(proveedor.direccion).includes(term)
                        || normalizar(proveedor.nombreComercial).includes(term)).slice(0, 25);
                };
                const cerrar = () => { results.hidden = true; activeIndex = -1; };
                const posicionar = () => {
                    const rect = search.getBoundingClientRect();
                    results.style.left = `${rect.left}px`;
                    results.style.top = `${rect.bottom + 4}px`;
                    results.style.width = `${rect.width}px`;
                };
                const pintar = () => {
                    currentItems = filtrar();
                    activeIndex = currentItems.length ? 0 : -1;
                    posicionar();
                    results.innerHTML = currentItems.length
                        ? currentItems.map((proveedor, index) => `<button type="button" class="producto-search-option${index === 0 ? ' active' : ''}" data-id="${escapeHtml(proveedor.id)}"><strong>${escapeHtml(proveedor.nombre)}</strong><span>${escapeHtml(proveedor.tipoDocumento || '-')} | ${escapeHtml(proveedor.documento || '-')}</span><em>${escapeHtml(proveedor.direccion || '-')}</em></button>`).join('')
                        : '<div class="producto-search-empty">Sin coincidencias</div>';
                    results.hidden = false;
                };
                const activar = (index) => {
                    if (!currentItems.length) return;
                    activeIndex = (index + currentItems.length) % currentItems.length;
                    results.querySelectorAll('.producto-search-option').forEach((item, itemIndex) => {
                        item.classList.toggle('active', itemIndex === activeIndex);
                        if (itemIndex === activeIndex) item.scrollIntoView({ block: 'nearest' });
                    });
                };
                const seleccionar = (proveedor) => {
                    if (!proveedor) return;
                    proveedorId.value = proveedor.id;
                    search.value = proveedor.texto || `${proveedor.nombre} - ${proveedor.documento}`;
                    if (resumenNombre) resumenNombre.textContent = proveedor.nombre || 'Seleccione proveedor';
                    if (resumenTipo) resumenTipo.textContent = proveedor.tipoDocumento || '-';
                    if (resumenDocumento) resumenDocumento.textContent = proveedor.documento || '-';
                    if (resumenDireccion) resumenDireccion.textContent = proveedor.direccion || '-';
                    cerrar();
                };
                const resolver = () => {
                    const exacto = proveedores.find((proveedor) => normalizar(proveedor.texto) === normalizar(search.value));
                    if (exacto) seleccionar(exacto);
                };
                search.addEventListener('input', () => { proveedorId.value = ''; pintar(); });
                search.addEventListener('focus', pintar);
                search.addEventListener('blur', () => window.setTimeout(() => { if (!pointerInResults) { resolver(); cerrar(); } }, 150));
                search.addEventListener('keydown', (event) => {
                    if (event.key === 'ArrowDown') { event.preventDefault(); if (results.hidden) pintar(); else activar(activeIndex + 1); }
                    if (event.key === 'ArrowUp') { event.preventDefault(); if (results.hidden) pintar(); else activar(activeIndex - 1); }
                    if (event.key === 'Enter') { event.preventDefault(); seleccionar(currentItems[activeIndex] || currentItems[0]); }
                    if (event.key === 'Escape') { event.preventDefault(); cerrar(); }
                });
                results.addEventListener('pointerenter', () => { pointerInResults = true; });
                results.addEventListener('pointerleave', () => { pointerInResults = false; });
                results.addEventListener('mousedown', (event) => {
                    const option = event.target.closest('.producto-search-option');
                    if (!option) return;
                    event.preventDefault();
                    seleccionar(proveedores.find((proveedor) => String(proveedor.id) === String(option.dataset.id)));
                });
                window.addEventListener('resize', cerrar);
                window.addEventListener('scroll', (event) => { if (!results.contains(event.target)) cerrar(); }, true);
            }

            const tipo = document.getElementById('categoriaIngresoId');
            const tipoNombre = document.getElementById('tipoIngresoNombre');
            const syncTipo = () => { if (tipo && tipoNombre) tipoNombre.value = tipo.selectedOptions[0]?.dataset.nombre || tipo.selectedOptions[0]?.textContent || tipoNombre.value; };
            tipo?.addEventListener('change', syncTipo);
            syncTipo();
            const importe = document.getElementById('importeFinanza');
            const total = document.getElementById('finanzaTotal');
            const syncTotal = () => { if (total && importe) total.textContent = `S/ ${(Number(importe.value || 0)).toLocaleString('es-PE', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`; };
            importe?.addEventListener('input', syncTotal);
            syncTotal();
            window.viveroFiltrarCuentasPorMedioPago?.({ medioPagoSelector: '#medioPagoFinanza', cuentaSelector: '#cuentaFinancieraFinanza' });
        })();
    </script>
}



