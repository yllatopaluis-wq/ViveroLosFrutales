@model PagedResult<TransferenciaListDto>
@{
    ViewData["Title"] = "Transferencias";
    var today = PeruDateTime.Today;
    var firstDay = new DateTime(today.Year, today.Month, 1).ToString("yyyy-MM-dd");
    var currentDay = today.ToString("yyyy-MM-dd");
    var fechaDesde = Context.Request.Query["FechaDesde"].FirstOrDefault() ?? firstDay;
    var fechaHasta = Context.Request.Query["FechaHasta"].FirstOrDefault() ?? currentDay;
    var search = Context.Request.Query["Search"].FirstOrDefault();
    var pageSize = Context.Request.Query["PageSize"].FirstOrDefault() ?? Model.PageSize.ToString();
    static string Money(decimal value) => $"S/ {value:N2}";
}

<section class="comprobantes-page ops-docs-page treasury-page">
    <form method="get" class="comprobantes-toolbar sales-docs-toolbar">
        <label class="comprobantes-search"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7" /><path d="m20 20-4-4" /></svg><input name="Search" value="@search" placeholder="Buscar cuenta u observacion..." autocomplete="off" />@if (!string.IsNullOrWhiteSpace(search)) { <a class="search-clear" asp-action="Index" asp-route-FechaDesde="@fechaDesde" asp-route-FechaHasta="@fechaHasta" asp-route-PageSize="@pageSize" aria-label="Limpiar busqueda">&times;</a> }</label>
        <label class="filter-field"><span>Desde</span><input name="FechaDesde" type="date" value="@fechaDesde" /></label>
        <label class="filter-field"><span>Hasta</span><input name="FechaHasta" type="date" value="@fechaHasta" /></label>
        <input type="hidden" name="PageSize" value="@pageSize" />
        <button class="btn-search" type="submit"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7" /><path d="m20 20-4-4" /></svg>Buscar</button>
        <a class="btn-export" asp-action="Create"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 5v14" /><path d="M5 12h14" /></svg>Nueva</a>
    </form>

    <div class="comprobantes-list ops-docs-list">
        <div class="comprobantes-head ops-docs-head"><span>Fecha</span><span>Origen</span><span>Destino</span><span>Monto</span><span>Estado</span><span>Acciones</span></div>
        @if (!Model.Items.Any())
        {
            <div class="comprobantes-empty"><strong>No hay transferencias</strong><span>Registra un movimiento entre cuentas financieras.</span></div>
        }
        else
        {
            @foreach (var item in Model.Items)
            {
                <article class="comprobante-row ops-docs-row">
                    <div class="comprobante-main"><span class="comprobante-icon @(item.Estado == EstadoRegistro.Activo ? "success" : "danger")"><svg viewBox="0 0 24 24"><path d="M7 7h11v11" /><path d="M7 17 18 6" /><path d="M17 17H6V6" /></svg></span><span class="comprobante-copy"><strong>@item.Fecha.ToString("dd/MM/yyyy")</strong><small>@(string.IsNullOrWhiteSpace(item.Observacion) ? "Transferencia" : item.Observacion)</small></span></div>
                    <div class="comprobante-client"><strong>@item.CuentaOrigen</strong><small>Egreso</small></div>
                    <div class="comprobante-client"><strong>@item.CuentaDestino</strong><small>Ingreso</small></div>
                    <div class="comprobante-total">@Money(item.Monto)</div>
                    <div class="comprobante-sunat"><span class="pill @(item.Estado == EstadoRegistro.Activo ? "success" : "danger")">@(item.Estado == EstadoRegistro.Activo ? "Activo" : "Anulado")</span></div>
                    <div class="comprobante-actions">
                        <details class="row-actions-menu">
                            <summary aria-label="Abrir acciones"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="5" r="1.5" /><circle cx="12" cy="12" r="1.5" /><circle cx="12" cy="19" r="1.5" /></svg></summary>
                            <div class="row-actions-panel">
                                @if (item.Estado == EstadoRegistro.Activo)
                                {
                                    <form asp-action="Anular" method="post" onsubmit="return solicitarMotivoAnulacionTransferencia(this);">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.TransferenciaFinancieraId" />
                                        <input type="hidden" name="motivo" value="" />
                                        <button type="submit" class="danger"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 6h18" /><path d="M8 6V4h8v2M19 6l-1 14H6L5 6" /><path d="M10 11v5M14 11v5" /></svg> Anular</button>
                                    </form>
                                }
                            </div>
                        </details>
                    </div>
                </article>
            }
        }
    </div>
    @await Html.PartialAsync("_Pager", Model)
</section>

<script>
function solicitarMotivoAnulacionTransferencia(form) {
    const motivo = prompt('Ingrese el motivo de anulacion de la transferencia:');
    if (!motivo || !motivo.trim()) return false;
    form.querySelector('input[name="motivo"]').value = motivo.trim();
    return true;
}
</script>
