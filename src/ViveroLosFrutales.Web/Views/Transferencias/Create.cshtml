@model TransferenciaEditDto
@{
    ViewData["Title"] = "Registrar Transferencia";
    static string TipoTexto(TipoCuentaFinanciera tipo) => tipo switch
    {
        TipoCuentaFinanciera.CAJA => "Caja",
        TipoCuentaFinanciera.BANCO => "Banco",
        TipoCuentaFinanciera.BILLETERA => "Billetera",
        _ => tipo.ToString()
    };
}

<form asp-action="Create" method="post" class="dense-form document-entry-form">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <fieldset class="form-grid cols-4">
        <label>Fecha<input asp-for="Fecha" class="form-control form-control-sm" type="date" /></label>
        <label>
            Cuenta origen
            <select asp-for="CuentaOrigenId" class="form-select form-select-sm">
                <option value="">Seleccione cuenta</option>
                @foreach (var cuenta in Model.Cuentas)
                {
                    <option value="@cuenta.CuentaFinancieraId" selected="@(Model.CuentaOrigenId == cuenta.CuentaFinancieraId)">@cuenta.Nombre - @TipoTexto(cuenta.Tipo)</option>
                }
            </select>
        </label>
        <label>
            Cuenta destino
            <select asp-for="CuentaDestinoId" class="form-select form-select-sm">
                <option value="">Seleccione cuenta</option>
                @foreach (var cuenta in Model.Cuentas)
                {
                    <option value="@cuenta.CuentaFinancieraId" selected="@(Model.CuentaDestinoId == cuenta.CuentaFinancieraId)">@cuenta.Nombre - @TipoTexto(cuenta.Tipo)</option>
                }
            </select>
        </label>
        <label>Monto<input asp-for="Monto" class="form-control form-control-sm" type="number" step="0.01" min="0.01" /></label>
        <label class="span-4">Observacion<input asp-for="Observacion" class="form-control form-control-sm" maxlength="500" /></label>
    </fieldset>
    @if (Model.Cuentas.Count < 2)
    {
        <div class="alert alert-warning mt-3">Debe existir al menos dos cuentas financieras activas para registrar una transferencia.</div>
    }
    <div class="form-actions">
        @if (Model.Cuentas.Count < 2)
        {
            <button class="btn btn-sm btn-primary" disabled>Guardar</button>
        }
        else
        {
            <button class="btn btn-sm btn-primary">Guardar</button>
        }
        <a class="btn btn-sm btn-outline-secondary" asp-action="Index">Volver</a>
    </div>
</form>

