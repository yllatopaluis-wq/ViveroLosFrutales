@model RegistrarCobroDto
@{
    ViewData["Title"] = "Registrar Pago";
    var referencia = ViewData["Referencia"] as string ?? string.Empty;
    var saldoPendiente = ViewData["SaldoPendiente"] as decimal? ?? 0;
}

<form asp-action="RegistrarPago" method="post" class="dense-form">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger"></div>
    <input asp-for="ComprobanteId" type="hidden" />

    <div class="finance-summary">
        <div><span>Comprobante</span><strong>@referencia</strong></div>
        <div><span>Saldo pendiente</span><strong>S/ @saldoPendiente.ToString("N2")</strong></div>
    </div>

    <div class="form-grid cols-4">
        <label>Fecha cobro<input asp-for="FechaCobro" class="form-control form-control-sm" type="date" /></label>
        <label>Monto<input asp-for="Monto" class="form-control form-control-sm text-end" type="number" step="0.01" min="0.01" /></label>
        <label>
            Medio pago
            <select asp-for="MedioPago" class="form-select form-select-sm">
                <option value="EFECTIVO">Efectivo</option>
                <option value="YAPE">Yape</option>
                <option value="PLIN">Plin</option>
                <option value="TRANSFERENCIA">Transferencia</option>
                <option value="TARJETA">Tarjeta</option>
                <option value="OTRO">Otro</option>
            </select>
        </label>
        <label class="span-2">Observacion<input asp-for="Observacion" class="form-control form-control-sm" /></label>
    </div>

    <div class="form-actions">
        <button class="btn btn-sm btn-primary">Guardar pago</button>
        <a class="btn btn-sm btn-outline-secondary" asp-action="Index">Volver</a>
    </div>
</form>
