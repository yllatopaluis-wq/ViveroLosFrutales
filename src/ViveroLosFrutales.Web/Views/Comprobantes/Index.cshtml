@model PagedResult<ComprobanteListDto>
@{
    ViewData["Title"] = "Comprobantes";
    var today = PeruDateTime.Today;
    var firstDay = new DateTime(today.Year, today.Month, 1).ToString("yyyy-MM-dd");
    var currentDay = today.ToString("yyyy-MM-dd");
    var fechaDesde = Context.Request.Query["FechaDesde"].FirstOrDefault() ?? firstDay;
    var fechaHasta = Context.Request.Query["FechaHasta"].FirstOrDefault() ?? currentDay;
    var search = Context.Request.Query["Search"].FirstOrDefault();
    var estado = Context.Request.Query["Estado"].FirstOrDefault();
    var pageSize = Context.Request.Query["PageSize"].FirstOrDefault() ?? Model.PageSize.ToString();
}

@functions {
    private static string EstadoPagoTexto(EstadoPagoComprobante estado) => estado switch
    {
        EstadoPagoComprobante.PENDIENTE => "Pendiente",
        EstadoPagoComprobante.PAGO_PARCIAL => "Parcial",
        EstadoPagoComprobante.PAGADO => "Pagado",
        _ => estado.ToString()
    };

    private static string EstadoPagoClass(EstadoPagoComprobante estado) => estado switch
    {
        EstadoPagoComprobante.PAGADO => "success",
        EstadoPagoComprobante.PAGO_PARCIAL => "info",
        _ => "warning"
    };

    private static string EstadoRegistroTexto(EstadoRegistro estado) =>
        estado == EstadoRegistro.Activo ? "Activo" : "Anulado";

    private static string EstadoRegistroClass(EstadoRegistro estado) =>
        estado == EstadoRegistro.Activo ? "success" : "danger";

    private static string SunatTexto(ComprobanteListDto item) => item.EstadoSunat switch
    {
        EstadoSunat.Aceptado => "SUNAT OK",
        EstadoSunat.Rechazado => "SUNAT No",
        EstadoSunat.Observado => "Observado",
        EstadoSunat.Pendiente => "Pendiente",
        _ => "No enviado"
    };

    private static string SunatClass(ComprobanteListDto item) => item.EstadoSunat switch
    {
        EstadoSunat.Aceptado => "success",
        EstadoSunat.Rechazado => "danger",
        EstadoSunat.Observado => "danger",
        EstadoSunat.Pendiente => "warning",
        _ => "muted"
    };

    private static string RowIconClass(ComprobanteListDto item)
    {
        if (item.Estado == EstadoRegistro.Anulado) return "danger";
        if (item.EstadoPago == EstadoPagoComprobante.PAGADO) return "success";
        return "warning";
    }
}

<section class="comprobantes-page">
    <form method="get" class="comprobantes-toolbar">
        <label class="comprobantes-search">
            <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7" /><path d="m20 20-4-4" /></svg>
            <input name="Search" value="@search" placeholder="Buscar por cliente, serie o n&uacute;mero..." autocomplete="off" />
            @if (!string.IsNullOrWhiteSpace(search))
            {
                <a class="search-clear" asp-action="Index" asp-route-FechaDesde="@fechaDesde" asp-route-FechaHasta="@fechaHasta" asp-route-Estado="@estado" asp-route-PageSize="@pageSize" aria-label="Limpiar b&uacute;squeda">&times;</a>
            }
        </label>

        <label class="filter-field">
            <span>Desde</span>
            <input name="FechaDesde" type="date" value="@fechaDesde" />
        </label>

        <label class="filter-field">
            <span>Hasta</span>
            <input name="FechaHasta" type="date" value="@fechaHasta" />
        </label>

        <label class="filter-field state-field">
            <span>Estado</span>
            <select name="Estado">
                <option value="" selected="@(string.IsNullOrWhiteSpace(estado))">Todos</option>
                <option value="1" selected="@(estado == "1")">Activo</option>
                <option value="2" selected="@(estado == "2")">Anulado</option>
            </select>
        </label>

        <input type="hidden" name="PageSize" value="@pageSize" />
        <button class="btn-search" type="submit">
            <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7" /><path d="m20 20-4-4" /></svg>
            Buscar
        </button>

        <button class="btn-export" type="button" id="exportComprobantesCsv">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3v12" /><path d="m8 11 4 4 4-4" /><path d="M5 20h14" /></svg>
            Exportar
        </button>

    </form>

    @if (TempData["Error"] is string error)
    {
        <div class="alert alert-danger py-2">@error</div>
    }
    @if (TempData["Success"] is string success)
    {
        <div class="alert alert-success py-2">@success</div>
    }

    <div class="comprobantes-list" id="comprobantesList">
        <div class="comprobantes-head" aria-hidden="true">
            <span>Comprobante</span>
            <span>Cliente</span>
            <span>Total</span>
            <span>Estado</span>
            <span>SUNAT / Impresi&oacute;n</span>
            <span>Acciones</span>
        </div>

        @if (!Model.Items.Any())
        {
            <div class="comprobantes-empty">
                <strong>No hay comprobantes</strong>
                <span>Ajusta los filtros o registra un nuevo comprobante.</span>
            </div>
        }
        else
        {
            @foreach (var item in Model.Items)
            {
                var numero = $"{item.Serie}-{item.Correlativo}";
                <article class="comprobante-row" data-csv="@numero|@item.FechaEmision.ToString("dd/MM/yyyy")|@item.Cliente|@item.Documento|@item.Total.ToString("N2")|@EstadoPagoTexto(item.EstadoPago)|@EstadoRegistroTexto(item.Estado)|@SunatTexto(item)">
                    <div class="comprobante-main">
                        <span class="comprobante-icon @RowIconClass(item)" aria-hidden="true">
                            <svg viewBox="0 0 24 24"><path d="M6 3h9l4 4v14H6z" /><path d="M14 3v5h5M9 12h6M9 16h4" /></svg>
                        </span>
                        <span class="comprobante-copy">
                            <strong>@numero</strong>
                            <small>@item.FechaEmision.ToString("dd/MM/yyyy")</small>
                            <small>@item.Documento</small>
                        </span>
                    </div>

                    <div class="comprobante-client">
                        <strong>@item.Cliente</strong>
                        @if (!string.IsNullOrWhiteSpace(item.Direccion))
                        {
                            <small>@item.Direccion</small>
                        }
                    </div>

                    <div class="comprobante-total">S/ @item.Total.ToString("N2")</div>

                    <div class="comprobante-status">
                        <span class="pill @EstadoPagoClass(item.EstadoPago)">@EstadoPagoTexto(item.EstadoPago)</span>
                        <span class="pill @EstadoRegistroClass(item.Estado)">@EstadoRegistroTexto(item.Estado)</span>
                    </div>

                    <div class="comprobante-sunat">
                        <span class="sunat-line @SunatClass(item)">
                            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 16.5a4 4 0 0 0-3.8-5 5 5 0 0 0-9.4-1.7A3.5 3.5 0 0 0 7.5 17H19" /></svg>
                            @SunatTexto(item)
                        </span>
                        <span class="sunat-line">
                            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 9V3h12v6" /><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" /><path d="M6 14h12v8H6Z" /></svg>
                            @(item.DocumentoImpreso ? "Impreso" : "No impreso")
                        </span>
                    </div>

                    <div class="comprobante-actions">
                        <details class="row-actions-menu">
                            <summary aria-label="Abrir acciones">
                                <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="5" r="1.5" /><circle cx="12" cy="12" r="1.5" /><circle cx="12" cy="19" r="1.5" /></svg>
                            </summary>
                            <div class="row-actions-panel">
                                <a asp-action="Details" asp-route-id="@item.ComprobanteId">
                                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6Z" /><path d="M12 9a3 3 0 1 1 0 6 3 3 0 0 1 0-6Z" /></svg>
                                    Ver comprobante
                                </a>
                                <form asp-action="Imprimir" method="post" target="_blank" onsubmit="return registrarImpresionComprobante();">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.ComprobanteId" />
                                    <button type="submit">
                                        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 9V3h12v6" /><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" /><path d="M6 14h12v8H6Z" /></svg>
                                        Imprimir
                                    </button>
                                </form>
                                @if (item.PuedeEditar)
                                {
                                    <a asp-action="Edit" asp-route-id="@item.ComprobanteId">
                                        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 20h9" /><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z" /></svg>
                                        Editar
                                    </a>
                                }
                                @if (item.PuedeRegistrarPago)
                                {
                                    <a asp-action="RegistrarPago" asp-route-id="@item.ComprobanteId">
                                        <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="8" /><path d="M12 7v10M9 10.5c0-1.4 1.3-2 3-2s3 .6 3 2-1.3 2-3 2-3 .6-3 2 1.3 2 3 2 3-.6 3-2" /></svg>
                                        Registrar cobro
                                    </a>
                                }
                                <a asp-action="NotaCredito" asp-route-id="@item.ComprobanteId">
                                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 3h9l4 4v14H6z" /><path d="M14 3v5h5M9 13h6M9 17h4" /></svg>
                                    Generar nota de cr&eacute;dito
                                </a>
                                @if (item.Estado == EstadoRegistro.Activo && !item.DocumentoAceptadoSunat)
                                {
                                    <form asp-action="ConsultarSunat" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.ComprobanteId" />
                                        <button type="submit">
                                            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 16.5a4 4 0 0 0-3.8-5 5 5 0 0 0-9.4-1.7A3.5 3.5 0 0 0 7.5 17H19" /></svg>
                                            Consultar SUNAT
                                        </button>
                                    </form>
                                }
                                @if (item.PuedeAnular)
                                {
                                    <form asp-action="Anular" method="post" onsubmit="return solicitarMotivoAnulacionComprobante(this, @(item.TotalPagado > 0 ? "true" : "false"), @(item.DocumentoImpreso ? "true" : "false"));">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.ComprobanteId" />
                                        <input type="hidden" name="motivo" value="" />
                                        <button type="submit" class="danger">
                                            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 6h18" /><path d="M8 6V4h8v2M19 6l-1 14H6L5 6" /><path d="M10 11v5M14 11v5" /></svg>
                                            Anular comprobante
                                        </button>
                                    </form>
                                }
                            </div>
                        </details>
                    </div>
                </article>
            }
        }
    </div>

    @await Html.PartialAsync("_Pager", Model)
</section>

<script>
    let recargarListadoPorImpresion = false;

    document.querySelectorAll('.row-actions-menu').forEach(menu => {
        menu.addEventListener('toggle', () => {
            if (!menu.open) return;
            document.querySelectorAll('.row-actions-menu[open]').forEach(other => {
                if (other !== menu) other.removeAttribute('open');
            });
        });
    });

    document.addEventListener('click', event => {
        if (event.target.closest('.row-actions-menu')) return;
        document.querySelectorAll('.row-actions-menu[open]').forEach(menu => menu.removeAttribute('open'));
    });

    document.getElementById('exportComprobantesCsv')?.addEventListener('click', () => {
        const rows = Array.from(document.querySelectorAll('.comprobante-row[data-csv]'));
        const header = ['Comprobante','Fecha','Cliente','Documento','Total','Estado pago','Estado','SUNAT'];
        const csvRows = [header, ...rows.map(row => row.dataset.csv.split('|'))]
            .map(cols => cols.map(value => `"${String(value ?? '').replaceAll('"', '""')}"`).join(','));
        const blob = new Blob([csvRows.join('\n')], { type: 'text/csv;charset=utf-8;' });
        const url = URL.createObjectURL(blob);
        const link = document.createElement('a');
        link.href = url;
        link.download = 'comprobantes.csv';
        link.click();
        URL.revokeObjectURL(url);
    });

    function registrarImpresionComprobante() {
        recargarListadoPorImpresion = true;
        setTimeout(() => {
            if (recargarListadoPorImpresion) {
                recargarListadoPorImpresion = false;
                window.location.reload();
            }
        }, 3500);
        return true;
    }

    window.addEventListener('focus', () => {
        if (recargarListadoPorImpresion) {
            recargarListadoPorImpresion = false;
            window.location.reload();
        }
    });

    window.addEventListener('message', event => {
        if (event.origin !== window.location.origin) return;
        if (event.data?.type !== 'comprobante-impreso') return;
        recargarListadoPorImpresion = false;
        window.location.reload();
    });

    function solicitarMotivoAnulacionComprobante(form, tieneCobros, documentoImpreso) {
        if (!documentoImpreso) {
            alert('No se puede anular el comprobante porque aun no fue enviado a Nubefact. Primero debe imprimir el comprobante para poder anularlo.');
            return false;
        }

        const avisoCobros = tieneCobros
            ? 'Este comprobante tiene cobros asociados. Al anularlo, los cobros y sus movimientos de caja permaneceran registrados y se generara una solicitud de devolucion por el monto cobrado.\n\n'
            : '';
        const motivo = prompt(avisoCobros + 'Ingrese el motivo de anulacion del comprobante:');
        if (motivo === null) return false;

        const motivoLimpio = motivo.trim();
        if (!motivoLimpio) {
            alert('Debe ingresar el motivo de anulacion.');
            return false;
        }

        form.querySelector("input[name='motivo']").value = motivoLimpio;
        return confirm('Confirmar anulacion del comprobante?');
    }
</script>

