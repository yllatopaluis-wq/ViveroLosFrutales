@model PagedResult<ComprobanteListDto>
@{
    ViewData["Title"] = "Comprobantes";
    var today = DateTime.Today;
    var firstDay = new DateTime(today.Year, today.Month, 1).ToString("yyyy-MM-dd");
    var currentDay = today.ToString("yyyy-MM-dd");
    var fechaDesde = Context.Request.Query["FechaDesde"].FirstOrDefault() ?? firstDay;
    var fechaHasta = Context.Request.Query["FechaHasta"].FirstOrDefault() ?? currentDay;
    var search = Context.Request.Query["Search"].FirstOrDefault();
}

@functions {
    private static string EstadoPagoTexto(EstadoPagoComprobante estado) => estado switch
    {
        EstadoPagoComprobante.PENDIENTE => "PENDIENTE",
        EstadoPagoComprobante.PAGO_PARCIAL => "PARCIAL",
        EstadoPagoComprobante.PAGADO => "PAGADO",
        _ => estado.ToString()
    };

    private static string EstadoRegistroTexto(EstadoRegistro estado) =>
        estado == EstadoRegistro.Activo ? "ACTIVO" : "ANULADO";
}

<div class="toolbar">
    <form method="get" class="search-form">
        <input name="FechaDesde" class="form-control form-control-sm" type="date" value="@fechaDesde" />
        <input name="FechaHasta" class="form-control form-control-sm" type="date" value="@fechaHasta" />
        <input name="Search" class="form-control form-control-sm" value="@search" placeholder="Buscar serie, cliente o documento" />
        <button class="btn btn-sm btn-primary">Buscar</button>
    </form>
    <a class="btn btn-sm btn-success" asp-action="Create">Crear</a>
</div>

@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger py-2">@error</div>
}
@if (TempData["Success"] is string success)
{
    <div class="alert alert-success py-2">@success</div>
}

<table class="table table-sm table-striped data-grid comprobantes-grid">
    <thead>
        <tr>
            <th class="text-end actions-heading">Acciones</th>
            <th>Numero</th>
            <th>Fecha</th>
            <th>Cliente</th>
            <th>Documento</th>
            <th class="text-end">Total</th>
            <th>Estado Pago</th>
            <th>Doc. Impreso</th>
            <th>Doc. Aceptado SUNAT</th>
            <th>Estado</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.Items)
    {
        <tr>
            <td class="actions-cell">
                <div class="quote-actions">
                    <a class="icon-btn" asp-action="Visualizar" asp-route-id="@item.ComprobanteId" title="Visualizar" aria-label="Visualizar">
                        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6Z" /><path d="M12 9a3 3 0 1 1 0 6 3 3 0 0 1 0-6Z" /></svg>
                    </a>
                    <form asp-action="Imprimir" method="post" class="icon-form" target="_blank" onsubmit="return registrarImpresionComprobante();">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@item.ComprobanteId" />
                        <button type="submit" class="icon-btn" title="Imprimir / descargar" aria-label="Imprimir / descargar">
                            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 9V3h12v6" /><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" /><path d="M6 14h12v8H6Z" /></svg>
                        </button>
                    </form>
                    @if (item.PuedeEditar)
                    {
                        <a class="icon-btn" asp-action="Edit" asp-route-id="@item.ComprobanteId" title="Editar" aria-label="Editar">
                            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 20h9" /><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z" /></svg>
                        </a>
                    }
                    @if (item.PuedeRegistrarPago)
                    {
                        <a class="icon-btn primary" asp-action="RegistrarPago" asp-route-id="@item.ComprobanteId" title="Registrar pago" aria-label="Registrar pago">$</a>
                    }
                    @if (item.PuedeAnular)
                    {
                        <form asp-action="Anular" method="post" class="icon-form" onsubmit="return solicitarMotivoAnulacionComprobante(this, @(item.TotalPagado > 0 ? "true" : "false"), @(item.DocumentoImpreso ? "true" : "false"));">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.ComprobanteId" />
                            <input type="hidden" name="motivo" value="" />
                            <button type="submit" class="icon-btn danger" title="Anular" aria-label="Anular">
                                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18 6 6 18" /><path d="m6 6 12 12" /></svg>
                            </button>
                        </form>
                    }
                </div>
            </td>
            <td>@($"{item.Serie}-{item.Correlativo}")</td>
            <td>@item.FechaEmision.ToString("dd/MM/yyyy")</td>
            <td>@item.Cliente</td>
            <td>@item.Documento</td>
            <td class="text-end">S/ @item.Total.ToString("N2")</td>
            <td><span class="status-badge @(item.EstadoPago == EstadoPagoComprobante.PAGADO ? "active" : item.EstadoPago == EstadoPagoComprobante.PAGO_PARCIAL ? "warning" : string.Empty)">@EstadoPagoTexto(item.EstadoPago)</span></td>
            <td>@(item.DocumentoImpreso ? "SI" : "NO")</td>
            <td>@(item.DocumentoAceptadoSunat ? "SI" : "NO")</td>
            <td>
                <span class="status-badge @(item.Estado == EstadoRegistro.Activo ? "active" : "danger")">@EstadoRegistroTexto(item.Estado)</span>
            </td>
        </tr>
    }
    </tbody>
</table>

@await Html.PartialAsync("_Pager", Model)

<script>
    let recargarListadoPorImpresion = false;

    function registrarImpresionComprobante() {
        recargarListadoPorImpresion = true;
        setTimeout(() => {
            if (recargarListadoPorImpresion) {
                recargarListadoPorImpresion = false;
                window.location.reload();
            }
        }, 3500);
        return true;
    }

    window.addEventListener('focus', () => {
        if (recargarListadoPorImpresion) {
            recargarListadoPorImpresion = false;
            window.location.reload();
        }
    });

    function solicitarMotivoAnulacionComprobante(form, tieneCobros, documentoImpreso) {
        if (!documentoImpreso) {
            alert("No se puede anular el comprobante porque aun no fue enviado a Nubefact. Primero debe imprimir el comprobante para poder anularlo.");
            return false;
        }

        const avisoCobros = tieneCobros
            ? "Este comprobante tiene cobros asociados. Al anularlo, los cobros y sus movimientos de caja permaneceran registrados y se generara una solicitud de devolucion por el monto cobrado.\n\n"
            : "";
        const motivo = prompt(avisoCobros + "Ingrese el motivo de anulacion del comprobante:");
        if (motivo === null) return false;

        const motivoLimpio = motivo.trim();
        if (!motivoLimpio) {
            alert("Debe ingresar el motivo de anulacion.");
            return false;
        }

        form.querySelector("input[name='motivo']").value = motivoLimpio;
        return confirm("Confirmar anulacion del comprobante?");
    }
</script>
