@model ValueTuple<string, string>
@{
    ViewData["Title"] = "Restablecer contrasena";
}

<form method="post" class="dense-form">
    <input name="id" value="@Model.Item1" type="hidden" />
    <div class="form-grid cols-2">
        <label>Nueva contrasena<input name="password" class="form-control form-control-sm" type="password" /></label>
    </div>
    <div class="form-actions">
        <button class="btn btn-sm btn-primary">Restablecer</button>
        <a class="btn btn-sm btn-outline-secondary" asp-action="Index">Volver</a>
    </div>
</form>
