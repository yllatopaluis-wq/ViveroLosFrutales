@model PagedResult<UsuarioListDto>
@{
    ViewData["Title"] = "Usuarios";
}

<div class="toolbar">
    <form method="get" class="search-form">
        <input name="Search" class="form-control form-control-sm" placeholder="Buscar usuario, correo o nombre" />
        <button class="btn btn-sm btn-primary">Buscar</button>
    </form>
    <a class="btn btn-sm btn-success" asp-action="Edit">Crear</a>
</div>

<table class="table table-sm table-striped data-grid">
    <thead><tr><th>Nombres</th><th>Apellidos</th><th>Correo</th><th>Usuario</th><th>Rol</th><th>Activo</th><th></th></tr></thead>
    <tbody>
    @foreach (var item in Model.Items)
    {
        <tr>
            <td>@item.Nombres</td>
            <td>@item.Apellidos</td>
            <td>@item.Correo</td>
            <td>@item.Usuario</td>
            <td>@item.Rol</td>
            <td>@(item.Activo ? "Si" : "No")</td>
            <td class="text-end">
                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.UsuarioId">Editar</a>
                <a class="btn btn-sm btn-outline-secondary" asp-action="RestablecerPassword" asp-route-id="@item.UsuarioId">Clave</a>
            </td>
        </tr>
    }
    </tbody>
</table>
