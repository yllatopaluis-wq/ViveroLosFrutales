@model PagedResult<RolListDto>
@{
    ViewData["Title"] = "Roles";
}

<div class="toolbar">
    <form method="get" class="search-form">
        <input name="Search" class="form-control form-control-sm" placeholder="Buscar rol" />
        <button class="btn btn-sm btn-primary">Buscar</button>
    </form>
    <a class="btn btn-sm btn-success" asp-action="Edit">Crear</a>
</div>

<table class="table table-sm table-striped data-grid">
    <thead><tr><th>Nombre</th><th>Descripcion</th><th>Estado</th><th></th></tr></thead>
    <tbody>
    @foreach (var item in Model.Items)
    {
        <tr>
            <td>@item.Nombre</td>
            <td>@item.Descripcion</td>
            <td>@item.Estado</td>
            <td class="text-end"><a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.RolId">Editar</a></td>
        </tr>
    }
    </tbody>
</table>
