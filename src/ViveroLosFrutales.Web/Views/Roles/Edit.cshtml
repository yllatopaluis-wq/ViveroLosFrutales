@model RolEditDto
@{
    ViewData["Title"] = Model.RolId == 0 ? "Crear rol" : "Editar rol";
    var permisos = ViewBag.Permisos as IReadOnlyList<PermisoDto> ?? Array.Empty<PermisoDto>();
    var grupos = permisos.GroupBy(x => x.Grupo).ToArray();
    var seleccionados = Model.PermisoIds.ToHashSet();
    var totalSeleccionados = permisos.Count(x => seleccionados.Contains(x.PermisoId));
}

<form method="post" class="dense-form document-entry-form role-entry-form">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input asp-for="RolId" type="hidden" />
    <input asp-for="Estado" type="hidden" />

    <section class="form-grid cols-2">
        <label>Nombre<input asp-for="Nombre" class="form-control form-control-sm" autocomplete="off" /></label>
        <label>Descripción<input asp-for="Descripcion" class="form-control form-control-sm" autocomplete="off" /></label>
    </section>

    <section class="role-permission-summary">
        <div>
            <span>Formularios existentes</span>
            <strong>@permisos.Select(x => x.Modulo).Distinct().Count()</strong>
        </div>
        <div>
            <span>Accesos disponibles</span>
            <strong>@permisos.Count</strong>
        </div>
        <div>
            <span>Accesos seleccionados</span>
            <strong id="selectedPermissionCount">@totalSeleccionados</strong>
        </div>
    </section>

    <div class="section-title">Permisos por men&uacute;</div>
    <p class="role-help">Selecciona los accesos que tendr&aacute; el rol. Los m&oacute;dulos se muestran seg&uacute;n las secciones actuales del men&uacute; del ERP.</p>

    <div class="permission-tree role-permission-tree">
        @foreach (var grupo in grupos)
        {
            var formularios = grupo.GroupBy(x => x.Modulo).ToArray();
            <section class="permission-module" data-permission-module>
                <label class="checkline permission-title">
                    <input type="checkbox" data-permission-module-check />
                    <span>@grupo.Key</span>
                    <small>@formularios.Length formularios</small>
                </label>
                <div class="permission-forms">
                    @foreach (var formulario in formularios)
                    {
                        var items = formulario.ToArray();
                        <section class="permission-form" data-permission-form>
                            <label class="checkline permission-subtitle">
                                <input type="checkbox" data-permission-form-check />
                                <span>@items.First().Formulario</span>
                                <small>@items.Length accesos</small>
                            </label>
                            <div class="permission-grid">
                                @foreach (var permiso in items)
                                {
                                    <label class="checkline compact">
                                        <input class="permission-action" type="checkbox" name="PermisoIds" value="@permiso.PermisoId" checked="@seleccionados.Contains(permiso.PermisoId)" />
                                        @permiso.AccionEtiqueta
                                    </label>
                                }
                            </div>
                        </section>
                    }
                </div>
            </section>
        }
    </div>

    <div class="form-actions">
        <button class="btn btn-sm btn-primary">Guardar</button>
        <a class="btn btn-sm btn-outline-secondary" asp-action="Index">Volver</a>
    </div>
</form>

@section Scripts {
    <script>
        (() => {
            const counter = document.getElementById('selectedPermissionCount');
            const tree = document.querySelector('.role-permission-tree');
            if (!counter || !tree) return;
            const update = () => counter.textContent = tree.querySelectorAll('.permission-action:checked').length.toString();
            tree.addEventListener('change', update);
            update();
        })();
    </script>
}
