@model PagedResult<PagoProveedorTesoreriaListDto>
@{
    ViewData["Title"] = "Pagos proveedores";
    var today = PeruDateTime.Today;
    var firstDay = new DateTime(today.Year, today.Month, 1).ToString("yyyy-MM-dd");
    var currentDay = today.ToString("yyyy-MM-dd");
    var fechaDesde = Context.Request.Query["FechaDesde"].FirstOrDefault() ?? firstDay;
    var fechaHasta = Context.Request.Query["FechaHasta"].FirstOrDefault() ?? currentDay;
    var search = Context.Request.Query["Search"].FirstOrDefault();
    var pageSize = Context.Request.Query["PageSize"].FirstOrDefault() ?? Model.PageSize.ToString();
}
@functions {
    private static string EstadoPagoClass(PagoProveedorEstado estado) => estado == PagoProveedorEstado.ACTIVO ? "success" : "danger";
}

<section class="comprobantes-page admin-docs-page">
    <form method="get" class="comprobantes-toolbar admin-docs-toolbar">
        <label class="comprobantes-search">
            <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7" /><path d="m20 20-4-4" /></svg>
            <input name="Search" value="@search" placeholder="Proveedor, documento o medio..." autocomplete="off" />
            @if (!string.IsNullOrWhiteSpace(search))
            {
                <a class="search-clear" asp-action="Index" asp-route-FechaDesde="@fechaDesde" asp-route-FechaHasta="@fechaHasta" asp-route-PageSize="@pageSize" aria-label="Limpiar busqueda">&times;</a>
            }
        </label>
        <label class="filter-field"><span>Desde</span><input name="FechaDesde" type="date" value="@fechaDesde" /></label>
        <label class="filter-field"><span>Hasta</span><input name="FechaHasta" type="date" value="@fechaHasta" /></label>
        <input type="hidden" name="PageSize" value="@pageSize" />
        <button class="btn-search" type="submit"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7" /><path d="m20 20-4-4" /></svg>Buscar</button>
        <button class="btn-export" type="button" id="exportPagosProveedoresCsv"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3v12" /><path d="m8 11 4 4 4-4" /><path d="M5 20h14" /></svg>Exportar</button>
    </form>

    @if (TempData["Error"] is string error) { <div class="alert alert-danger py-2">@error</div> }
    @if (TempData["Success"] is string success) { <div class="alert alert-success py-2">@success</div> }

    <div class="comprobantes-list admin-docs-list">
        <div class="comprobantes-head admin-docs-head"><span>Pago</span><span>Proveedor</span><span>Compra</span><span>Monto</span><span>Cuenta / Estado</span><span>Acciones</span></div>
        @if (!Model.Items.Any())
        {
            <div class="comprobantes-empty"><strong>No hay pagos registrados</strong><span>Los pagos aparecen aqui cuando una compra se paga al contado o cuando registras un pago a proveedor.</span></div>
        }
        else
        {
            @foreach (var item in Model.Items)
            {
                <article class="comprobante-row admin-docs-row" data-csv="@item.FechaPago.ToString("dd/MM/yyyy")|@item.Proveedor|@item.DocumentoCompra|@item.MedioPago|@item.CuentaFinanciera|@item.Monto.ToString("N2")|@item.Estado|@item.Observacion">
                    <div class="comprobante-main"><span class="comprobante-icon @(item.Estado == PagoProveedorEstado.ACTIVO ? "success" : "danger")"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="8" /><path d="M12 7v10M9 10.5c0-1.4 1.3-2 3-2s3 .6 3 2-1.3 2-3 2-3 .6-3 2 1.3 2 3 2 3-.6 3-2" /></svg></span><span class="comprobante-copy"><strong>@item.FechaPago.ToString("dd/MM/yyyy")</strong><small>@item.MedioPago</small></span></div>
                    <div class="comprobante-client"><strong>@item.Proveedor</strong><small>Proveedor</small></div>
                    <div class="comprobante-client"><strong>@item.DocumentoCompra</strong><small>@item.Observacion</small></div>
                    <div class="comprobante-total">S/ @item.Monto.ToString("N2")</div>
                    <div class="comprobante-sunat"><span class="sunat-line muted">@item.CuentaFinanciera</span><span class="pill @EstadoPagoClass(item.Estado)">@item.Estado</span></div>
                    <div class="comprobante-actions">
                        <details class="row-actions-menu">
                            <summary aria-label="Abrir acciones"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="5" r="1.5" /><circle cx="12" cy="12" r="1.5" /><circle cx="12" cy="19" r="1.5" /></svg></summary>
                            <div class="row-actions-panel">
                                @if (item.PuedeAnular)
                                {
                                    <form asp-action="Anular" method="post" onsubmit="return solicitarMotivoAnulacionPagoProveedor(this, '@item.DocumentoCompra');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.PagoProveedorId" />
                                        <input type="hidden" name="motivo" value="" />
                                        <button type="submit" class="danger"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 6h18" /><path d="M8 6V4h8v2M19 6l-1 14H6L5 6" /><path d="M10 11v5M14 11v5" /></svg> Anular pago</button>
                                    </form>
                                }
                            </div>
                        </details>
                    </div>
                </article>
            }
        }
    </div>
    @await Html.PartialAsync("_Pager", Model)
</section>

<script>
document.querySelectorAll('.row-actions-menu').forEach(menu => {
    menu.addEventListener('toggle', () => {
        if (!menu.open) return;
        document.querySelectorAll('.row-actions-menu[open]').forEach(other => { if (other !== menu) other.removeAttribute('open'); });
    });
});
document.addEventListener('click', event => {
    if (event.target.closest('.row-actions-menu')) return;
    document.querySelectorAll('.row-actions-menu[open]').forEach(menu => menu.removeAttribute('open'));
});
function solicitarMotivoAnulacionPagoProveedor(form, documento) {
    const motivo = prompt('Ingrese el motivo de anulacion del pago ' + documento + ':');
    if (motivo === null) return false;
    const motivoLimpio = motivo.trim();
    if (!motivoLimpio) {
        alert('Debe ingresar el motivo de anulacion.');
        return false;
    }
    form.querySelector("input[name='motivo']").value = motivoLimpio;
    return confirm('Confirmar anulacion del pago?');
}
document.getElementById('exportPagosProveedoresCsv')?.addEventListener('click', () => {
    const rows = Array.from(document.querySelectorAll('.admin-docs-row[data-csv]'));
    const header = ["Fecha","Proveedor","Documento compra","Medio pago","Cuenta","Monto","Estado","Observacion"];
    const csvRows = [header, ...rows.map(row => row.dataset.csv.split('|'))].map(cols => cols.map(value => '"' + String(value ?? '').replaceAll('"', '""') + '"').join(','));
    const blob = new Blob([csvRows.join('\n')], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = 'pagos-proveedores.csv';
    link.click();
    URL.revokeObjectURL(url);
});
</script>


