@model IReadOnlyList<CompraListDto>
@{
    ViewData["Title"] = "Compras pendientes de pago";
    var today = PeruDateTime.Today;
    var firstDay = new DateTime(today.Year, today.Month, 1).ToString("yyyy-MM-dd");
    var currentDay = today.ToString("yyyy-MM-dd");
    var fechaDesde = Context.Request.Query["FechaDesde"].FirstOrDefault() ?? firstDay;
    var fechaHasta = Context.Request.Query["FechaHasta"].FirstOrDefault() ?? currentDay;
    var search = Context.Request.Query["Search"].FirstOrDefault();
}
@functions {
    private static string EstadoPagoClass(EstadoPagoCompra estado) => estado == EstadoPagoCompra.PAGADO ? "success" : estado == EstadoPagoCompra.PARCIAL ? "warning" : "info";
}

<section class="comprobantes-page admin-docs-page">
    <form method="get" class="comprobantes-toolbar admin-docs-toolbar">
        <label class="comprobantes-search">
            <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7" /><path d="m20 20-4-4" /></svg>
            <input name="Search" value="@search" placeholder="Proveedor o documento..." autocomplete="off" />
            @if (!string.IsNullOrWhiteSpace(search))
            {
                <a class="search-clear" asp-action="Pendientes" asp-route-FechaDesde="@fechaDesde" asp-route-FechaHasta="@fechaHasta" aria-label="Limpiar busqueda">&times;</a>
            }
        </label>
        <label class="filter-field"><span>Desde</span><input name="FechaDesde" type="date" value="@fechaDesde" /></label>
        <label class="filter-field"><span>Hasta</span><input name="FechaHasta" type="date" value="@fechaHasta" /></label>
        <button class="btn-search" type="submit"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7" /><path d="m20 20-4-4" /></svg>Buscar</button>
        <a class="btn btn-sm btn-secondary" asp-action="Index">Ver pagos</a><button class="btn-export" type="button" id="exportComprasPendientesPagoCsv"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3v12" /><path d="m8 11 4 4 4-4" /><path d="M5 20h14" /></svg>Exportar</button>
    </form>

    @if (TempData["Error"] is string error) { <div class="alert alert-danger py-2">@error</div> }
    @if (TempData["Success"] is string success) { <div class="alert alert-success py-2">@success</div> }

    <div class="comprobantes-list admin-docs-list">
        <div class="comprobantes-head admin-docs-head"><span>Compra</span><span>Proveedor</span><span>Total</span><span>Pagado / Saldo</span><span>Estado</span><span>Acciones</span></div>
        @if (!Model.Any())
        {
            <div class="comprobantes-empty"><strong>No hay cuentas por pagar</strong><span>Ajusta los filtros para encontrar compras pendientes.</span></div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <article class="comprobante-row admin-docs-row" data-csv="@item.Fecha.ToString("dd/MM/yyyy")|@item.Proveedor|@item.Documento|@item.Total.ToString("N2")|@item.TotalPagado.ToString("N2")|@item.SaldoPendiente.ToString("N2")|@item.EstadoPago">
                    <div class="comprobante-main"><span class="comprobante-icon success"><svg viewBox="0 0 24 24"><path d="M6 3h9l4 4v14H6z" /><path d="M14 3v5h5M9 12h6M9 16h4" /></svg></span><span class="comprobante-copy"><strong>@item.Documento</strong><small>@item.Fecha.ToString("dd/MM/yyyy")</small></span></div>
                    <div class="comprobante-client"><strong>@item.Proveedor</strong><small>Proveedor</small></div>
                    <div class="comprobante-total">S/ @item.Total.ToString("N2")</div>
                    <div class="comprobante-status"><span class="sunat-line success">Pagado: S/ @item.TotalPagado.ToString("N2")</span><span class="sunat-line muted">Saldo: S/ @item.SaldoPendiente.ToString("N2")</span></div>
                    <div class="comprobante-sunat"><span class="pill @EstadoPagoClass(item.EstadoPago)">@item.EstadoPago</span></div>
                    <div class="comprobante-actions"><a class="btn btn-sm btn-primary" asp-action="Registrar" asp-route-id="@item.CompraId">Registrar pago</a></div>
                </article>
            }
        }
    </div>
</section>

<script>
document.getElementById('exportComprasPendientesPagoCsv')?.addEventListener('click', () => {
    const rows = Array.from(document.querySelectorAll('.admin-docs-row[data-csv]'));
    const header = ["Fecha","Proveedor","Documento","Total","Pagado","Saldo","Estado pago"];
    const csvRows = [header, ...rows.map(row => row.dataset.csv.split('|'))].map(cols => cols.map(value => '"' + String(value ?? '').replaceAll('"', '""') + '"').join(','));
    const blob = new Blob([csvRows.join('\n')], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = 'compras-pendientes-pago.csv';
    link.click();
    URL.revokeObjectURL(url);
});
</script>

