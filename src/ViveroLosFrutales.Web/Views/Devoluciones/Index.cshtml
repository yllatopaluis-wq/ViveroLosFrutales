@model PagedResult<DevolucionListDto>
@{
    ViewData["Title"] = "Devoluciones";
    var today = DateTime.Today;
    var firstDay = new DateTime(today.Year, today.Month, 1).ToString("yyyy-MM-dd");
    var currentDay = today.ToString("yyyy-MM-dd");
    var fechaDesde = Context.Request.Query["FechaDesde"].FirstOrDefault() ?? firstDay;
    var fechaHasta = Context.Request.Query["FechaHasta"].FirstOrDefault() ?? currentDay;
    var search = Context.Request.Query["Search"].FirstOrDefault();

    static string EstadoCss(EstadoDevolucion estado) => estado switch
    {
        EstadoDevolucion.DEVUELTO => "active",
        EstadoDevolucion.ANULADO => "danger",
        EstadoDevolucion.PARCIAL => "warning",
        _ => string.Empty
    };
}

<div class="toolbar">
    <form method="get" class="search-form">
        <input name="FechaDesde" class="form-control form-control-sm" type="date" value="@fechaDesde" />
        <input name="FechaHasta" class="form-control form-control-sm" type="date" value="@fechaHasta" />
        <input name="Search" class="form-control form-control-sm" value="@search" placeholder="Buscar cliente, proveedor o documento" />
        <button class="btn btn-sm btn-primary">Buscar</button>
    </form>
</div>

@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger py-2">@error</div>
}
@if (TempData["Success"] is string success)
{
    <div class="alert alert-success py-2">@success</div>
}

<table class="table table-sm table-striped data-grid">
    <thead>
        <tr>
            <th>Fecha</th>
            <th>Tipo tercero</th>
            <th>Cliente / Proveedor</th>
            <th>Origen</th>
            <th>Documento origen</th>
            <th class="text-end">Monto original</th>
            <th class="text-end">Monto devuelto</th>
            <th class="text-end">Monto pendiente</th>
            <th>Estado</th>
            <th class="text-end actions-heading">Acciones</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.Items)
    {
        <tr>
            <td>@item.FechaGeneracion.ToString("dd/MM/yyyy")</td>
            <td>@item.TipoTercero</td>
            <td>@item.Tercero</td>
            <td>@item.OrigenDescripcion</td>
            <td>@item.DocumentoOrigen</td>
            <td class="text-end">S/ @item.MontoOriginal.ToString("N2")</td>
            <td class="text-end">S/ @item.MontoDevuelto.ToString("N2")</td>
            <td class="text-end">S/ @item.MontoPendiente.ToString("N2")</td>
            <td><span class="status-badge @EstadoCss(item.Estado)">@item.Estado</span></td>
            <td class="actions-cell">
                <div class="quote-actions">
                    <a class="icon-btn" asp-action="Details" asp-route-id="@item.DevolucionId" title="Ver" aria-label="Ver">
                        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6Z" /><path d="M12 9a3 3 0 1 1 0 6 3 3 0 0 1 0-6Z" /></svg>
                    </a>
                    @if (item.PuedeRegistrarDevolucion)
                    {
                        <a class="icon-btn primary" asp-action="Registrar" asp-route-id="@item.DevolucionId" title="Registrar devolucion" aria-label="Registrar devolucion">$</a>
                    }
                </div>
            </td>
        </tr>
    }
    </tbody>
</table>

@await Html.PartialAsync("_Pager", Model)
