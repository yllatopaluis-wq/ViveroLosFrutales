@model RegistrarDevolucionDto
@{
    var cuentas = Model.CuentasFinancieras ?? Array.Empty<CuentaFinancieraOptionDto>();
    ViewData["Title"] = "Registrar Devolución";
    var mensajeCaja = Model.TipoTercero == TipoTerceroDevolucion.CLIENTE
        ? "Al confirmar se creará un MovimientoCaja de tipo EGRESO. Los ingresos históricos permanecen registrados."
        : "Al confirmar se creará un MovimientoCaja de tipo INGRESO. Los egresos históricos permanecen registrados.";
}

<form asp-action="Registrar" method="post" class="form-card">
    @Html.AntiForgeryToken()
    <input asp-for="DevolucionId" type="hidden" />
    <input asp-for="TipoTercero" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <section class="nota-summary-grid">
        <div class="nota-summary-card"><span>Tipo tercero</span><strong>@Model.TipoTercero</strong></div>
        <div class="nota-summary-card"><span>Cliente / Proveedor</span><strong>@Model.Tercero</strong></div>
        <div class="nota-summary-card"><span>Documento origen</span><strong>@Model.DocumentoOrigen</strong></div>
        <div class="nota-summary-card"><span>Monto pendiente</span><strong>S/ @Model.MontoPendiente.ToString("N2")</strong></div>
    </section>

    <div class="form-grid">
        <label>Monto devolver<input asp-for="MontoDevolver" class="form-control form-control-sm" /></label>
        <label>
            Medio devolución
            <select asp-for="MedioDevolucion" class="form-select form-select-sm">
                <option value="EFECTIVO">Efectivo</option>
                <option value="TRANSFERENCIA">Transferencia</option>
                <option value="YAPE">Yape</option>
                <option value="TARJETA DEBITO">Tarjeta débito</option>
                <option value="TARJETA CREDITO">Tarjeta crédito</option>
            </select>
        </label>
        <label>Fecha<input asp-for="Fecha" type="date" class="form-control form-control-sm" /></label>
        <label>Cuenta origen<select asp-for="CuentaFinancieraId" class="form-select form-select-sm"><option value="">Caja principal</option>@foreach (var cuenta in cuentas) { <option value="@cuenta.CuentaFinancieraId" data-tipo="@cuenta.Tipo" selected="@(Model.CuentaFinancieraId == cuenta.CuentaFinancieraId)">@cuenta.Nombre</option> }</select></label>
    </div>
    <label>Observación<textarea asp-for="Observacion" class="form-control form-control-sm"></textarea></label>
    <p class="text-muted">@mensajeCaja</p>
    <div class="form-actions">
        <button type="submit" class="btn btn-sm btn-primary">Registrar devolución</button>
        <a class="btn btn-sm btn-secondary" asp-action="Index">Volver</a>
    </div>
</form>



@section Scripts {
    <script>window.viveroFiltrarCuentasPorMedioPago?.({ medioPagoSelector: '[name="MedioDevolucion"]' });</script>
}
