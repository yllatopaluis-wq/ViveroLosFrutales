@model CotizacionFormDataDto
@using System.Text.Json
@{
    var esEdicion = Model.Cotizacion.CotizacionId > 0;
    ViewData["Title"] = esEdicion ? "Editar cotizacion" : "Nueva cotizacion";
    var formAction = esEdicion ? "Edit" : "Create";
    var clienteSeleccionado = Model.Clientes.FirstOrDefault(x => x.ClienteId == Model.Cotizacion.ClienteId);
    var clienteTexto = clienteSeleccionado is null ? string.Empty : $"{clienteSeleccionado.NombreCompleto} - {clienteSeleccionado.NumeroDocumento}";
    var clienteDireccion = string.IsNullOrWhiteSpace(Model.Cotizacion.Direccion)
        ? clienteSeleccionado?.Direccion ?? string.Empty
        : Model.Cotizacion.Direccion;
    var clienteTelefono = string.IsNullOrWhiteSpace(Model.Cotizacion.ClienteTelefono) ? clienteSeleccionado?.Telefono ?? string.Empty : Model.Cotizacion.ClienteTelefono;
    var clienteEmail = string.IsNullOrWhiteSpace(Model.Cotizacion.ClienteEmail) ? clienteSeleccionado?.Email ?? string.Empty : Model.Cotizacion.ClienteEmail;
    var numeroCotizacion = $"{Model.Numeracion.Serie}-{Model.Numeracion.Correlativo}";
    var clientesJson = JsonSerializer.Serialize(Model.Clientes.Select(x => new
    {
        id = x.ClienteId,
        nombre = x.NombreCompleto,
        documento = x.NumeroDocumento,
        telefono = x.Telefono,
        email = x.Email,
        direccion = x.Direccion,
        texto = $"{x.NombreCompleto} - {x.NumeroDocumento}"
    }));
    var productosJson = JsonSerializer.Serialize(Model.Productos.Select(x => new
    {
        id = x.ProductoId,
        nombre = x.Nombre,
        categoria = x.Categoria,
        codigo = $"PROD-{x.ProductoId:D6}",
        sku = string.Empty,
        codigoBarras = string.Empty,
        unidad = x.UnidadMedida,
        precio = x.PrecioVentaConIgv,
        stock = x.Stock,
        afectoIgv = x.AfectoIgv,
        texto = string.IsNullOrWhiteSpace(x.Categoria) ? x.Nombre : $"{x.Nombre} ({x.Categoria})"
    }));
    var detalles = Model.Cotizacion.Detalles;

    var subtotalExonerado = 0m;
    var subtotalGravado = 0m;
    foreach (var detalle in detalles)
    {
        var importe = decimal.Round(detalle.Cantidad * detalle.PrecioUnitario, 2);
        var producto = Model.Productos.FirstOrDefault(x => x.ProductoId == detalle.ProductoId);
        if (producto?.AfectoIgv == true)
        {
            subtotalGravado += decimal.Round(importe / 1.18m, 2);
        }
        else
        {
            subtotalExonerado += importe;
        }
    }
    var totalGravado = detalles.Sum(detalle =>
    {
        var producto = Model.Productos.FirstOrDefault(x => x.ProductoId == detalle.ProductoId);
        return producto?.AfectoIgv == true ? decimal.Round(detalle.Cantidad * detalle.PrecioUnitario, 2) : 0m;
    });
    var igvCalculado = decimal.Round(totalGravado - subtotalGravado, 2);
    var totalCalculado = subtotalExonerado + subtotalGravado + igvCalculado;
}

<form asp-action="@formAction" method="post" class="document-form comprobante-form quote-form">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger"></div>
    <input type="hidden" asp-for="Cotizacion.CotizacionId" name="CotizacionId" />

    <section class="quote-panel quote-header-panel">
        <div class="quote-panel-title">
            <span class="document-section-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M6 3h9l4 4v14H6z" /><path d="M14 3v5h5M9 12h6M9 16h4" /></svg></span>
            <strong>Informacion general</strong>
        </div>
        <strong class="quote-number">@numeroCotizacion</strong>
        <fieldset class="quote-general-grid">
            <label>
                <span>Fecha</span>
                <input asp-for="Cotizacion.FechaEmision" name="FechaEmision" class="form-control" type="date" />
            </label>
            <label>
                <span>Validez</span>
                <input class="form-control" value="15 dias" readonly />
            </label>
            <label>
                <span>Moneda</span>
                <input class="form-control" value="Soles" readonly />
            </label>
            <label>
                <span>Forma de pago</span>
                <select asp-for="Cotizacion.FormaPago" name="FormaPago" asp-items="Html.GetEnumSelectList<FormaPago>()" class="form-select"></select>
            </label>
        </fieldset>
        <input name="Serie" value="@Model.Numeracion.Serie" type="hidden" />
        <input name="Correlativo" value="@Model.Numeracion.Correlativo" type="hidden" />
    </section>

    <section class="quote-panel">
        <div class="quote-panel-title">
            <span class="document-section-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M20 21a8 8 0 0 0-16 0" /><path d="M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z" /></svg></span>
            <strong>Cliente</strong>
        </div>
        <div class="quote-client-search">
            <input class="form-control" id="clienteSearch" list="clientesOptions" value="@clienteTexto" placeholder="Buscar cliente por nombre, documento o telefono..." autocomplete="off" />
            <input asp-for="Cotizacion.ClienteId" name="ClienteId" type="hidden" id="clienteId" />
        </div>
        <div class="quote-client-summary quote-client-summary-line">
            <div class="client-name-block">
                <strong id="clienteResumenNombre">@(clienteSeleccionado?.NombreCompleto ?? "Seleccione cliente")</strong>
            </div>
            <div>
                <span>Documento</span>
                <strong id="clienteResumenDocumento">@(clienteSeleccionado?.NumeroDocumento ?? "-")</strong>
            </div>
            <div>
                <span>Telefono</span>
                <strong id="clienteResumenTelefono">@(string.IsNullOrWhiteSpace(clienteTelefono) ? "-" : clienteTelefono)</strong>
            </div>
            <div>
                <span>Email</span>
                <strong id="clienteResumenEmail">@(string.IsNullOrWhiteSpace(clienteEmail) ? "-" : clienteEmail)</strong>
            </div>
            <div>
                <span>Direccion</span>
                <strong id="clienteResumenDireccion">@(string.IsNullOrWhiteSpace(clienteDireccion) ? "-" : clienteDireccion)</strong>
                <input asp-for="Cotizacion.Direccion" name="Direccion" id="clienteDireccion" value="@clienteDireccion" type="hidden" />
            </div>
        </div>
    </section>

    <section class="quote-panel">
        <div class="quote-panel-title">
            <span class="document-section-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M12 3 3 7l9 4 9-4-9-4Z" /><path d="M3 12l9 4 9-4" /><path d="M3 17l9 4 9-4" /></svg></span>
            <strong>Detalle de productos</strong>
        </div>
        <div class="quote-product-picker" data-product-grid-picker>
            <div class="producto-search-wrap quote-product-search">
                <input class="form-control producto-grid-search" placeholder="Buscar producto por nombre, código, SKU o código de barras..." autocomplete="off" />
                <button type="button" class="producto-search-toggle" aria-label="Mostrar productos">v</button>
                <div class="producto-search-results" hidden></div>
            </div>
            <button type="button" class="document-more-btn product-grid-add">+ Agregar producto</button>
        </div>

        <fieldset class="document-detail-fieldset quote-detail-fieldset">
            <div class="document-detail-table-wrap quote-detail-table-wrap">
                <table class="table table-sm data-grid detalle-grid document-detail-table quote-detail-table" id="detalle" data-show-totals="true" data-product-picker-owned="true">
                    <colgroup>
                        <col class="detalle-item" />
                        <col class="detalle-producto" />
                        <col class="detalle-unidad" />
                        <col class="detalle-stock" />
                        <col class="detalle-cantidad" />
                        <col class="detalle-precio" />
                        <col class="detalle-descuento" />
                        <col class="detalle-total" />
                        <col class="detalle-accion" />
                    </colgroup>
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Producto</th>
                            <th>Unidad</th>
                            <th class="text-end">Stock</th>
                            <th class="text-end">Cantidad</th>
                            <th class="text-end">Precio unitario</th>
                            <th class="text-end">Descuento %</th>
                            <th class="text-end">Total</th>
                            <th class="text-center">Accion</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var i = 0; i < detalles.Count; i++)
                        {
                            var productoSeleccionado = Model.Productos.FirstOrDefault(x => x.ProductoId == detalles[i].ProductoId);
                            <tr>
                                <td class="quote-row-number">@(i + 1)</td>
                                <td>
                                    <input class="form-control form-control-sm producto-search" value="@(productoSeleccionado is null ? detalles[i].Producto : (string.IsNullOrWhiteSpace(productoSeleccionado.Categoria) ? productoSeleccionado.Nombre : $"{productoSeleccionado.Nombre} ({productoSeleccionado.Categoria})"))" readonly />
                                    <input name="Detalles[@i].ProductoId" class="producto-select" type="hidden" value="@detalles[i].ProductoId" />
                                </td>
                                <td><input value="@(productoSeleccionado?.UnidadMedida ?? "NIU")" class="form-control form-control-sm unidad-input" readonly /></td>
                                <td><input value="@((productoSeleccionado?.Stock ?? 0m).ToString("N2"))" class="form-control form-control-sm text-end stock-input" readonly /></td>
                                <td><input name="Detalles[@i].Cantidad" value="@detalles[i].Cantidad" class="form-control form-control-sm text-end cantidad-input" type="number" step="0.01" min="0.01" /></td>
                                <td><input name="Detalles[@i].PrecioUnitario" value="@detalles[i].PrecioUnitario" class="form-control form-control-sm text-end precio-input" type="number" step="0.01" min="0" /></td>
                                <td><input value="0" class="form-control form-control-sm text-end descuento-input" type="number" step="0.01" min="0" max="100" /></td>
                                <td><input value="@((detalles[i].Cantidad * detalles[i].PrecioUnitario).ToString("N2"))" class="form-control form-control-sm text-end line-total" readonly /></td>
                                <td class="text-center">
                                    <button type="button" class="icon-btn danger remove-row" title="Quitar fila" aria-label="Quitar fila"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18 6 6 18" /><path d="m6 6 12 12" /></svg></button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </fieldset>
    </section>

    <section class="quote-notes-grid">
        <label class="quote-panel">
            <span class="quote-panel-title">
                <span class="document-section-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M5 4h14v16H5z" /><path d="M8 8h8M8 12h8M8 16h5" /></svg></span>
                <strong>Observaciones</strong>
            </span>
            <textarea asp-for="Cotizacion.CaracteristicasTecnicas" name="CaracteristicasTecnicas" class="form-control" rows="3" placeholder="Detalle tecnico, entrega u observaciones para el cliente."></textarea>
        </label>
        <label class="quote-panel">
            <span class="quote-panel-title">
                <span class="document-section-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M9 11l3 3L22 4" /><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" /></svg></span>
                <strong>Condiciones comerciales</strong>
            </span>
            <textarea asp-for="Cotizacion.CondicionesVenta" name="CondicionesVenta" class="form-control" rows="3" placeholder="Garantia, validez, forma de pago y condiciones de entrega."></textarea>
        </label>
    </section>

    <div class="document-total-strip quote-total-strip" aria-label="Totales de la cotizacion">
        <div><span>Subtotal exonerado</span><strong id="comprobanteSubtotalExonerado">S/ @subtotalExonerado.ToString("N2")</strong></div>
        <div><span>Subtotal gravado</span><strong id="comprobanteSubtotalGravado">S/ @subtotalGravado.ToString("N2")</strong></div>
        <div><span>Descuento</span><strong id="comprobanteDescuento">S/ 0.00</strong></div>
        <div><span>IGV (18%)</span><strong id="comprobanteIgv">S/ @igvCalculado.ToString("N2")</strong></div>
        <div class="grand-total"><span>Total</span><strong id="comprobanteTotal">S/ @totalCalculado.ToString("N2")</strong></div>
    </div>

    <div class="document-bottom-actions quote-bottom-actions">
        <button type="submit" name="submit" value="guardar" class="document-save-btn">Guardar cotizacion</button>
        <a class="document-more-btn" asp-action="Index">Volver</a>
    </div>
</form>

@section Scripts {
    <script>
        window.viveroComprobanteForm({
            clientes: @Html.Raw(clientesJson),
            productos: @Html.Raw(productosJson),
            clientesUrl: '@Url.Action("BuscarClientes", "Cotizaciones")',
            productosUrl: '@Url.Action("BuscarProductos", "Cotizaciones")'
        });
        window.viveroProductoGridSearch({
            productos: @Html.Raw(productosJson),
            productosUrl: '@Url.Action("BuscarProductos", "Cotizaciones")',
            tableSelector: '#detalle'
        });
    </script>
}









