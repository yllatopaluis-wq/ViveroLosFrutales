@model CotizacionFormDataDto
@using System.Text.Json
@{
    var esEdicion = Model.Cotizacion.CotizacionId > 0;
    ViewData["Title"] = esEdicion ? "Editar cotizacion" : "Nueva cotizacion";
    var formAction = esEdicion ? "Edit" : "Create";
    var clienteSeleccionado = Model.Clientes.FirstOrDefault(x => x.ClienteId == Model.Cotizacion.ClienteId);
    var clienteTexto = clienteSeleccionado is null ? string.Empty : $"{clienteSeleccionado.NombreCompleto} - {clienteSeleccionado.NumeroDocumento}";
    var clienteDireccion = string.IsNullOrWhiteSpace(Model.Cotizacion.Direccion)
        ? clienteSeleccionado?.Direccion ?? string.Empty
        : Model.Cotizacion.Direccion;
    var clientesJson = JsonSerializer.Serialize(Model.Clientes.Select(x => new
    {
        id = x.ClienteId,
        nombre = x.NombreCompleto,
        documento = x.NumeroDocumento,
        direccion = x.Direccion,
        texto = $"{x.NombreCompleto} - {x.NumeroDocumento}"
    }));
    var productosJson = JsonSerializer.Serialize(Model.Productos.Select(x => new
    {
        id = x.ProductoId,
        nombre = x.Nombre,
        categoria = x.Categoria,
        precio = x.PrecioVentaConIgv,
        stock = x.Stock,
        afectoIgv = x.AfectoIgv,
        texto = string.IsNullOrWhiteSpace(x.Categoria) ? x.Nombre : $"{x.Nombre} ({x.Categoria})"
    }));
    var detalles = Model.Cotizacion.Detalles.Count == 0
        ? new List<ComprobanteDetalleDto> { new() }
        : Model.Cotizacion.Detalles;
    var subtotalExonerado = 0m;
    var subtotalGravado = 0m;
    foreach (var detalle in detalles)
    {
        var importe = decimal.Round(detalle.Cantidad * detalle.PrecioUnitario, 2);
        var producto = Model.Productos.FirstOrDefault(x => x.ProductoId == detalle.ProductoId);
        if (producto?.AfectoIgv == true)
        {
            subtotalGravado += decimal.Round(importe / 1.18m, 2);
        }
        else
        {
            subtotalExonerado += importe;
        }
    }
    var totalGravado = detalles.Sum(detalle =>
    {
        var producto = Model.Productos.FirstOrDefault(x => x.ProductoId == detalle.ProductoId);
        return producto?.AfectoIgv == true ? decimal.Round(detalle.Cantidad * detalle.PrecioUnitario, 2) : 0m;
    });
    var igvCalculado = decimal.Round(totalGravado - subtotalGravado, 2);
    var totalCalculado = subtotalExonerado + subtotalGravado + igvCalculado;
}

<form asp-action="@formAction" method="post" class="dense-form comprobante-form">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger"></div>
    <input type="hidden" asp-for="Cotizacion.CotizacionId" name="CotizacionId" />

    <div class="form-grid cols-4">
        <label>
            Tipo
            <input class="form-control form-control-sm" value="Cotizacion" readonly />
        </label>
        <label>
            Serie
            <input name="Serie" class="form-control form-control-sm" value="@Model.Numeracion.Serie" readonly />
        </label>
        <label>
            Correlativo
            <input name="Correlativo" class="form-control form-control-sm text-end" value="@Model.Numeracion.Correlativo" readonly />
        </label>
        <label>
            Fecha
            <input asp-for="Cotizacion.FechaEmision" name="FechaEmision" class="form-control form-control-sm" type="date" />
        </label>
        <label class="span-2">
            Condiciones de venta
            <textarea asp-for="Cotizacion.CondicionesVenta" name="CondicionesVenta" class="form-control form-control-sm" rows="5"></textarea>
        </label>
        <label class="span-2">
            Características técnicas
            <textarea asp-for="Cotizacion.CaracteristicasTecnicas" name="CaracteristicasTecnicas" class="form-control form-control-sm" rows="5"></textarea>
        </label>
        <label class="span-2">
            Cliente
            <input class="form-control form-control-sm" id="clienteSearch" list="clientesOptions" value="@clienteTexto" placeholder="Buscar por nombre o numero de documento" autocomplete="off" />
            <input asp-for="Cotizacion.ClienteId" name="ClienteId" type="hidden" id="clienteId" />
        </label>
        <label class="span-2">
            Direccion
            <input asp-for="Cotizacion.Direccion" name="Direccion" class="form-control form-control-sm" id="clienteDireccion" value="@clienteDireccion" readonly />
        </label>
        <label>
            Forma Pago
            <select asp-for="Cotizacion.FormaPago" name="FormaPago" asp-items="Html.GetEnumSelectList<FormaPago>()" class="form-select form-select-sm"></select>
        </label>
    </div>

    <div class="section-title">Detalle</div>
    <table class="table table-sm data-grid detalle-grid" id="detalle" data-show-totals="true">
        <colgroup>
            <col class="detalle-producto" />
            <col class="detalle-unidad" />
            <col class="detalle-cantidad" />
            <col class="detalle-precio" />
            <col class="detalle-total" />
            <col class="detalle-accion" />
        </colgroup>
        <thead>
            <tr>
                <th>Producto</th>
                <th>Unidad</th>
                <th class="text-end">Cantidad</th>
                <th class="text-end">Precio</th>
                <th class="text-end">Total</th>
                <th class="text-center"></th>
            </tr>
        </thead>
        <tbody>
            @for (var i = 0; i < detalles.Count; i++)
            {
                <tr>
                    <td>
                        <select name="Detalles[@i].ProductoId" class="form-select form-select-sm producto-select">
                            <option value="">Seleccione producto</option>
                            @foreach (var producto in Model.Productos)
                            {
                                var selected = detalles[i].ProductoId == producto.ProductoId;
                                <option value="@producto.ProductoId" data-precio="@producto.PrecioVentaConIgv" data-afecto-igv="@producto.AfectoIgv" selected="@selected">
                                    @(string.IsNullOrWhiteSpace(producto.Categoria) ? producto.Nombre : $"{producto.Nombre} ({producto.Categoria})")
                                </option>
                            }
                        </select>
                    </td>
                    <td><input value="UNIDAD" class="form-control form-control-sm" readonly /></td>
                    <td><input name="Detalles[@i].Cantidad" value="@detalles[i].Cantidad" class="form-control form-control-sm text-end cantidad-input" type="number" step="0.01" min="0.01" /></td>
                    <td><input name="Detalles[@i].PrecioUnitario" value="@detalles[i].PrecioUnitario" class="form-control form-control-sm text-end precio-input" type="number" step="0.01" min="0" /></td>
                    <td><input value="@((detalles[i].Cantidad * detalles[i].PrecioUnitario).ToString("N2"))" class="form-control form-control-sm text-end line-total" readonly /></td>
                    <td class="text-center">
                        <button type="button" class="icon-btn primary add-row" title="Agregar fila" aria-label="Agregar fila">
                            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 5v14" /><path d="M5 12h14" /></svg>
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="form-totals" aria-label="Totales de la cotizacion">
        <div><span>Subtotal Exonerado</span><strong id="comprobanteSubtotalExonerado">S/ @subtotalExonerado.ToString("N2")</strong></div>
        <div><span>Subtotal Gravado</span><strong id="comprobanteSubtotalGravado">S/ @subtotalGravado.ToString("N2")</strong></div>
        <div><span>IGV</span><strong id="comprobanteIgv">S/ @igvCalculado.ToString("N2")</strong></div>
        <div><span>Total</span><strong id="comprobanteTotal">S/ @totalCalculado.ToString("N2")</strong></div>
    </div>

    <div class="form-actions">
        <button type="submit" name="submit" value="guardar" class="btn btn-sm btn-primary">Guardar cotizacion</button>
        <a class="btn btn-sm btn-outline-secondary" asp-action="Index">Volver</a>
    </div>
</form>

@section Scripts {
    <script>
        window.viveroComprobanteForm({
            clientes: @Html.Raw(clientesJson),
            productos: @Html.Raw(productosJson),
            clientesUrl: '@Url.Action("BuscarClientes", "Cotizaciones")',
            productosUrl: '@Url.Action("BuscarProductos", "Cotizaciones")'
        });
    </script>
}
