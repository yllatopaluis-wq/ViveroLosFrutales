@model PagedResult<CotizacionListDto>
@{
    ViewData["Title"] = "Cotizaciones";
    var today = DateTime.Today;
    var firstDay = new DateTime(today.Year, today.Month, 1).ToString("yyyy-MM-dd");
    var currentDay = today.ToString("yyyy-MM-dd");
    var fechaDesde = Context.Request.Query["FechaDesde"].FirstOrDefault() ?? firstDay;
    var fechaHasta = Context.Request.Query["FechaHasta"].FirstOrDefault() ?? currentDay;
    var search = Context.Request.Query["Search"].FirstOrDefault();
}

@functions {
    private static bool EsCotizacionConvertida(CotizacionEstado estado) =>
        (int)estado is 3 or 4 or 5;

    private static string EstadoCotizacionTexto(CotizacionEstado estado) =>
        EsCotizacionConvertida(estado) ? "CONVERTIDA" : estado.ToString();
}

<div class="toolbar">
    <form method="get" class="search-form">
        <input name="FechaDesde" class="form-control form-control-sm" type="date" value="@fechaDesde" />
        <input name="FechaHasta" class="form-control form-control-sm" type="date" value="@fechaHasta" />
        <input name="Search" class="form-control form-control-sm" value="@search" placeholder="Buscar cotizacion, cliente o documento" />
        <button class="btn btn-sm btn-primary">Buscar</button>
    </form>
    <a class="btn btn-sm btn-success" asp-action="Create">Nueva cotizacion</a>
</div>

@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger py-2">@error</div>
}
@if (TempData["Success"] is string success)
{
    <div class="alert alert-success py-2">@success</div>
}

<table class="table table-sm table-striped data-grid cotizaciones-grid">
    <thead>
        <tr>
            <th>Numero cotizacion</th>
            <th>Fecha</th>
            <th>Cliente</th>
            <th>Documento</th>
            <th class="text-end">Total</th>
            <th>Estado</th>
            <th class="text-end actions-heading">Acciones</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.Items)
    {
        var esEditable = item.EstadoCotizacion == CotizacionEstado.ACTIVA;
        var esAnulable = item.EstadoCotizacion != CotizacionEstado.ANULADA
            && !EsCotizacionConvertida(item.EstadoCotizacion);
        <tr>
            <td>@($"{item.Serie}-{item.Correlativo}")</td>
            <td>@item.FechaEmision.ToString("dd/MM/yyyy")</td>
            <td>@item.Cliente</td>
            <td>@item.Documento</td>
            <td class="text-end">S/ @item.Total.ToString("N2")</td>
            <td>
                <span class="status-badge active">@EstadoCotizacionTexto(item.EstadoCotizacion)</span>
            </td>
            <td class="actions-cell">
                <div class="quote-actions">
                    <a class="icon-btn" asp-action="Details" asp-route-id="@item.CotizacionId" title="Ver" aria-label="Ver">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6Z" />
                            <path d="M12 9a3 3 0 1 1 0 6 3 3 0 0 1 0-6Z" />
                        </svg>
                    </a>
                    <form asp-action="Imprimir" method="post" class="icon-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@item.CotizacionId" />
                        <button type="submit" class="icon-btn" title="Imprimir PDF" aria-label="Imprimir PDF">
                            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 9V3h12v6" /><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" /><path d="M6 14h12v8H6Z" /></svg>
                        </button>
                    </form>
                    @if (esEditable)
                    {
                        <a class="icon-btn" asp-action="Edit" asp-route-id="@item.CotizacionId" title="Editar" aria-label="Editar">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M12 20h9" />
                                <path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z" />
                            </svg>
                        </a>
                    }
                    @if (esAnulable)
                    {
                        <form asp-action="Anular" method="post" class="icon-form" onsubmit="return confirm('Anular esta cotizacion?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.CotizacionId" />
                            <button type="submit" class="icon-btn danger" title="Anular" aria-label="Anular">
                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M18 6 6 18" />
                                    <path d="m6 6 12 12" />
                                </svg>
                            </button>
                        </form>
                    }
                    @if (esEditable)
                    {
                        <form asp-action="Convertir" method="post" class="icon-form" onsubmit="return confirm('Convertir esta cotizacion a nota de pedido?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.CotizacionId" />
                            <button type="submit" class="icon-btn" title="Convertir a Nota de pedido" aria-label="Convertir a Nota de pedido">
                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z" />
                                    <path d="M14 2v6h6" />
                                    <path d="M8 13h7" />
                                    <path d="m12 10 3 3-3 3" />
                                </svg>
                            </button>
                        </form>
                    }
                </div>
            </td>
        </tr>
    }
    </tbody>
</table>

@await Html.PartialAsync("_Pager", Model)
