@model CotizacionDetalleViewDto
@{
    ViewData["Title"] = "Detalle Cotizacion";
    var puedeConvertir = Model.EstadoCotizacion == CotizacionEstado.ACTIVA
        && !Model.TieneDocumentosRelacionados;
    var estadoTexto = EstadoCotizacionTexto(Model.EstadoCotizacion);
    var estadoClase = estadoTexto == "ACTIVA" ? string.Empty : estadoTexto == "ANULADA" ? "danger" : "info";
}

@functions {
    private static bool EsCotizacionConvertida(CotizacionEstado estado) =>
        (int)estado is 3 or 4 or 5;

    private static string EstadoCotizacionTexto(CotizacionEstado estado) =>
        EsCotizacionConvertida(estado) ? "CONVERTIDA" : estado.ToString();
}

<section class="ds-document-shell">
    <header class="ds-document-header">
        <div class="ds-document-title">
            <div class="ds-document-eyebrow">
                <span class="document-section-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M6 3h9l4 4v14H6z" /><path d="M14 3v5h5M9 12h6M9 16h4" /></svg></span>
                <span>Detalle Cotizacion</span>
            </div>
            <h1 class="ds-document-number">@Model.Numero</h1>
            <span class="ds-document-subtitle">@Model.Cliente</span>
        </div>
        <div class="ds-document-actions">
            @if (puedeConvertir)
            {
                <form asp-action="Convertir" method="post" class="icon-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.CotizacionId" />
                    <button type="submit" class="ds-action primary"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 7h10v10" /><path d="M7 17 17 7" /></svg> Convertir a Nota de pedido</button>
                </form>
            }
            <a class="ds-action outline" asp-action="Edit" asp-route-id="@Model.CotizacionId"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 20h9" /><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z" /></svg> Editar</a>
            <form asp-action="Imprimir" method="post" class="icon-form" target="_blank">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.CotizacionId" />
                <button type="submit" class="ds-action ghost"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 9V3h12v6" /><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" /><path d="M6 14h12v7H6z" /></svg> Imprimir PDF</button>
            </form>
            <a class="ds-action ghost" asp-action="Index"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M19 12H5" /><path d="m12 19-7-7 7-7" /></svg> Volver</a>
        </div>
    </header>

    <div class="ds-kpi-grid">
        <article class="ds-kpi orange"><div class="ds-kpi-copy"><small>Forma de pago</small><strong>@Model.FormaPago</strong></div><span class="ds-kpi-icon"><svg viewBox="0 0 24 24"><path d="M21 12a9 9 0 1 1-9-9" /><path d="M12 7v5l3 2" /></svg></span></article>
        <article class="ds-kpi orange"><div class="ds-kpi-copy"><small>Fecha de emision</small><strong>@Model.FechaEmision.ToString("dd/MM/yyyy")</strong></div><span class="ds-kpi-icon"><svg viewBox="0 0 24 24"><path d="M8 2v4M16 2v4" /><path d="M3 10h18" /><path d="M5 4h14v17H5z" /></svg></span></article>
        <article class="ds-kpi"><div class="ds-kpi-copy"><small>Total</small><strong>S/ @Model.Total.ToString("N2")</strong></div><span class="ds-kpi-icon"><svg viewBox="0 0 24 24"><path d="M4 7h16v12H4z" /><path d="M16 11h4" /></svg></span></article>
        <article class="ds-kpi neutral"><div class="ds-kpi-copy"><small>Estado</small><strong><span class="ds-status @estadoClase">@estadoTexto</span></strong></div><span class="ds-kpi-icon"><svg viewBox="0 0 24 24"><path d="M6 3h9l4 4v14H6z" /><path d="M14 3v5h5" /></svg></span></article>
    </div>
    <section class="ds-panel">
        <div class="ds-panel-title"><span class="document-section-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M6 3h9l4 4v14H6z" /><path d="M14 3v5h5M9 13h6" /></svg></span><strong>Informacion general</strong></div>
        <div class="ds-info-grid">
            <div class="ds-field wide"><span>Cliente</span><strong>@Model.Cliente</strong></div>
            <div class="ds-field"><span>Documento</span><strong>@Model.Documento</strong></div>
            <div class="ds-field"><span>Fecha de emision</span><strong>@Model.FechaEmision.ToString("dd/MM/yyyy")</strong></div>
            <div class="ds-field wide"><span>Direccion</span><strong>@(string.IsNullOrWhiteSpace(Model.Direccion) ? "-" : Model.Direccion)</strong></div>
            <div class="ds-field"><span>Tipo documento</span><strong>@Model.TipoDocumento</strong></div>
            <div class="ds-field"><span>Condicion de pago</span><strong>@Model.FormaPago</strong></div>
        </div>
    </section>

    <div class="ds-document-content">
        <section class="ds-panel ds-products-panel">
            <div class="ds-panel-title"><span class="document-section-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M12 3 3 7l9 4 9-4-9-4Z" /><path d="M3 12l9 4 9-4" /><path d="M3 17l9 4 9-4" /></svg></span><strong>Productos</strong></div>
            <div class="ds-table-wrap">
                <table class="ds-table">
                    <thead><tr><th>#</th><th>Producto</th><th class="text-end">Cantidad</th><th class="text-end">Precio unitario</th><th class="text-end">Subtotal</th><th class="text-end">IGV</th><th class="text-end">Total</th></tr></thead>
                    <tbody>
                    @{ var index = 1; }
                    @foreach (var item in Model.Detalles)
                    {
                        <tr><td>@index</td><td>@item.Producto</td><td class="text-end">@item.Cantidad.ToString("N2")</td><td class="text-end">S/ @item.PrecioUnitario.ToString("N2")</td><td class="text-end">S/ @item.Subtotal.ToString("N2")</td><td class="text-end">S/ @item.Igv.ToString("N2")</td><td class="text-end"><strong>S/ @item.Total.ToString("N2")</strong></td></tr>
                        index++;
                    }
                    <tr class="ds-total-row"><td colspan="2">Totales</td><td class="text-end">@Model.Detalles.Sum(x => x.Cantidad).ToString("N2")</td><td></td><td class="text-end">S/ @Model.Subtotal.ToString("N2")</td><td class="text-end">S/ @Model.Igv.ToString("N2")</td><td class="text-end">S/ @Model.Total.ToString("N2")</td></tr>
                    </tbody>
                </table>
            </div>
        </section>

        <section class="ds-tabs-panel">
            <div class="ds-tabs">
                <input type="radio" name="cotizacionTabs" id="cotizacionTabObservaciones" checked />
                <label for="cotizacionTabObservaciones">Observaciones</label>
                <input type="radio" name="cotizacionTabs" id="cotizacionTabDocumentos" />
                <label for="cotizacionTabDocumentos">Documentos relacionados</label>
                <div class="ds-tab-content ds-tab-observaciones"><div class="ds-note-card">Sin observaciones registradas.</div></div>
                <div class="ds-tab-content ds-tab-documentos"><div class="ds-note-card">@(Model.TieneDocumentosRelacionados ? "Existen documentos relacionados." : "No hay documentos relacionados.")</div></div>
            </div>
        </section>
    </div>
</section>