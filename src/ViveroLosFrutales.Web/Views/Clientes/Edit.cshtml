@model ClienteEditDto
@{
    var readOnly = ViewData["ReadOnly"] as bool? == true;
    ViewData["Title"] = readOnly ? "Visualizar cliente" : Model.ClienteId == 0 ? "Crear cliente" : "Editar cliente";
}

<form method="post" class="dense-form">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input asp-for="ClienteId" type="hidden" />
    <fieldset disabled="@readOnly" class="form-grid cols-3">
        <label>Tipo Documento<select asp-for="TipoDocumento" asp-items="Html.GetEnumSelectList<TipoDocumentoCliente>()" class="form-select form-select-sm"></select></label>
        <label>Numero Documento<input asp-for="NumeroDocumento" class="form-control form-control-sm" /></label>
        <label>Cliente<input asp-for="NombreCompleto" class="form-control form-control-sm" /></label>
        <label>Email<input asp-for="Email" class="form-control form-control-sm" /></label>
        <label>Direccion<input asp-for="Direccion" class="form-control form-control-sm" /></label>
        <label>Telefono<input asp-for="Telefono" class="form-control form-control-sm" /></label>
    </fieldset>
    <div class="form-actions">
        @if (!readOnly)
        {
            <button class="btn btn-sm btn-primary">Guardar</button>
        }
        <a class="btn btn-sm btn-outline-secondary" asp-action="Index">Volver</a>
    </div>
</form>
