@model CompraDetalleViewDto
@{
    ViewData["Title"] = "Detalle Compra";
    var puedePagar = Model.EstadoDocumento == EstadoDocumentoCompra.ACTIVO && Model.EstadoPago != EstadoPagoCompra.PAGADO && Model.SaldoPendiente > 0;
}

<div class="toolbar">
    <a class="btn btn-sm btn-secondary" asp-action="Index">Volver</a>
    @if (puedePagar)
    {
        <a class="btn btn-sm btn-primary" asp-action="RegistrarPago" asp-route-id="@Model.CompraId">Registrar pago</a>
    }
</div>

@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger py-2">@error</div>
}
@if (TempData["Success"] is string success)
{
    <div class="alert alert-success py-2">@success</div>
}

<section class="nota-summary-grid">
    <div class="nota-summary-card"><span>Proveedor</span><strong>@Model.Proveedor</strong></div>
    <div class="nota-summary-card"><span>Documento</span><strong>@Model.Documento</strong></div>
    <div class="nota-summary-card"><span>Fecha</span><strong>@Model.Fecha.ToString("dd/MM/yyyy")</strong></div>
    <div class="nota-summary-card"><span>Forma pago</span><strong>@Model.FormaPago</strong></div>
    <div class="nota-summary-card"><span>Total</span><strong>S/ @Model.Total.ToString("N2")</strong></div>
    <div class="nota-summary-card"><span>Pagado</span><strong>S/ @Model.TotalPagado.ToString("N2")</strong></div>
    <div class="nota-summary-card"><span>Saldo</span><strong>S/ @Model.SaldoPendiente.ToString("N2")</strong></div>
    <div class="nota-summary-card"><span>Estado pago</span><strong>@Model.EstadoPago</strong></div>
    <div class="nota-summary-card"><span>Estado doc.</span><strong>@Model.EstadoDocumento</strong></div>
</section>

<div class="section-title">Detalle</div>
<table class="table table-sm data-grid">
    <thead><tr><th>Producto</th><th>Unidad</th><th class="text-end">Cantidad</th><th class="text-end">Costo</th><th class="text-end">Importe</th><th class="text-end">IGV</th><th class="text-end">Total</th></tr></thead>
    <tbody>
    @foreach (var item in Model.Detalles)
    {
        <tr>
            <td>@item.Producto</td>
            <td>@item.UnidadMedida</td>
            <td class="text-end">@item.Cantidad.ToString("N2")</td>
            <td class="text-end">S/ @item.CostoUnitario.ToString("N2")</td>
            <td class="text-end">S/ @item.Importe.ToString("N2")</td>
            <td class="text-end">S/ @item.Igv.ToString("N2")</td>
            <td class="text-end">S/ @item.TotalLinea.ToString("N2")</td>
        </tr>
    }
    </tbody>
</table>

<div class="section-title">Pagos</div>
<table class="table table-sm data-grid">
    <thead><tr><th>Fecha</th><th>Medio</th><th class="text-end">Monto</th><th>Estado</th><th>Observacion</th><th class="text-end actions-heading">Acciones</th></tr></thead>
    <tbody>
    @foreach (var pago in Model.Pagos)
    {
        <tr>
            <td>@pago.FechaPago.ToString("dd/MM/yyyy")</td>
            <td>@pago.MedioPago</td>
            <td class="text-end">S/ @pago.Monto.ToString("N2")</td>
            <td><span class="status-badge @(pago.Estado == PagoProveedorEstado.ACTIVO ? "active" : "danger")">@pago.Estado</span></td>
            <td>@pago.Observacion</td>
            <td class="actions-cell">
                @if (pago.PuedeAnular)
                {
                    <form asp-action="AnularPago" method="post" class="icon-form" onsubmit="return solicitarMotivoAnulacionPago(this);">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@pago.PagoProveedorId" />
                        <input type="hidden" name="compraId" value="@Model.CompraId" />
                        <input type="hidden" name="motivo" value="" />
                        <button type="submit" class="icon-btn danger" title="Anular pago" aria-label="Anular pago">
                            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18 6 6 18" /><path d="m6 6 12 12" /></svg>
                        </button>
                    </form>
                }
            </td>
        </tr>
    }
    </tbody>
</table>

<script>
    function solicitarMotivoAnulacionPago(form) {
        const motivo = prompt("Ingrese el motivo de anulacion del pago:");
        if (motivo === null) return false;
        const motivoLimpio = motivo.trim();
        if (!motivoLimpio) {
            alert("Debe ingresar el motivo de anulacion.");
            return false;
        }
        form.querySelector("input[name='motivo']").value = motivoLimpio;
        return confirm("Confirmar anulacion del pago?");
    }
</script>
