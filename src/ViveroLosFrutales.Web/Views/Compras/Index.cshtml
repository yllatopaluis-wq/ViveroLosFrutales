@model PagedResult<CompraListDto>
@{
    ViewData["Title"] = "Lista Compras";
    var today = DateTime.Today;
    var firstDay = new DateTime(today.Year, today.Month, 1).ToString("yyyy-MM-dd");
    var currentDay = today.ToString("yyyy-MM-dd");
    var fechaDesde = Context.Request.Query["FechaDesde"].FirstOrDefault() ?? firstDay;
    var fechaHasta = Context.Request.Query["FechaHasta"].FirstOrDefault() ?? currentDay;
    var search = Context.Request.Query["Search"].FirstOrDefault();
}

<div class="toolbar">
    <form method="get" class="search-form">
        <input name="FechaDesde" class="form-control form-control-sm" type="date" value="@fechaDesde" />
        <input name="FechaHasta" class="form-control form-control-sm" type="date" value="@fechaHasta" />
        <input name="Search" class="form-control form-control-sm" value="@search" placeholder="Proveedor o documento" />
        <button class="btn btn-sm btn-primary">Buscar</button>
    </form>
    <a class="btn btn-sm btn-success" asp-action="Create">Registrar Compra</a>
</div>

@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger py-2">@error</div>
}
@if (TempData["Success"] is string success)
{
    <div class="alert alert-success py-2">@success</div>
}

<table class="table table-sm table-striped data-grid">
    <thead>
        <tr>
            <th>Fecha</th>
            <th>Proveedor</th>
            <th>Documento</th>
            <th class="text-end">Total</th>
            <th class="text-end">Pagado</th>
            <th class="text-end">Saldo</th>
            <th>Estado Pago</th>
            <th>Estado Doc.</th>
            <th class="text-end actions-heading">Acciones</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.Items)
    {
        <tr>
            <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
            <td>@item.Proveedor</td>
            <td>@item.Documento</td>
            <td class="text-end">S/ @item.Total.ToString("N2")</td>
            <td class="text-end">S/ @item.TotalPagado.ToString("N2")</td>
            <td class="text-end">S/ @item.SaldoPendiente.ToString("N2")</td>
            <td><span class="status-badge @(item.EstadoPago == EstadoPagoCompra.PAGADO ? "active" : item.EstadoPago == EstadoPagoCompra.PARCIAL ? "warning" : string.Empty)">@item.EstadoPago</span></td>
            <td><span class="status-badge @(item.EstadoDocumento == EstadoDocumentoCompra.ACTIVO ? "active" : "danger")">@item.EstadoDocumento</span></td>
            <td class="actions-cell">
                <div class="quote-actions">
                    <a class="icon-btn" asp-action="Details" asp-route-id="@item.CompraId" title="Ver" aria-label="Ver">
                        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6Z" /><path d="M12 9a3 3 0 1 1 0 6 3 3 0 0 1 0-6Z" /></svg>
                    </a>
                    @if (item.PuedeRegistrarPago)
                    {
                        <a class="icon-btn primary" asp-action="RegistrarPago" asp-route-id="@item.CompraId" title="Registrar pago" aria-label="Registrar pago">$</a>
                    }
                    @if (item.PuedeAnular)
                    {
                        <form asp-action="Anular" method="post" class="icon-form" onsubmit="return solicitarMotivoAnulacionCompra(this, '@item.Documento');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.CompraId" />
                            <input type="hidden" name="motivo" value="" />
                            <button type="submit" class="icon-btn danger" title="Anular" aria-label="Anular">
                                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18 6 6 18" /><path d="m6 6 12 12" /></svg>
                            </button>
                        </form>
                    }
                </div>
            </td>
        </tr>
    }
    </tbody>
</table>

@await Html.PartialAsync("_Pager", Model)

<script>
    function solicitarMotivoAnulacionCompra(form, documento) {
        const motivo = prompt(`Ingrese el motivo de anulacion de la compra ${documento}:`);
        if (motivo === null) return false;
        const motivoLimpio = motivo.trim();
        if (!motivoLimpio) {
            alert("Debe ingresar el motivo de anulacion.");
            return false;
        }
        form.querySelector("input[name='motivo']").value = motivoLimpio;
        return confirm("Confirmar anulacion de la compra?");
    }
</script>
