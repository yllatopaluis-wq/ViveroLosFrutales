@model AplicarPagoProveedorFormDto
@{
    ViewData["Title"] = "Aplicar pago de proveedor";
}

<form asp-action="AplicarPagos" method="post" class="dense-form document-entry-form">
    @Html.AntiForgeryToken()
    <input asp-for="CompraId" type="hidden" />
    <div asp-validation-summary="All" class="text-danger"></div>

    <section class="quote-panel">
        <div class="quote-panel-title">
            <span class="document-section-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M6 3h9l4 4v14H6z" /><path d="M14 3v5h5M9 12h6M9 16h4" /></svg></span>
            <strong>Aplicacion de pago de proveedor</strong>
        </div>

        <div class="finance-summary">
            <div><span>Compra</span><strong>@Model.Compra</strong></div>
            <div><span>Proveedor</span><strong>@Model.Proveedor</strong></div>
            @if (!string.IsNullOrWhiteSpace(Model.OrdenCompra))
            {
                <div><span>Orden de compra</span><strong>@Model.OrdenCompra</strong></div>
            }
            <div><span>Total compra</span><strong>S/ @Model.TotalCompra.ToString("N2")</strong></div>
            <div><span>Pagado</span><strong>S/ @Model.TotalPagado.ToString("N2")</strong></div>
            <div><span>Saldo pendiente</span><strong id="saldoPendienteAplicacion">S/ @Model.SaldoPendiente.ToString("N2")</strong></div>
        </div>

        @if (!Model.PagosDisponibles.Any())
        {
            <div class="alert alert-warning py-2">No hay pagos disponibles para aplicar a esta compra.</div>
        }
        else
        {
            <div class="document-detail-table-wrap quote-detail-table-wrap">
                <table class="table table-sm data-grid document-detail-table quote-detail-table">
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>Referencia</th>
                            <th class="text-end">Monto original</th>
                            <th class="text-end">Aplicado</th>
                            <th class="text-end">Saldo disponible</th>
                            <th class="text-end">Monto a aplicar</th>
                        </tr>
                    </thead>
                    <tbody>
                    @for (var i = 0; i < Model.PagosDisponibles.Count; i++)
                    {
                        var pago = Model.PagosDisponibles[i];
                        var item = i < Model.Pagos.Count ? Model.Pagos[i] : new AplicarPagoProveedorItemDto { PagoProveedorId = pago.PagoProveedorId };
                        <tr>
                            <td>@pago.FechaPago.ToString("dd/MM/yyyy")</td>
                            <td>@pago.Referencia<input name="Pagos[@i].PagoProveedorId" type="hidden" value="@pago.PagoProveedorId" /></td>
                            <td class="text-end">S/ @pago.MontoOriginal.ToString("N2")</td>
                            <td class="text-end">S/ @pago.MontoAplicado.ToString("N2")</td>
                            <td class="text-end">S/ @pago.SaldoDisponible.ToString("N2")</td>
                            <td><input name="Pagos[@i].MontoAplicar" value="@item.MontoAplicar" class="form-control form-control-sm text-end pago-aplicar-input" type="number" step="0.01" min="0" max="@pago.SaldoDisponible" data-disponible="@pago.SaldoDisponible" /></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
            <div class="document-total-strip quote-total-strip" aria-label="Resumen aplicacion de pagos">
                <div><span>Saldo pendiente</span><strong>S/ @Model.SaldoPendiente.ToString("N2")</strong></div>
                <div class="grand-total"><span>Total a aplicar</span><strong id="totalAplicarProveedor">S/ 0.00</strong></div>
            </div>
        }

        <div class="form-actions">
            @if (Model.PagosDisponibles.Any())
            {
                <button class="btn btn-sm btn-primary" type="submit">Aplicar pagos</button>
            }
            <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@Model.CompraId">Volver</a>
        </div>
    </section>
</form>

@section Scripts {
    <script>
        (() => {
            const inputs = [...document.querySelectorAll('.pago-aplicar-input')];
            const total = document.getElementById('totalAplicarProveedor');
            const money = (value) => `S/ ${Number(value || 0).toFixed(2)}`;
            const sync = () => {
                let suma = 0;
                for (const input of inputs) {
                    const disponible = Number(input.dataset.disponible || 0);
                    let value = Number(input.value || 0);
                    if (value < 0) value = 0;
                    if (value > disponible) value = disponible;
                    input.value = value ? value.toFixed(2) : '0.00';
                    suma += value;
                }
                if (total) total.textContent = money(suma);
            };
            inputs.forEach((input) => input.addEventListener('change', sync));
            inputs.forEach((input) => input.addEventListener('input', () => {
                const suma = inputs.reduce((acc, item) => acc + Number(item.value || 0), 0);
                if (total) total.textContent = money(suma);
            }));
            sync();
        })();
    </script>
}