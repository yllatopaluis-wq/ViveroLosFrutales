@model CompraFormDataDto
@{
    ViewData["Title"] = "Registrar Compra";
    var detalles = Model.Compra.Detalles.Count == 0 ? new List<CompraDetalleEditDto> { new() } : Model.Compra.Detalles;
}

<form asp-action="Create" method="post" class="document-form compra-form">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger"></div>

    <section class="document-section">
        <div class="document-section-heading">
            <span class="document-section-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M6 3h9l4 4v14H6z" /><path d="M14 3v5h5M9 12h6M9 16h4" /></svg>
            </span>
            <h3>Informaci&oacute;n de la compra</h3>
        </div>

        <fieldset class="document-grid compra-main-grid">
            <label class="span-2">
                <span>Proveedor <b>*</b></span>
                <select asp-for="Compra.ProveedorId" name="ProveedorId" class="form-select">
                    <option value="">Seleccione proveedor</option>
                    @foreach (var proveedor in Model.Proveedores)
                    {
                        <option value="@proveedor.ProveedorId" selected="@(Model.Compra.ProveedorId == proveedor.ProveedorId)">@proveedor.RazonSocial - @proveedor.NumeroDocumento</option>
                    }
                </select>
            </label>
            <label>
                <span>Tipo documento <b>*</b></span>
                <select asp-for="Compra.TipoDocumento" name="TipoDocumento" class="form-select" id="tipoDocumentoCompra">
                    <option value="@TipoDocumentoCompra.FACTURA">FACTURA</option>
                    <option value="@TipoDocumentoCompra.BOLETA">BOLETA</option>
                    <option value="@TipoDocumentoCompra.LIQUIDACION_COMPRA">LIQUIDACI&Oacute;N DE COMPRA</option>
                    <option value="@TipoDocumentoCompra.PENDIENTE_COMPROBANTE">PENDIENTE DE COMPROBANTE</option>
                    <option value="@TipoDocumentoCompra.SIN_DOCUMENTO">SIN DOCUMENTO</option>
                </select>
            </label>
            <label>
                <span>Fecha <b>*</b></span>
                <input asp-for="Compra.Fecha" name="Fecha" class="form-control" type="date" />
            </label>
            <label class="compra-document-number-field">
                <span>Serie <b>*</b></span>
                <input asp-for="Compra.Serie" name="Serie" class="form-control" id="serieCompra" />
            </label>
            <label class="compra-document-number-field">
                <span>N&uacute;mero <b>*</b></span>
                <input asp-for="Compra.Numero" name="Numero" class="form-control" id="numeroCompra" />
            </label>
            <label>
                <span>Forma de pago <b>*</b></span>
                <select asp-for="Compra.FormaPago" name="FormaPago" asp-items="Html.GetEnumSelectList<FormaPagoCompra>()" class="form-select"></select>
            </label>
            <label>
                <span>Medio de pago <b>*</b></span>
                <select asp-for="Compra.MedioPago" name="MedioPago" class="form-select">
                    <option value="EFECTIVO">Efectivo</option>
                    <option value="YAPE">Yape</option>
                    <option value="PLIN">Plin</option>
                    <option value="TRANSFERENCIA">Transferencia</option>
                    <option value="TARJETA">Tarjeta</option>
                    <option value="OTRO">Otro</option>
                </select>
            </label>
            <label class="span-4">
                <span>Observaci&oacute;n</span>
                <input asp-for="Compra.Observacion" name="Observacion" class="form-control" />
            </label>
        </fieldset>
    </section>

    <section class="document-section">
        <div class="document-section-heading">
            <span class="document-section-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M12 3 3 7l9 4 9-4-9-4Z" /><path d="M3 12l9 4 9-4" /><path d="M3 17l9 4 9-4" /></svg>
            </span>
            <h3>Detalle de productos</h3>
        </div>

        <fieldset class="document-detail-fieldset">
            <div class="document-detail-table-wrap">
                <table class="table table-sm data-grid detalle-grid document-detail-table compra-detail-table" id="compraDetalle">
                    <colgroup>
                        <col class="detalle-producto" />
                        <col class="detalle-cantidad" />
                        <col class="detalle-precio" />
                        <col class="detalle-total" />
                        <col class="detalle-accion" />
                    </colgroup>
                    <thead>
                        <tr>
                            <th>Producto</th>
                            <th class="text-end">Cantidad</th>
                            <th class="text-end">Costo unitario</th>
                            <th class="text-end">Importe</th>
                            <th class="text-center">Acci&oacute;n</th>
                        </tr>
                    </thead>
                    <tbody>
                    @for (var i = 0; i < detalles.Count; i++)
                    {
                        var detalle = detalles[i];
                        <tr>
                            <td>
                                <select name="Detalles[@i].ProductoId" class="form-select form-select-sm producto-select">
                                    <option value="">Seleccione producto</option>
                                    @foreach (var producto in Model.Productos)
                                    {
                                        <option value="@producto.ProductoId" selected="@(detalle.ProductoId == producto.ProductoId)">
                                            @producto.Nombre (@producto.Categoria)
                                        </option>
                                    }
                                </select>
                                <input name="Detalles[@i].UnidadMedida" value="@detalle.UnidadMedida" type="hidden" />
                            </td>
                            <td><input name="Detalles[@i].Cantidad" value="@detalle.Cantidad" class="form-control form-control-sm text-end cantidad-input" type="number" step="0.01" min="0.01" /></td>
                            <td><input name="Detalles[@i].CostoUnitario" value="@detalle.CostoUnitario" class="form-control form-control-sm text-end costo-input" type="number" step="0.01" min="0" /></td>
                            <td><input value="@((detalle.Cantidad * detalle.CostoUnitario).ToString("N2"))" class="form-control form-control-sm text-end line-total" readonly /></td>
                            <td class="text-center">
                                <button type="button" class="icon-btn primary add-row" title="Agregar fila" aria-label="Agregar fila">
                                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 5v14" /><path d="M5 12h14" /></svg>
                                </button>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </fieldset>

        <div class="document-total-strip compra-total-strip" aria-label="Totales de compra">
            <div><span>Subtotal</span><strong id="compraSubtotal">S/ 0.00</strong></div>
            <div><span>IGV</span><strong id="compraIgv">S/ 0.00</strong></div>
            <div class="grand-total"><span>Total</span><strong id="compraTotal">S/ 0.00</strong></div>
            <div><span>Total pagado</span><strong id="compraPagado">S/ 0.00</strong></div>
            <div><span>Saldo pendiente</span><strong id="compraSaldo">S/ 0.00</strong></div>
            <div><span>Estado pago</span><strong id="compraEstadoPago">Pendiente</strong></div>
        </div>
    </section>

    <div class="document-bottom-actions">
        <button class="document-save-btn">Guardar</button>
        <a class="document-more-btn" asp-action="Index">Volver</a>
    </div>
</form>

@section Scripts {
    <script>
        window.viveroCompraForm();
        window.viveroCompraDocumentoForm?.();
    </script>
}