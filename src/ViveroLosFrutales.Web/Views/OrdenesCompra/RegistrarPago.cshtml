@model RegistrarPagoOrdenCompraDto
@{
    var cuentas = Model.CuentasFinancieras ?? Array.Empty<CuentaFinancieraOptionDto>();
    ViewData["Title"] = "Registrar pago orden de compra";
}

<form asp-action="RegistrarPago" method="post" class="dense-form document-entry-form">
    @Html.AntiForgeryToken()
    <input asp-for="OrdenCompraId" type="hidden" />
    <div asp-validation-summary="All" class="text-danger"></div>

    <section class="quote-panel">
        <div class="quote-panel-title">
            <span class="document-section-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M6 3h9l4 4v14H6z" /><path d="M14 3v5h5M9 12h6M9 16h4" /></svg></span>
            <strong>Pago adelantado</strong>
        </div>

        <div class="finance-summary">
            <div><span>Orden</span><strong>@Model.OrdenCompra</strong></div>
            <div><span>Proveedor</span><strong>@Model.Proveedor</strong></div>
            <div><span>Saldo disponible</span><strong>S/ @Model.SaldoDisponible.ToString("N2")</strong></div>
        </div>

        <div class="form-grid cols-4">
            <label>Fecha pago<input asp-for="FechaPago" class="form-control form-control-sm" type="date" /></label>
            <label>Importe<input asp-for="MontoPago" class="form-control form-control-sm text-end" type="number" step="0.01" min="0.01" /></label>
            <label>
                Medio pago
                <select asp-for="MedioPago" class="form-select form-select-sm" id="medioPagoOrdenCompra">
                    <option value="EFECTIVO">Efectivo</option>
                    <option value="TRANSFERENCIA">Transferencia</option>
                    <option value="YAPE">Yape</option>
                    <option value="TARJETA DEBITO">Tarjeta debito</option>
                    <option value="TARJETA CREDITO">Tarjeta credito</option>
                </select>
            </label>
            <label>
                Cuenta
                <select asp-for="CuentaFinancieraId" class="form-select form-select-sm" id="cuentaOrdenCompra">
                    <option value="" disabled>Seleccione cuenta</option>
                    @foreach (var cuenta in cuentas)
                    {
                        <option value="@cuenta.CuentaFinancieraId" data-tipo="@cuenta.Tipo" selected="@(Model.CuentaFinancieraId == cuenta.CuentaFinancieraId)">@cuenta.Nombre</option>
                    }
                </select>
            </label>
            <label class="span-2">Observacion<input asp-for="Observacion" class="form-control form-control-sm" /></label>
        </div>

        <div class="form-actions">
            <button class="btn btn-sm btn-primary" type="submit">Guardar pago</button>
            <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@Model.OrdenCompraId">Volver</a>
        </div>
    </section>
</form>

@section Scripts {
    <script>
        window.viveroFiltrarCuentasPorMedioPago?.({
            medioPagoSelector: '#medioPagoOrdenCompra',
            cuentaSelector: '#cuentaOrdenCompra'
        });
    </script>
}