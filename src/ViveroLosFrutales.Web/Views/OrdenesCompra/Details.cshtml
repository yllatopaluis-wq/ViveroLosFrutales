@model OrdenCompraDetalleViewDto
@{
    ViewData["Title"] = "Orden de compra";
    var estadoDocumentoClase = Model.EstadoDocumento.ToString().Contains("ANUL", StringComparison.OrdinalIgnoreCase) ? "danger" : string.Empty;
    var estadoFinancieroClase = Model.EstadoFinanciero.ToString().Contains("PAG", StringComparison.OrdinalIgnoreCase) ? string.Empty : Model.EstadoFinanciero.ToString().Contains("PARC", StringComparison.OrdinalIgnoreCase) ? "warning" : "info";
}

<section class="ds-document-shell">
    <header class="ds-document-header">
        <div class="ds-document-title">
            <div class="ds-document-eyebrow"><span class="document-section-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M6 3h9l4 4v14H6z" /><path d="M14 3v5h5M9 12h6M9 16h4" /></svg></span><span>Orden de compra</span></div>
            <h1 class="ds-document-number">@Model.Documento</h1>
            <span class="ds-document-subtitle">@Model.Proveedor</span>
        </div>
        <div class="ds-document-actions">
            <a class="ds-action primary" asp-action="RegistrarPago" asp-route-id="@Model.OrdenCompraId"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2v20" /><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7H14a3.5 3.5 0 0 1 0 7H6" /></svg> Registrar pago</a>
            <a class="ds-action outline" asp-action="RegistrarCompra" asp-route-id="@Model.OrdenCompraId"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 3h9l4 4v14H6z" /><path d="M14 3v5h5M9 13h6" /></svg> Registrar compra</a>
            <form asp-action="Cerrar" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.OrdenCompraId" />
                <input type="hidden" name="solicitarDevolucion" value="false" />
                <button class="ds-action ghost" type="submit"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 6 9 17l-5-5" /></svg> Cerrar</button>
            </form>
            <a class="ds-action ghost" asp-action="Index"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M19 12H5" /><path d="m12 19-7-7 7-7" /></svg> Volver</a>
        </div>
    </header>

    <div class="ds-kpi-grid">
        <article class="ds-kpi"><div class="ds-kpi-copy"><small>Total OC</small><strong>S/ @Model.Total.ToString("N2")</strong><em>@Model.Moneda</em></div><span class="ds-kpi-icon"><svg viewBox="0 0 24 24"><path d="M6 6h15l-1.5 9h-12z" /><path d="M6 6 5 3H2" /></svg></span></article>
        <article class="ds-kpi blue"><div class="ds-kpi-copy"><small>Facturado</small><strong>S/ @Model.TotalFacturado.ToString("N2")</strong><em>Pendiente S/ @Model.PendienteFacturar.ToString("N2")</em></div><span class="ds-kpi-icon"><svg viewBox="0 0 24 24"><path d="M6 3h12v18H6z" /><path d="M9 7h6M9 11h6M9 15h3" /></svg></span></article>
        <article class="ds-kpi orange"><div class="ds-kpi-copy"><small>Pagado</small><strong>S/ @Model.TotalPagado.ToString("N2")</strong><em>Aplicado S/ @Model.TotalAplicado.ToString("N2")</em></div><span class="ds-kpi-icon"><svg viewBox="0 0 24 24"><path d="M4 7h16v12H4z" /><path d="M16 11h4" /></svg></span></article>
        <article class="ds-kpi neutral"><div class="ds-kpi-copy"><small>Disponible</small><strong>S/ @Model.SaldoDisponible.ToString("N2")</strong><em>Devuelto S/ @Model.TotalDevuelto.ToString("N2")</em></div><span class="ds-kpi-icon"><svg viewBox="0 0 24 24"><path d="M12 8v8" /><path d="M8 12h8" /><circle cx="12" cy="12" r="9" /></svg></span></article>
    </div>

    <section class="ds-panel">
        <div class="ds-panel-title"><span class="document-section-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M6 3h9l4 4v14H6z" /><path d="M14 3v5h5M9 13h6" /></svg></span><strong>Informacion general</strong></div>
        <div class="ds-info-grid">
            <div class="ds-field wide"><span>Proveedor</span><strong>@Model.Proveedor</strong></div>
            <div class="ds-field"><span>Documento proveedor</span><strong>@Model.ProveedorDocumento</strong></div>
            <div class="ds-field"><span>Fecha</span><strong>@Model.Fecha.ToString("dd/MM/yyyy")</strong></div>
            <div class="ds-field"><span>Entrega esperada</span><strong>@(Model.FechaEntregaEsperada?.ToString("dd/MM/yyyy") ?? "-")</strong></div>
            <div class="ds-field"><span>Forma de pago</span><strong>@Model.FormaPago</strong></div>
            <div class="ds-field"><span>Condicion pago</span><strong>@(string.IsNullOrWhiteSpace(Model.CondicionPago) ? "-" : Model.CondicionPago)</strong></div>
            <div class="ds-field"><span>Estado documento</span><strong><span class="ds-status @estadoDocumentoClase">@Model.EstadoDocumento</span></strong></div>
            <div class="ds-field"><span>Estado financiero</span><strong><span class="ds-status @estadoFinancieroClase">@Model.EstadoFinanciero</span></strong></div>
            <div class="ds-field wide"><span>Lugar entrega</span><strong>@(string.IsNullOrWhiteSpace(Model.LugarEntrega) ? "-" : Model.LugarEntrega)</strong></div>
            <div class="ds-field wide"><span>Observacion</span><strong>@(string.IsNullOrWhiteSpace(Model.Observacion) ? "-" : Model.Observacion)</strong></div>
        </div>
    </section>

    <section class="ds-panel">
        <div class="ds-panel-title"><span class="document-section-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M12 3 3 7l9 4 9-4-9-4Z" /><path d="M3 12l9 4 9-4" /><path d="M3 17l9 4 9-4" /></svg></span><strong>Productos</strong></div>
        <div class="ds-table-wrap"><table class="ds-table"><thead><tr><th>Producto</th><th>Unidad</th><th class="text-end">Cantidad</th><th class="text-end">Facturada</th><th class="text-end">Precio</th><th class="text-end">Total</th></tr></thead><tbody>
        @foreach (var d in Model.Detalles)
        {
            <tr><td><strong>@d.Producto</strong></td><td>@d.UnidadMedida</td><td class="text-end">@d.Cantidad.ToString("N2")</td><td class="text-end">@d.CantidadFacturada.ToString("N2")</td><td class="text-end">S/ @d.CostoUnitario.ToString("N2")</td><td class="text-end"><strong>S/ @d.Total.ToString("N2")</strong></td></tr>
        }
        <tr class="ds-total-row"><td colspan="5">Total</td><td class="text-end">S/ @Model.Total.ToString("N2")</td></tr>
        </tbody></table></div>
    </section>

    <div class="ds-panel-grid">
        <section class="ds-panel">
            <div class="ds-panel-title"><span class="document-section-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M6 3h12v18H6z" /><path d="M9 7h6M9 11h6M9 15h3" /></svg></span><strong>Compras / Facturas</strong></div>
            <div class="ds-table-wrap"><table class="ds-table"><thead><tr><th>Documento</th><th>Fecha</th><th class="text-end">Total</th><th class="text-end">Pagado</th><th class="text-end">Saldo</th><th>Acciones</th></tr></thead><tbody>
            @if (Model.Compras.Any())
            {
                @foreach (var c in Model.Compras)
                {
                    <tr><td>@c.Documento</td><td>@c.Fecha.ToString("dd/MM/yyyy")</td><td class="text-end">S/ @c.Total.ToString("N2")</td><td class="text-end">S/ @c.TotalPagado.ToString("N2")</td><td class="text-end">S/ @c.SaldoPendiente.ToString("N2")</td><td><a asp-controller="Compras" asp-action="Details" asp-route-id="@c.CompraId">Ver</a>@if (Model.SaldoDisponible > 0 && c.SaldoPendiente > 0){<form asp-action="AplicarAutomaticamente" method="post" class="d-inline">@Html.AntiForgeryToken()<input type="hidden" name="compraId" value="@c.CompraId" /><input type="hidden" name="ordenCompraId" value="@Model.OrdenCompraId" /><button type="submit" class="ds-action outline">Aplicar automatico</button></form>}</td></tr>
                }
            }
            else
            {
                <tr><td colspan="6" class="text-center text-muted">No hay compras registradas.</td></tr>
            }
            </tbody></table></div>
        </section>
        <aside class="ds-side-stack">
            <section class="ds-panel">
                <div class="ds-panel-title"><span class="document-section-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M4 4h16v16H4z" /><path d="M8 9h8M8 13h8M8 17h5" /></svg></span><strong>Timeline de pagos</strong></div>
                @if (Model.Pagos.Any())
                {
                    <ol class="ds-timeline">
                    @foreach (var p in Model.Pagos.OrderByDescending(x => x.FechaPago))
                    {
                        <li class="ds-timeline-item"><strong>@p.FechaPago.ToString("dd/MM/yyyy") - S/ @p.Monto.ToString("N2")</strong><span>@p.MedioPago · @(string.IsNullOrWhiteSpace(p.CuentaFinanciera) ? "Sin cuenta" : p.CuentaFinanciera)</span><small>Aplicado S/ @p.MontoAplicado.ToString("N2") · Disponible S/ @p.SaldoDisponible.ToString("N2")</small></li>
                    }
                    </ol>
                }
                else
                {
                    <div class="ds-note-card">No hay pagos registrados.</div>
                }
            </section>
        </aside>
    </div>

    <section class="ds-panel">
        <div class="ds-panel-title"><span class="document-section-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M3 7h18" /><path d="M6 11h12" /><path d="M8 15h8" /></svg></span><strong>Devoluciones</strong></div>
        <div class="ds-table-wrap"><table class="ds-table"><thead><tr><th>Origen</th><th class="text-end">Original</th><th class="text-end">Devuelto</th><th class="text-end">Pendiente</th><th>Estado</th></tr></thead><tbody>
        @if (Model.Devoluciones.Any())
        {
            @foreach (var d in Model.Devoluciones)
            {
                <tr><td>@d.OrigenDescripcion</td><td class="text-end">S/ @d.MontoOriginal.ToString("N2")</td><td class="text-end">S/ @d.MontoDevuelto.ToString("N2")</td><td class="text-end">S/ @d.MontoPendiente.ToString("N2")</td><td><span class="ds-status neutral">@d.Estado</span></td></tr>
            }
        }
        else
        {
            <tr><td colspan="5" class="text-center text-muted">No hay devoluciones registradas.</td></tr>
        }
        </tbody></table></div>
    </section>
</section>