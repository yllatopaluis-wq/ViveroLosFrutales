@model OrdenCompraFormDataDto
@using System.Text.Json
@{
    ViewData["Title"] = "Nueva orden de compra";
    var proveedorSeleccionado = Model.Proveedores.FirstOrDefault(x => x.ProveedorId == Model.OrdenCompra.ProveedorId);
    var proveedorTexto = proveedorSeleccionado is null ? string.Empty : $"{proveedorSeleccionado.RazonSocial} - {proveedorSeleccionado.NumeroDocumento}";
    var proveedoresJson = JsonSerializer.Serialize(Model.Proveedores.Select(x => new
    {
        id = x.ProveedorId,
        nombre = x.RazonSocial,
        documento = x.NumeroDocumento,
        tipoDocumento = x.TipoDocumento.ToString(),
        direccion = x.Direccion,
        texto = $"{x.RazonSocial} - {x.NumeroDocumento}"
    }));
    var productosJson = JsonSerializer.Serialize(Model.Productos.Select(x => new
    {
        id = x.ProductoId,
        nombre = x.Nombre,
        categoria = x.Categoria,
        codigo = $"PROD-{x.ProductoId:D6}",
        sku = string.Empty,
        codigoBarras = string.Empty,
        unidad = x.UnidadMedida,
        precio = x.PrecioCompra,
        precioCompra = x.PrecioCompra,
        stock = x.Stock,
        afectoIgv = x.AfectoIgv,
        texto = string.IsNullOrWhiteSpace(x.Categoria) ? x.Nombre : $"{x.Nombre} ({x.Categoria})"
    }));
    var detalles = Model.OrdenCompra.Detalles.Count == 0 ? new List<OrdenCompraDetalleEditDto> { new() } : Model.OrdenCompra.Detalles;
    var bloques = Model.FormularioConfiguracion.Bloques.ToDictionary(x => x.Bloque, x => x, StringComparer.OrdinalIgnoreCase);
    var campos = Model.FormularioConfiguracion.Campos.ToDictionary(x => $"{x.Bloque}:{x.Campo}", x => x, StringComparer.OrdinalIgnoreCase);
    bool BloqueVisible(string bloque) => !bloques.TryGetValue(bloque, out var config) || config.Visible;
    FormularioCampoDto Campo(string bloque, string campo, string etiquetaDefault, int ordenDefault = 999, string anchoDefault = "3") =>
        campos.TryGetValue($"{bloque}:{campo}", out var config)
            ? config
            : new FormularioCampoDto(bloque, campo, etiquetaDefault, true, false, false, ordenDefault, anchoDefault, null);
    bool CampoVisible(string bloque, string campo) => Campo(bloque, campo, campo).Visible;
    string Etiqueta(string bloque, string campo, string fallback) => Campo(bloque, campo, fallback).Etiqueta;
    bool Obligatorio(string bloque, string campo) => Campo(bloque, campo, campo).Obligatorio;
    bool SoloLectura(string bloque, string campo) => Campo(bloque, campo, campo).SoloLectura;
    int Ancho(string bloque, string campo, string fallback = "3")
    {
        var raw = Campo(bloque, campo, campo, 999, fallback).Ancho;
        if (string.Equals(raw, "full", StringComparison.OrdinalIgnoreCase)) return 12;
        return int.TryParse(raw, out var ancho) && ancho is >= 1 and <= 12 ? ancho : int.Parse(fallback);
    }
    string ColClass(string bloque, string campo, string fallback = "3") => $"col-12 col-md-{Ancho(bloque, campo, fallback)}";
    string RequiredMark(string bloque, string campo) => Obligatorio(bloque, campo) ? " *" : string.Empty;
    var productBehavior = Model.FormularioConfiguracion.ProductoComportamiento;
    var mostrarBuscadorProducto = CampoVisible("PRODUCTOS", "BuscadorProducto");
    var mostrarAgregarProducto = CampoVisible("PRODUCTOS", "AgregarProducto");
    var mostrarItemProducto = CampoVisible("PRODUCTOS", "Item");
    var mostrarAccionProducto = CampoVisible("PRODUCTOS", "Accion");    var subtotalExonerado = 0m;
    var subtotalGravado = 0m;
    foreach (var detalle in detalles)
    {
        var importe = decimal.Round(detalle.Cantidad * detalle.CostoUnitario, 2);
        var producto = Model.Productos.FirstOrDefault(x => x.ProductoId == detalle.ProductoId);
        if (producto?.AfectoIgv == true) subtotalGravado += decimal.Round(importe / 1.18m, 2);
        else subtotalExonerado += importe;
    }
    var totalGravado = detalles.Sum(detalle =>
    {
        var producto = Model.Productos.FirstOrDefault(x => x.ProductoId == detalle.ProductoId);
        return producto?.AfectoIgv == true ? decimal.Round(detalle.Cantidad * detalle.CostoUnitario, 2) : 0m;
    });
    var igvCalculado = decimal.Round(totalGravado - subtotalGravado, 2);
    var totalCalculado = subtotalExonerado + subtotalGravado + igvCalculado;
    var productColumnsJson = JsonSerializer.Serialize(new[] { "Producto", "Unidad", "Stock", "Cantidad", "PrecioUnitario", "TotalLinea" });
    var productBehaviorJson = JsonSerializer.Serialize(new { cantidadInicial = productBehavior.CantidadInicial, unirProductosDuplicados = productBehavior.UnirProductosDuplicados, permitirEditarPrecio = productBehavior.PermitirEditarPrecio && !SoloLectura("PRODUCTOS", "PrecioUnitario"), permitirDescuento = false, mostrarStock = productBehavior.MostrarStock, bloquearSinStock = productBehavior.BloquearSinStock, mostrarItem = mostrarItemProducto, mostrarAccion = mostrarAccionProducto });
}

<form asp-action="Create" method="post" class="document-form comprobante-form quote-form compra-form">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger"></div>

    <section class="quote-panel quote-header-panel @(BloqueVisible("GENERAL") ? "" : "d-none")">
        <div class="quote-panel-title">
            <span class="document-section-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M6 3h9l4 4v14H6z" /><path d="M14 3v5h5M9 12h6M9 16h4" /></svg></span>
            <strong>@(bloques.TryGetValue("GENERAL", out var generalBlock) ? generalBlock.Titulo : "Informacion general")</strong>
            <span class="quote-number">@Model.OrdenCompra.Serie-@Model.OrdenCompra.Correlativo.ToString("000000")</span>
        </div>
        <div class="row g-2 quote-general-row">
            <label class="@ColClass("GENERAL", "Serie", "2")"><span>@Etiqueta("GENERAL", "Serie", "Serie")@RequiredMark("GENERAL", "Serie")</span><input asp-for="OrdenCompra.Serie" class="form-control" readonly="@(SoloLectura("GENERAL", "Serie"))" /></label>
            <label class="@ColClass("GENERAL", "Numero", "2")"><span>@Etiqueta("GENERAL", "Numero", "Numero")@RequiredMark("GENERAL", "Numero")</span><input asp-for="OrdenCompra.Correlativo" class="form-control text-end" readonly /></label>
            <label class="@ColClass("GENERAL", "Fecha", "2")"><span>@Etiqueta("GENERAL", "Fecha", "Fecha")@RequiredMark("GENERAL", "Fecha")</span><input asp-for="OrdenCompra.Fecha" type="date" class="form-control" readonly="@(SoloLectura("GENERAL", "Fecha"))" required="@(Obligatorio("GENERAL", "Fecha"))" /></label>
            <label class="@ColClass("GENERAL", "FormaPago", "2")"><span>@Etiqueta("GENERAL", "FormaPago", "Forma de pago")@RequiredMark("GENERAL", "FormaPago")</span><select asp-for="OrdenCompra.FormaPago" class="form-select" disabled="@(SoloLectura("GENERAL", "FormaPago"))" required="@(Obligatorio("GENERAL", "FormaPago"))"><option value="@FormaPagoCompra.CONTADO">Contado</option><option value="@FormaPagoCompra.CREDITO">Credito</option></select></label>
            <label class="@ColClass("GENERAL", "CondicionPago", "2")"><span>@Etiqueta("GENERAL", "CondicionPago", "Condicion de pago")@RequiredMark("GENERAL", "CondicionPago")</span><input asp-for="OrdenCompra.CondicionPago" class="form-control" readonly="@(SoloLectura("GENERAL", "CondicionPago"))" required="@(Obligatorio("GENERAL", "CondicionPago"))" /></label>
            <label class="@ColClass("GENERAL", "Moneda", "2")"><span>@Etiqueta("GENERAL", "Moneda", "Moneda")@RequiredMark("GENERAL", "Moneda")</span><input asp-for="OrdenCompra.Moneda" class="form-control" readonly="@(SoloLectura("GENERAL", "Moneda"))" required="@(Obligatorio("GENERAL", "Moneda"))" /></label>
            <label class="@ColClass("GENERAL", "FechaEsperada", "2")"><span>@Etiqueta("GENERAL", "FechaEsperada", "Fecha esperada")@RequiredMark("GENERAL", "FechaEsperada")</span><input asp-for="OrdenCompra.FechaEntregaEsperada" type="date" class="form-control" readonly="@(SoloLectura("GENERAL", "FechaEsperada"))" required="@(Obligatorio("GENERAL", "FechaEsperada"))" /></label>
            <label class="@ColClass("GENERAL", "LugarEntrega", "4")"><span>@Etiqueta("GENERAL", "LugarEntrega", "Lugar de entrega")@RequiredMark("GENERAL", "LugarEntrega")</span><input asp-for="OrdenCompra.LugarEntrega" class="form-control" readonly="@(SoloLectura("GENERAL", "LugarEntrega"))" required="@(Obligatorio("GENERAL", "LugarEntrega"))" /></label>
        </div>
    </section>
    <section class="quote-panel">
        <div class="quote-panel-title">
            <span class="document-section-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M20 21a8 8 0 0 0-16 0" /><path d="M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z" /></svg></span>
            <strong>Proveedor</strong>
        </div>
        <div class="quote-client-search">
            <input class="form-control" id="proveedorSearch" value="@proveedorTexto" placeholder="@Etiqueta("PROVEEDOR", "ProveedorBuscador", "Buscar proveedor por razon social, documento o telefono...")" autocomplete="off" required="@(Obligatorio("PROVEEDOR", "ProveedorBuscador"))" />
            <div class="producto-search-results proveedor-search-results" id="proveedorSearchResults" hidden></div>
            <input asp-for="OrdenCompra.ProveedorId" name="OrdenCompra.ProveedorId" type="hidden" id="proveedorId" />
        </div>
        <div class="quote-client-summary quote-client-summary-line">
            <div class="client-name-block"><span>Razon social</span><strong id="proveedorResumenNombre">@(proveedorSeleccionado?.RazonSocial ?? "Seleccione proveedor")</strong></div>
            <div><span>Tipo documento</span><strong id="proveedorResumenTipoDocumento">@(proveedorSeleccionado is null ? "-" : proveedorSeleccionado.TipoDocumento.ToString())</strong></div>
            <div><span>Numero documento</span><strong id="proveedorResumenDocumento">@(proveedorSeleccionado?.NumeroDocumento ?? "-")</strong></div>
            <div><span>Direccion</span><strong id="proveedorResumenDireccion">@(string.IsNullOrWhiteSpace(proveedorSeleccionado?.Direccion) ? "-" : proveedorSeleccionado.Direccion)</strong></div>
        </div>
    </section>

    <section class="quote-panel">
        <div class="quote-panel-title">
            <span class="document-section-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M12 3 3 7l9 4 9-4-9-4Z" /><path d="M3 12l9 4 9-4" /><path d="M3 17l9 4 9-4" /></svg></span>
            <strong>Detalle de productos</strong>
        </div>
        <div class="quote-product-picker @((mostrarBuscadorProducto || mostrarAgregarProducto) ? "" : "d-none")" data-product-grid-picker>
            <div class="producto-search-wrap quote-product-search @(mostrarBuscadorProducto ? "" : "d-none")">
                <input class="form-control producto-grid-search" placeholder="@Etiqueta("PRODUCTOS", "BuscadorProducto", "Buscar producto por nombre, codigo, SKU o codigo de barras...")" autocomplete="off" />
                <button type="button" class="producto-search-toggle" aria-label="Mostrar productos">v</button>
                <div class="producto-search-results" hidden></div>
            </div>
            <button type="button" class="document-more-btn product-grid-add @(mostrarAgregarProducto ? "" : "d-none")">+ @Etiqueta("PRODUCTOS", "AgregarProducto", "Agregar producto")</button>
        </div>
        <fieldset class="document-detail-fieldset quote-detail-fieldset">
            <div class="document-detail-table-wrap quote-detail-table-wrap">
                <table class="table table-sm data-grid detalle-grid document-detail-table quote-detail-table compra-detail-table" id="detalle" data-show-totals="true" data-product-picker-owned="true">
                    <colgroup><col style="width:34px" /><col style="width:34%" /><col style="width:12%" /><col style="width:12%" /><col style="width:14%" /><col style="width:14%" /><col style="width:14%" /><col style="width:52px" /></colgroup>
                    <thead><tr><th>#</th><th>Producto</th><th>Unidad</th><th class="text-end">Stock</th><th class="text-end">Cantidad</th><th class="text-end">Precio compra</th><th class="text-end">Total</th><th class="text-center">Accion</th></tr></thead>
                    <tbody>
                    @for (var i = 0; i < detalles.Count; i++)
                    {
                        var productoSeleccionado = Model.Productos.FirstOrDefault(x => x.ProductoId == detalles[i].ProductoId);
                        <tr>
                            <td class="quote-row-number">@(i + 1)</td>
                            <td data-field="Producto"><input class="form-control form-control-sm producto-search" value="@(productoSeleccionado is null ? string.Empty : string.IsNullOrWhiteSpace(productoSeleccionado.Categoria) ? productoSeleccionado.Nombre : $"{productoSeleccionado.Nombre} ({productoSeleccionado.Categoria})")" readonly /><input name="OrdenCompra.Detalles[@i].ProductoId" class="producto-select" type="hidden" value="@detalles[i].ProductoId" /></td>
                            <td data-field="Unidad"><input name="OrdenCompra.Detalles[@i].UnidadMedida" value="@(string.IsNullOrWhiteSpace(detalles[i].UnidadMedida) ? productoSeleccionado?.UnidadMedida ?? "NIU" : detalles[i].UnidadMedida)" class="form-control form-control-sm unidad-input" readonly /></td>
                            <td data-field="Stock"><input value="@((productoSeleccionado?.Stock ?? 0m).ToString("N2"))" class="form-control form-control-sm text-end stock-input" readonly /></td>
                            <td data-field="Cantidad"><input name="OrdenCompra.Detalles[@i].Cantidad" value="@detalles[i].Cantidad" class="form-control form-control-sm text-end cantidad-input" type="number" step="0.01" min="0.01" required /></td>
                            <td data-field="PrecioUnitario"><input name="OrdenCompra.Detalles[@i].CostoUnitario" value="@detalles[i].CostoUnitario" class="form-control form-control-sm text-end precio-input" type="number" step="0.01" min="0" required /></td>
                            <td data-field="TotalLinea"><input value="@((detalles[i].Cantidad * detalles[i].CostoUnitario).ToString("N2"))" class="form-control form-control-sm text-end line-total" readonly /></td>
                            <td class="text-center"><button type="button" class="icon-btn danger remove-row" title="Quitar fila" aria-label="Quitar fila"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18 6 6 18" /><path d="m6 6 12 12" /></svg></button></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </fieldset>
    </section>
    <section class="quote-panel">
        <div class="quote-panel-title">
            <span class="document-section-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M5 4h14v16H5z" /><path d="M8 8h8M8 12h8M8 16h5" /></svg></span>
            <strong>Condiciones comerciales</strong>
        </div>
        <div class="row g-2 quote-general-row">
            <label class="col-12 col-md-3"><span>Plazo de entrega</span><input asp-for="OrdenCompra.PlazoDias" class="form-control" type="number" min="0" /></label>
            <label class="col-12 col-md-3"><span>Garantia</span><input asp-for="OrdenCompra.Garantia" class="form-control" /></label>
            <label class="col-12 col-md-3"><span>% adelanto</span><input asp-for="OrdenCompra.PorcentajeAdelanto" class="form-control" type="number" step="0.01" min="0" /></label>
            <label class="col-12 col-md-3"><span>Condicion entrega</span><input asp-for="OrdenCompra.CondicionEntrega" class="form-control" /></label>
        </div>
    </section>

    <section class="quote-panel quote-observations-panel @(BloqueVisible("OBSERVACIONES") ? "" : "d-none")">
        <div class="quote-panel-title">
            <span class="document-section-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M5 4h14v16H5z" /><path d="M8 8h8M8 12h8M8 16h5" /></svg></span>
            <strong>@(bloques.TryGetValue("OBSERVACIONES", out var observacionesBlock) ? observacionesBlock.Titulo : "Observaciones")</strong>
        </div>
        <textarea asp-for="OrdenCompra.Observacion" class="form-control quote-observations-input" rows="2" placeholder="@Etiqueta("OBSERVACIONES", "Observacion", "Observaciones")"></textarea>
    </section>

    <div class="document-total-strip quote-total-strip @(BloqueVisible("TOTALES") ? "" : "d-none")" aria-label="Totales de orden de compra">
        <div><span>Subtotal exonerado</span><strong id="comprobanteSubtotalExonerado">S/ @subtotalExonerado.ToString("N2")</strong></div>
        <div><span>Subtotal gravado</span><strong id="comprobanteSubtotalGravado">S/ @subtotalGravado.ToString("N2")</strong></div>
        <div><span>Descuento</span><strong id="comprobanteDescuento">S/ 0.00</strong></div>
        <div><span>IGV (18%)</span><strong id="comprobanteIgv">S/ @igvCalculado.ToString("N2")</strong></div>
        <div class="grand-total"><span>Total</span><strong id="comprobanteTotal">S/ @totalCalculado.ToString("N2")</strong></div>
    </div>

    <div class="document-bottom-actions quote-bottom-actions @(BloqueVisible("ACCIONES") ? "" : "d-none")">
        @if (CampoVisible("ACCIONES", "Guardar")) { <button type="submit" class="document-save-btn">@Etiqueta("ACCIONES", "Guardar", "Guardar orden")</button> }
        @if (CampoVisible("ACCIONES", "Volver")) { <a class="document-more-btn" asp-action="Index">@Etiqueta("ACCIONES", "Volver", "Volver")</a> }
    </div>
</form>

@section Scripts {
    <script>
        (() => {
            const proveedores = @Html.Raw(proveedoresJson);
            const search = document.getElementById('proveedorSearch');
            const results = document.getElementById('proveedorSearchResults');
            const proveedorId = document.getElementById('proveedorId');
            const resumenNombre = document.getElementById('proveedorResumenNombre');
            const resumenTipo = document.getElementById('proveedorResumenTipoDocumento');
            const resumenDocumento = document.getElementById('proveedorResumenDocumento');
            const resumenDireccion = document.getElementById('proveedorResumenDireccion');
            if (!search || !results || !proveedorId) return;
            if (results.parentElement !== document.body) document.body.appendChild(results);
            let activeIndex = -1;
            let currentItems = [];
            let pointerInResults = false;
            const normalizar = (value) => String(value || '').normalize('NFD').replace(/[\u0300-\u036f]/g, '').trim().toUpperCase();
            const escapeHtml = (value) => String(value ?? '').replaceAll('&', '&amp;').replaceAll('<', '&lt;').replaceAll('>', '&gt;').replaceAll('"', '&quot;').replaceAll("'", '&#039;');
            const filtrar = () => {
                const term = normalizar(search.value);
                return proveedores.filter((proveedor) => !term
                    || normalizar(proveedor.texto).includes(term)
                    || normalizar(proveedor.nombre).includes(term)
                    || normalizar(proveedor.documento).includes(term)
                    || normalizar(proveedor.direccion).includes(term)).slice(0, 25);
            };
            const cerrar = () => { results.hidden = true; activeIndex = -1; };
            const posicionar = () => {
                const rect = search.getBoundingClientRect();
                results.style.left = `${rect.left}px`;
                results.style.top = `${rect.bottom + 4}px`;
                results.style.width = `${rect.width}px`;
            };
            const pintar = () => {
                currentItems = filtrar();
                activeIndex = currentItems.length ? 0 : -1;
                posicionar();
                results.innerHTML = currentItems.length
                    ? currentItems.map((proveedor, index) => `<button type="button" class="producto-search-option${index === 0 ? ' active' : ''}" data-id="${escapeHtml(proveedor.id)}"><strong>${escapeHtml(proveedor.nombre)}</strong><span>${escapeHtml(proveedor.tipoDocumento || '-')} | ${escapeHtml(proveedor.documento || '-')}</span><em>${escapeHtml(proveedor.direccion || '-')}</em></button>`).join('')
                    : '<div class="producto-search-empty">Sin coincidencias</div>';
                results.hidden = false;
            };
            const activar = (index) => {
                if (!currentItems.length) return;
                activeIndex = (index + currentItems.length) % currentItems.length;
                results.querySelectorAll('.producto-search-option').forEach((item, itemIndex) => {
                    item.classList.toggle('active', itemIndex === activeIndex);
                    if (itemIndex === activeIndex) item.scrollIntoView({ block: 'nearest' });
                });
            };
            const seleccionar = (proveedor) => {
                if (!proveedor) return;
                proveedorId.value = proveedor.id;
                search.value = proveedor.texto || `${proveedor.nombre} - ${proveedor.documento}`;
                if (resumenNombre) resumenNombre.textContent = proveedor.nombre || 'Seleccione proveedor';
                if (resumenTipo) resumenTipo.textContent = proveedor.tipoDocumento || '-';
                if (resumenDocumento) resumenDocumento.textContent = proveedor.documento || '-';
                if (resumenDireccion) resumenDireccion.textContent = proveedor.direccion || '-';
                cerrar();
            };
            const resolver = () => {
                const exacto = proveedores.find((proveedor) => normalizar(proveedor.texto) === normalizar(search.value));
                if (exacto) seleccionar(exacto);
            };
            search.addEventListener('input', () => { proveedorId.value = ''; pintar(); });
            search.addEventListener('focus', pintar);
            search.addEventListener('blur', () => window.setTimeout(() => { if (!pointerInResults) { resolver(); cerrar(); } }, 150));
            search.addEventListener('keydown', (event) => {
                if (event.key === 'ArrowDown') { event.preventDefault(); if (results.hidden) pintar(); else activar(activeIndex + 1); }
                if (event.key === 'ArrowUp') { event.preventDefault(); if (results.hidden) pintar(); else activar(activeIndex - 1); }
                if (event.key === 'Enter') { event.preventDefault(); seleccionar(currentItems[activeIndex] || currentItems[0]); }
                if (event.key === 'Escape') { event.preventDefault(); cerrar(); }
            });
            results.addEventListener('pointerenter', () => { pointerInResults = true; });
            results.addEventListener('pointerleave', () => { pointerInResults = false; });
            results.addEventListener('mousedown', (event) => {
                const option = event.target.closest('.producto-search-option');
                if (!option) return;
                event.preventDefault();
                seleccionar(proveedores.find((proveedor) => String(proveedor.id) === String(option.dataset.id)));
            });
            window.addEventListener('resize', cerrar);
            window.addEventListener('scroll', (event) => { if (!results.contains(event.target)) cerrar(); }, true);
        })();
        window.viveroProductoGridSearch({
            productos: @Html.Raw(productosJson),
            tableSelector: '#detalle',
            columns: @Html.Raw(productColumnsJson),
            behavior: @Html.Raw(productBehaviorJson),
            priceFieldName: 'CostoUnitario',
            unitFieldName: 'UnidadMedida',
            detailPrefix: 'OrdenCompra.Detalles'
        });
    </script>
}