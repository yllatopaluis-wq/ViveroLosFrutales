@model PagedResult<OrdenCompraListDto>
@{
    ViewData["Title"] = "Ordenes de compra";
    var today = PeruDateTime.Today;
    var firstDay = new DateTime(today.Year, today.Month, 1).ToString("yyyy-MM-dd");
    var currentDay = today.ToString("yyyy-MM-dd");
    var fechaDesde = Context.Request.Query["FechaDesde"].FirstOrDefault() ?? firstDay;
    var fechaHasta = Context.Request.Query["FechaHasta"].FirstOrDefault() ?? currentDay;
    var search = Context.Request.Query["Search"].FirstOrDefault();
    var pageSize = Context.Request.Query["PageSize"].FirstOrDefault() ?? Model.PageSize.ToString();
}
@functions {
    private static string EstadoDocumentoClass(EstadoDocumentoOrdenCompra estado) => estado == EstadoDocumentoOrdenCompra.ACTIVO ? "success" : estado == EstadoDocumentoOrdenCompra.CERRADO ? "info" : "danger";
    private static string EstadoFacturacionClass(EstadoFacturacionOrdenCompra estado) => estado == EstadoFacturacionOrdenCompra.FACTURADO_TOTAL ? "success" : estado == EstadoFacturacionOrdenCompra.FACTURADO_PARCIAL ? "warning" : estado == EstadoFacturacionOrdenCompra.FACTURADO_CON_DIFERENCIA ? "danger" : "info";
    private static string EstadoFinancieroClass(EstadoFinancieroOrdenCompra estado) => estado == EstadoFinancieroOrdenCompra.PAGADO ? "success" : estado == EstadoFinancieroOrdenCompra.SALDO_A_FAVOR ? "warning" : estado == EstadoFinancieroOrdenCompra.PAGO_PARCIAL ? "info" : "muted";
}
<section class="comprobantes-page ops-docs-page">
<form method="get" class="comprobantes-toolbar sales-docs-toolbar">
    <label class="comprobantes-search"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7" /><path d="m20 20-4-4" /></svg><input name="Search" value="@search" placeholder="Buscar proveedor, documento u orden..." autocomplete="off" />@if (!string.IsNullOrWhiteSpace(search)) { <a class="search-clear" asp-action="Index" asp-route-FechaDesde="@fechaDesde" asp-route-FechaHasta="@fechaHasta" asp-route-PageSize="@pageSize" aria-label="Limpiar busqueda">&times;</a> }</label>
    <label class="filter-field"><span>Desde</span><input name="FechaDesde" type="date" value="@fechaDesde" /></label>
    <label class="filter-field"><span>Hasta</span><input name="FechaHasta" type="date" value="@fechaHasta" /></label>
    <input type="hidden" name="PageSize" value="@pageSize" />
    <button class="btn-search" type="submit"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7" /><path d="m20 20-4-4" /></svg>Buscar</button>
    <button class="btn-export" type="button" id="exportOrdenesCompraCsv"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3v12" /><path d="m8 11 4 4 4-4" /><path d="M5 20h14" /></svg>Exportar</button>
</form>
@if (TempData["Error"] is string error) { <div class="alert alert-danger py-2">@error</div> }
@if (TempData["Success"] is string success) { <div class="alert alert-success py-2">@success</div> }
<div class="comprobantes-list ops-docs-list"><div class="comprobantes-head ops-docs-head"><span>Orden</span><span>Proveedor</span><span>Total OC</span><span>Facturado / Pagado</span><span>Estado</span><span>Acciones</span></div>
@if (!Model.Items.Any()) { <div class="comprobantes-empty"><strong>No hay ordenes de compra</strong><span>Ajusta los filtros o registra una nueva orden.</span></div> } else {
@foreach (var item in Model.Items) {
<article class="comprobante-row ops-docs-row" data-csv="@item.Fecha.ToString("dd/MM/yyyy")|@item.Documento|@item.Proveedor|@item.Total.ToString("N2")|@item.TotalFacturado.ToString("N2")|@item.TotalPagado.ToString("N2")|@item.TotalAplicado.ToString("N2")|@item.SaldoDisponible.ToString("N2")|@item.PendienteFacturar.ToString("N2")|@item.EstadoFacturacion|@item.EstadoFinanciero|@item.EstadoDocumento">
<div class="comprobante-main"><span class="comprobante-icon @(item.EstadoDocumento == EstadoDocumentoOrdenCompra.ACTIVO ? "success" : item.EstadoDocumento == EstadoDocumentoOrdenCompra.CERRADO ? "info" : "danger")"><svg viewBox="0 0 24 24"><path d="M6 3h9l4 4v14H6z" /><path d="M14 3v5h5M9 12h6M9 16h4" /></svg></span><span class="comprobante-copy"><strong>@item.Documento</strong><small>@item.Fecha.ToString("dd/MM/yyyy")</small></span></div>
<div class="comprobante-client"><strong>@item.Proveedor</strong><small>Proveedor</small></div>
<div class="comprobante-total">S/ @item.Total.ToString("N2")</div>
<div class="comprobante-status"><span class="sunat-line success">Facturado: S/ @item.TotalFacturado.ToString("N2")</span><span class="sunat-line muted">Pagado: S/ @item.TotalPagado.ToString("N2")</span><span class="sunat-line muted">Disponible: S/ @item.SaldoDisponible.ToString("N2")</span></div>
<div class="comprobante-sunat"><span class="pill @EstadoFacturacionClass(item.EstadoFacturacion)">@item.EstadoFacturacion</span><span class="pill @EstadoFinancieroClass(item.EstadoFinanciero)">@item.EstadoFinanciero</span><span class="pill @EstadoDocumentoClass(item.EstadoDocumento)">@item.EstadoDocumento</span></div>
<div class="comprobante-actions"><details class="row-actions-menu"><summary aria-label="Abrir acciones"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="5" r="1.5" /><circle cx="12" cy="12" r="1.5" /><circle cx="12" cy="19" r="1.5" /></svg></summary><div class="row-actions-panel"><a asp-action="Details" asp-route-id="@item.OrdenCompraId"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6Z" /><path d="M12 9a3 3 0 1 1 0 6 3 3 0 0 1 0-6Z" /></svg> Ver orden</a>@if (item.PuedeRegistrarPago) { <a asp-action="RegistrarPago" asp-route-id="@item.OrdenCompraId"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="8" /><path d="M12 7v10M9 10.5c0-1.4 1.3-2 3-2s3 .6 3 2-1.3 2-3 2-3 .6-3 2 1.3 2 3 2 3-.6 3-2" /></svg> Registrar pago</a> }@if (item.PuedeRegistrarCompra) { <a asp-action="RegistrarCompra" asp-route-id="@item.OrdenCompraId"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 6h16" /><path d="M4 12h16" /><path d="M4 18h10" /></svg> Registrar compra</a> }@if (item.PuedeCerrar) { <form asp-action="Cerrar" method="post">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@item.OrdenCompraId" /><input type="hidden" name="solicitarDevolucion" value="false" /><button type="submit"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 6 9 17l-5-5" /></svg> Cerrar orden</button></form> }@if (item.PuedeAnular) { <form asp-action="Anular" method="post" onsubmit="return solicitarMotivoAnulacionOrdenCompra(this, '@item.Documento');">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@item.OrdenCompraId" /><input type="hidden" name="motivo" value="" /><button type="submit" class="danger"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 6h18" /><path d="M8 6V4h8v2M19 6l-1 14H6L5 6" /><path d="M10 11v5M14 11v5" /></svg> Anular orden</button></form> }</div></details></div>
</article>}}
</div>@await Html.PartialAsync("_Pager", Model)</section>

<script>
    document.querySelectorAll('.row-actions-menu').forEach(menu => {
        menu.addEventListener('toggle', () => {
            if (!menu.open) return;
            document.querySelectorAll('.row-actions-menu[open]').forEach(other => { if (other !== menu) other.removeAttribute('open'); });
        });
    });
    document.addEventListener('click', event => {
        if (event.target.closest('.row-actions-menu')) return;
        document.querySelectorAll('.row-actions-menu[open]').forEach(menu => menu.removeAttribute('open'));
    });
    document.getElementById('exportOrdenesCompraCsv')?.addEventListener('click', () => {
        const rows = Array.from(document.querySelectorAll('.ops-docs-row[data-csv]'));
        const header = ["Fecha","Orden","Proveedor","Total","Facturado","Pagado","Aplicado","Disponible","Pendiente facturar","Estado facturacion","Estado financiero","Estado documento"];
        const csvRows = [header, ...rows.map(row => row.dataset.csv.split('|'))].map(cols => cols.map(value => '"' + String(value ?? '').replaceAll('"', '""') + '"').join(','));
        const blob = new Blob([csvRows.join('\n')], { type: 'text/csv;charset=utf-8;' });
        const url = URL.createObjectURL(blob);
        const link = document.createElement('a');
        link.href = url;
        link.download = 'ordenes-compra.csv';
        link.click();
        URL.revokeObjectURL(url);
    });
</script>
<script>function solicitarMotivoAnulacionOrdenCompra(form, documento) { const motivo = prompt('Ingrese el motivo de anulacion de la orden ' + documento + ':'); if (motivo === null) return false; const motivoLimpio = motivo.trim(); if (!motivoLimpio) { alert('Debe ingresar el motivo de anulacion.'); return false; } form.querySelector("input[name='motivo']").value = motivoLimpio; return confirm('Confirmar anulacion de la orden?'); }</script>
