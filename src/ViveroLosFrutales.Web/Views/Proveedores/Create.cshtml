@model ProveedorEditDto
@{
    var readOnly = ViewData["ReadOnly"] as bool? == true;
    ViewData["Title"] = readOnly ? "Visualizar Proveedor" : Model.ProveedorId == 0 ? "Crear Proveedor" : "Editar Proveedor";
}

<form method="post" class="dense-form document-entry-form">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input asp-for="ProveedorId" type="hidden" />
    <input asp-for="Estado" type="hidden" />
    <fieldset disabled="@readOnly" class="form-grid cols-3">
        <label>Tipo Documento<select asp-for="TipoDocumento" asp-items="Html.GetEnumSelectList<TipoDocumentoCliente>()" class="form-select form-select-sm"></select><span asp-validation-for="TipoDocumento" class="text-danger"></span></label>
        <label>Numero Documento<input asp-for="NumeroDocumento" class="form-control form-control-sm" maxlength="11" /><span asp-validation-for="NumeroDocumento" class="text-danger"></span></label>
        <label>Razon Social<input asp-for="RazonSocial" class="form-control form-control-sm" /><span asp-validation-for="RazonSocial" class="text-danger"></span></label>
        <label>Nombre Comercial<input asp-for="NombreComercial" class="form-control form-control-sm" /><span asp-validation-for="NombreComercial" class="text-danger"></span></label>
        <label>Direccion<input asp-for="Direccion" class="form-control form-control-sm" /><span asp-validation-for="Direccion" class="text-danger"></span></label>
        <label>Telefono<input asp-for="Telefono" class="form-control form-control-sm" /><span asp-validation-for="Telefono" class="text-danger"></span></label>
        <label>Email<input asp-for="Email" class="form-control form-control-sm" type="email" /><span asp-validation-for="Email" class="text-danger"></span></label>
    </fieldset>
    <div class="form-actions">
        @if (!readOnly)
        {
            <button class="btn btn-sm btn-primary">Guardar</button>
        }
        <a class="btn btn-sm btn-outline-secondary" asp-action="Index">Volver</a>
    </div>
</form>
