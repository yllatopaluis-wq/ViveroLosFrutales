@model NotaPedidoFormDataDto
@using System.Text.Json
@{
    var isEditing = Model.NotaPedido.NotaPedidoId > 0;
    var formAction = isEditing ? "Edit" : "Nuevo";
    ViewData["Title"] = isEditing ? "Editar nota de pedido" : "Nueva nota de pedido";
    var clienteSeleccionado = Model.Clientes.FirstOrDefault(x => x.ClienteId == Model.NotaPedido.ClienteId);
    var clienteTexto = clienteSeleccionado is null ? string.Empty : $"{clienteSeleccionado.NombreCompleto} - {clienteSeleccionado.NumeroDocumento}";
    var clienteDireccion = clienteSeleccionado?.Direccion ?? string.Empty;
    var clientesJson = JsonSerializer.Serialize(Model.Clientes.Select(x => new
    {
        id = x.ClienteId,
        nombre = x.NombreCompleto,
        documento = x.NumeroDocumento,
        direccion = x.Direccion,
        texto = $"{x.NombreCompleto} - {x.NumeroDocumento}"
    }));
    var productosJson = JsonSerializer.Serialize(Model.Productos.Select(x => new
    {
        id = x.ProductoId,
        nombre = x.Nombre,
        categoria = x.Categoria,
        precio = x.PrecioVentaConIgv,
        stock = x.Stock,
        afectoIgv = x.AfectoIgv,
        texto = string.IsNullOrWhiteSpace(x.Categoria) ? x.Nombre : $"{x.Nombre} ({x.Categoria})"
    }));
    var detalles = Model.NotaPedido.Detalles.Count == 0 ? new List<NotaPedidoDetalleEditDto> { new() } : Model.NotaPedido.Detalles;
    var subtotalExonerado = 0m;
    var subtotalGravado = 0m;
    foreach (var detalle in detalles)
    {
        var importe = decimal.Round(detalle.Cantidad * detalle.PrecioUnitario, 2);
        var producto = Model.Productos.FirstOrDefault(x => x.ProductoId == detalle.ProductoId);
        if (producto?.AfectoIgv == true)
        {
            subtotalGravado += decimal.Round(importe / 1.18m, 2);
        }
        else
        {
            subtotalExonerado += importe;
        }
    }
    var totalGravado = detalles.Sum(detalle =>
    {
        var producto = Model.Productos.FirstOrDefault(x => x.ProductoId == detalle.ProductoId);
        return producto?.AfectoIgv == true ? decimal.Round(detalle.Cantidad * detalle.PrecioUnitario, 2) : 0m;
    });
    var igvCalculado = decimal.Round(totalGravado - subtotalGravado, 2);
    var totalCalculado = subtotalExonerado + subtotalGravado + igvCalculado;
}

<form asp-action="@formAction" method="post" class="document-form comprobante-form">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger"></div>
    <input asp-for="NotaPedido.NotaPedidoId" name="NotaPedidoId" type="hidden" />

    <section class="document-section">
        <div class="document-section-heading">
            <span class="document-section-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M6 3h9l4 4v14H6z" /><path d="M14 3v5h5M9 12h6M9 16h4" /></svg></span>
            <h3>Información de la nota de pedido</h3>
        </div>
        <fieldset class="document-grid order-main-grid">
            <label>
                <span>Serie</span>
                <input asp-for="NotaPedido.Serie" name="Serie" class="form-control" id="serieComprobante" readonly />
            </label>
            <label>
                <span>Número</span>
                <input asp-for="NotaPedido.Correlativo" name="Correlativo" class="form-control text-end" id="correlativoComprobante" readonly />
            </label>
            <label>
                <span>Fecha</span>
                <input asp-for="NotaPedido.Fecha" name="Fecha" class="form-control" type="date" />
            </label>
        </fieldset>
    </section>

    <section class="document-section">
        <div class="document-section-heading">
            <span class="document-section-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M20 21a8 8 0 0 0-16 0" /><path d="M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z" /></svg></span>
            <h3>Cliente</h3>
        </div>
        <fieldset class="document-grid client-document-grid">
            <label>
                <span>Buscar cliente</span>
                <input class="form-control" id="clienteSearch" list="clientesOptions" value="@clienteTexto" placeholder="Buscar por nombre o número de documento..." autocomplete="off" />
                <input asp-for="NotaPedido.ClienteId" name="ClienteId" type="hidden" id="clienteId" />
            </label>
            <label>
                <span>Dirección</span>
                <input class="form-control" id="clienteDireccion" value="@clienteDireccion" readonly />
            </label>
        </fieldset>
    </section>

    <section class="document-section">
        <div class="document-section-heading">
            <span class="document-section-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M12 3 3 7l9 4 9-4-9-4Z" /><path d="M3 12l9 4 9-4" /><path d="M3 17l9 4 9-4" /></svg></span>
            <h3>Detalle de productos</h3>
        </div>
        <fieldset class="document-detail-fieldset">
            <div class="document-detail-table-wrap">
                <table class="table table-sm data-grid detalle-grid document-detail-table" id="detalle" data-show-totals="true">
                    <colgroup>
                        <col class="detalle-producto" />
                        <col class="detalle-unidad" />
                        <col class="detalle-cantidad" />
                        <col class="detalle-precio" />
                        <col class="detalle-total" />
                        <col class="detalle-accion" />
                    </colgroup>
                    <thead>
                        <tr>
                            <th>Producto</th>
                            <th>Unidad</th>
                            <th class="text-end">Cantidad</th>
                            <th class="text-end">Precio unitario</th>
                            <th class="text-end">Total</th>
                            <th class="text-center">Acción</th>
                        </tr>
                    </thead>
                    <tbody>
                    @for (var i = 0; i < detalles.Count; i++)
                    {
                        <tr>
                            <td>
                                <select name="Detalles[@i].ProductoId" class="form-select form-select-sm producto-select">
                                    <option value="">Seleccione producto</option>
                                    @foreach (var producto in Model.Productos)
                                    {
                                        var selected = detalles[i].ProductoId == producto.ProductoId;
                                        <option value="@producto.ProductoId" data-precio="@producto.PrecioVentaConIgv" data-afecto-igv="@producto.AfectoIgv" selected="@selected">
                                            @(string.IsNullOrWhiteSpace(producto.Categoria) ? producto.Nombre : $"{producto.Nombre} ({producto.Categoria})")
                                        </option>
                                    }
                                </select>
                            </td>
                            <td><input value="UNIDAD" class="form-control form-control-sm" readonly /></td>
                            <td><input name="Detalles[@i].Cantidad" value="@detalles[i].Cantidad" class="form-control form-control-sm text-end cantidad-input" type="number" step="0.01" min="0.01" /></td>
                            <td><input name="Detalles[@i].PrecioUnitario" value="@detalles[i].PrecioUnitario" class="form-control form-control-sm text-end precio-input" type="number" step="0.01" min="0" /></td>
                            <td><input value="@((detalles[i].Cantidad * detalles[i].PrecioUnitario).ToString("N2"))" class="form-control form-control-sm text-end line-total" readonly /></td>
                            <td class="text-center"><button type="button" class="icon-btn primary add-row" title="Agregar fila" aria-label="Agregar fila"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 5v14" /><path d="M5 12h14" /></svg></button></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </fieldset>
        <div class="document-total-strip">
            <div><span>Subtotal exonerado</span><strong id="comprobanteSubtotalExonerado">S/ @subtotalExonerado.ToString("N2")</strong></div>
            <div><span>Subtotal gravado</span><strong id="comprobanteSubtotalGravado">S/ @subtotalGravado.ToString("N2")</strong></div>
            <div><span>IGV</span><strong id="comprobanteIgv">S/ @igvCalculado.ToString("N2")</strong></div>
            <div class="grand-total"><span>Total</span><strong id="comprobanteTotal">S/ @totalCalculado.ToString("N2")</strong></div>
        </div>
    </section>

    <div class="document-bottom-actions">
        <button type="submit" class="document-save-btn">Guardar</button>
        <a class="document-more-btn" asp-action="Index">Volver</a>
    </div>
</form>

@section Scripts {
    <script>
        window.viveroNotaPedidoForm({
            clientes: @Html.Raw(clientesJson),
            productos: @Html.Raw(productosJson),
            clientesUrl: '@Url.Action("BuscarClientes", "NotasPedido")',
            productosUrl: '@Url.Action("BuscarProductos", "NotasPedido")'
        });
    </script>
}
