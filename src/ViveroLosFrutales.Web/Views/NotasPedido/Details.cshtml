@model NotaPedidoDetalleViewDto
@{
    ViewData["Title"] = "Detalle Nota de Pedido";
    var puedeCobrar = Model.EstadoDocumento == NotaPedidoEstado.ACTIVO
        && Model.EstadoPago != EstadoPagoNotaPedido.PAGADO
        && Model.ComprobanteId is null;
    var puedeConvertir = Model.EstadoDocumento == NotaPedidoEstado.ACTIVO
        && Model.EstadoPago == EstadoPagoNotaPedido.PAGADO
        && Model.SaldoPendiente <= 0
        && Model.ComprobanteId is null;
    var estadoDocumentoTexto = EstadoDocumentoTexto(Model.EstadoDocumento);
    var estadoPagoTexto = EstadoPagoTexto(Model.EstadoPago);
    var estadoDocumentoClase = Model.EstadoDocumento == NotaPedidoEstado.ACTIVO ? string.Empty : "danger";
    var estadoPagoClase = Model.EstadoPago == EstadoPagoNotaPedido.PAGADO ? string.Empty : Model.EstadoPago == EstadoPagoNotaPedido.PAGO_PARCIAL ? "warning" : "info";
}

@functions {
    private static string EstadoPagoTexto(EstadoPagoNotaPedido estado) => estado switch
    {
        EstadoPagoNotaPedido.PENDIENTE => "PENDIENTE",
        EstadoPagoNotaPedido.PAGO_PARCIAL => "PARCIAL",
        EstadoPagoNotaPedido.PAGADO => "PAGADO",
        _ => estado.ToString()
    };

    private static string EstadoDocumentoTexto(NotaPedidoEstado estado) =>
        estado == NotaPedidoEstado.ACTIVO ? "ACTIVO" : "ANULADO";

    private static string EstadoCobroTexto(CobroClienteEstado estado) =>
        estado == CobroClienteEstado.ACTIVO ? "ACTIVO" : "ANULADO";

    private static string EstadoCobroClase(CobroClienteEstado estado) =>
        estado == CobroClienteEstado.ACTIVO ? string.Empty : "danger";
}

<section class="ds-document-shell">
    <header class="ds-document-header">
        <div class="ds-document-title">
            <div class="ds-document-eyebrow"><span class="document-section-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M6 3h9l4 4v14H6z" /><path d="M14 3v5h5M9 12h6M9 16h4" /></svg></span><span>Detalle Nota de Pedido</span></div>
            <div class="ds-document-number-row"><h1 class="ds-document-number">@Model.Numero</h1><span class="ds-status @estadoPagoClase">@estadoPagoTexto</span></div>
            <span class="ds-document-subtitle">@Model.Cliente</span>
        </div>
        <div class="ds-document-actions">
            @if (puedeCobrar)
            {
                <a class="ds-action primary" asp-action="RegistrarCobro" asp-route-id="@Model.NotaPedidoId"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2v20" /><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7H14a3.5 3.5 0 0 1 0 7H6" /></svg> Registrar cobro</a>
            }
            @if (puedeConvertir)
            {
                <form asp-action="ConvertirAComprobante" method="post" class="icon-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.NotaPedidoId" />
                    <button class="ds-action primary" type="submit"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 7h10v10" /><path d="M7 17 17 7" /></svg> Convertir a Comprobante</button>
                </form>
            }
            <a class="ds-action outline" asp-action="Edit" asp-route-id="@Model.NotaPedidoId"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 20h9" /><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z" /></svg> Editar</a>
            <form asp-action="Imprimir" method="post" class="icon-form" target="_blank">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.NotaPedidoId" />
                <button type="submit" class="ds-action ghost"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 9V3h12v6" /><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" /><path d="M6 14h12v7H6z" /></svg> Imprimir PDF</button>
            </form>
            <a class="ds-action ghost" asp-action="Index"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M19 12H5" /><path d="m12 19-7-7 7-7" /></svg> Volver</a>
        </div>
    </header>

    <div class="ds-kpi-grid">
        <article class="ds-kpi"><div class="ds-kpi-copy"><small>Total pedido</small><strong>S/ @Model.Total.ToString("N2")</strong></div><span class="ds-kpi-icon"><svg viewBox="0 0 24 24"><path d="M6 6h15l-1.5 9h-12z" /><path d="M6 6 5 3H2" /></svg></span></article>
        <article class="ds-kpi blue"><div class="ds-kpi-copy"><small>Total cobrado</small><strong>S/ @Model.TotalCobrado.ToString("N2")</strong></div><span class="ds-kpi-icon"><svg viewBox="0 0 24 24"><path d="M4 7h16v12H4z" /><path d="M16 11h4" /></svg></span></article>
        <article class="ds-kpi orange"><div class="ds-kpi-copy"><small>Saldo pendiente</small><strong>S/ @Model.SaldoPendiente.ToString("N2")</strong></div><span class="ds-kpi-icon"><svg viewBox="0 0 24 24"><path d="M12 8v8" /><path d="M8 12h8" /><circle cx="12" cy="12" r="9" /></svg></span></article>
        <article class="ds-kpi neutral"><div class="ds-kpi-copy"><small>Estado documento</small><strong><span class="ds-status @estadoDocumentoClase">@estadoDocumentoTexto</span></strong></div><span class="ds-kpi-icon"><svg viewBox="0 0 24 24"><path d="M6 3h9l4 4v14H6z" /><path d="M14 3v5h5" /></svg></span></article>
    </div>

    <section class="ds-panel">
        <div class="ds-panel-title"><span class="document-section-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M20 21a8 8 0 0 0-16 0" /><path d="M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z" /></svg></span><strong>Informacion general</strong></div>
        <div class="ds-info-grid">
            <div class="ds-field wide"><span>Cliente</span><strong>@Model.Cliente</strong></div>
            <div class="ds-field"><span>Tipo documento</span><strong>@Model.ClienteTipoDocumento</strong></div>
            <div class="ds-field"><span>Numero</span><strong>@Model.Numero</strong></div>
            <div class="ds-field"><span>Fecha</span><strong>@Model.Fecha.ToString("dd/MM/yyyy")</strong></div>
            <div class="ds-field"><span>Subtotal</span><strong>S/ @Model.Subtotal.ToString("N2")</strong></div>
            <div class="ds-field"><span>IGV</span><strong>S/ @Model.Igv.ToString("N2")</strong></div>
        </div>
    </section>

    <div class="ds-document-content">
        <section class="ds-panel ds-products-panel">
            <div class="ds-panel-title"><span class="document-section-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M12 3 3 7l9 4 9-4-9-4Z" /><path d="M3 12l9 4 9-4" /><path d="M3 17l9 4 9-4" /></svg></span><strong>Productos</strong></div>
            <div class="ds-table-wrap"><table class="ds-table"><thead><tr><th>#</th><th>Producto</th><th class="text-end">Cantidad</th><th class="text-end">Precio</th><th class="text-end">Subtotal</th><th class="text-end">IGV</th><th class="text-end">Total</th></tr></thead><tbody>
            @{ var index = 1; }
            @foreach (var item in Model.Detalles)
            {
                <tr><td>@index</td><td>@item.Producto</td><td class="text-end">@item.Cantidad.ToString("N2")</td><td class="text-end">S/ @item.PrecioUnitario.ToString("N2")</td><td class="text-end">S/ @item.Subtotal.ToString("N2")</td><td class="text-end">S/ @item.Igv.ToString("N2")</td><td class="text-end"><strong>S/ @item.Total.ToString("N2")</strong></td></tr>
                index++;
            }
            <tr class="ds-total-row"><td colspan="2">Totales</td><td class="text-end">@Model.Detalles.Sum(x => x.Cantidad).ToString("N2")</td><td></td><td class="text-end">S/ @Model.Subtotal.ToString("N2")</td><td class="text-end">S/ @Model.Igv.ToString("N2")</td><td class="text-end">S/ @Model.Total.ToString("N2")</td></tr>
            </tbody></table></div>
        </section>

        <section class="ds-tabs-panel">
            <div class="ds-tabs">
                <input type="radio" name="notaPedidoTabs" id="notaPedidoTabCobros" checked />
                <label for="notaPedidoTabCobros">Historial de cobros</label>
                <input type="radio" name="notaPedidoTabs" id="notaPedidoTabComprobantes" />
                <label for="notaPedidoTabComprobantes">Comprobantes relacionados</label>

                <div class="ds-tab-content ds-tab-cobros">
                @if (Model.Cobros.Any())
                {
                    <ol class="ds-timeline">
                    @foreach (var cobro in Model.Cobros.OrderByDescending(x => x.FechaCobro))
                    {
                        <li class="ds-timeline-item"><strong>@cobro.FechaCobro.ToString("dd/MM/yyyy") - S/ @cobro.Monto.ToString("N2")</strong><span>@cobro.MedioPago - <span class="ds-status @EstadoCobroClase(cobro.Estado)">@EstadoCobroTexto(cobro.Estado)</span></span><small>@(string.IsNullOrWhiteSpace(cobro.Observacion) ? "Sin observacion" : cobro.Observacion)</small></li>
                    }
                    </ol>
                }
                else
                {
                    <div class="ds-note-card">No hay cobros registrados.</div>
                }
                </div>

                <div class="ds-tab-content ds-tab-comprobantes">
                    <div class="ds-note-card">@(Model.Comprobantes.Any() ? $"{Model.Comprobantes.Count} comprobante(s) relacionado(s)." : "No hay comprobantes relacionados.")</div>
                </div>
            </div>
        </section>
    </div>
</section>
