@model PagedResult<NotaPedidoListDto>
@{
    ViewData["Title"] = "Notas de Pedido";
    var today = DateTime.Today;
    var firstDay = new DateTime(today.Year, today.Month, 1).ToString("yyyy-MM-dd");
    var currentDay = today.ToString("yyyy-MM-dd");
    var fechaDesde = Context.Request.Query["FechaDesde"].FirstOrDefault() ?? firstDay;
    var fechaHasta = Context.Request.Query["FechaHasta"].FirstOrDefault() ?? currentDay;
    var search = Context.Request.Query["Search"].FirstOrDefault();
}

@functions {
    private static string EstadoPagoTexto(EstadoPagoNotaPedido estado) => estado switch
    {
        EstadoPagoNotaPedido.PENDIENTE => "PENDIENTE",
        EstadoPagoNotaPedido.PAGO_PARCIAL => "PARCIAL",
        EstadoPagoNotaPedido.PAGADO => "PAGADO",
        _ => estado.ToString()
    };

    private static string EstadoDocumentoTexto(NotaPedidoEstado estado) =>
        estado == NotaPedidoEstado.ACTIVO ? "ACTIVO" : "ANULADO";
}

<div class="toolbar">
    <form method="get" class="search-form">
        <input name="FechaDesde" class="form-control form-control-sm" type="date" value="@fechaDesde" />
        <input name="FechaHasta" class="form-control form-control-sm" type="date" value="@fechaHasta" />
        <input name="Search" class="form-control form-control-sm" value="@search" placeholder="Cliente o numero" />
        <button class="btn btn-sm btn-primary">Buscar</button>
    </form>
    <a class="btn btn-sm btn-success" asp-action="Nuevo">Nueva Nota</a>
</div>

@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger py-2">@error</div>
}
@if (TempData["Success"] is string success)
{
    <div class="alert alert-success py-2">@success</div>
}

<table class="table table-sm table-striped data-grid notas-pedido-grid">
    <thead>
        <tr>
            <th>Numero</th>
            <th>Fecha</th>
            <th>Cliente</th>
            <th class="text-end">Total</th>
            <th class="text-end">Cobrado</th>
            <th class="text-end">Saldo</th>
            <th class="estado-pago-col">Estado Pago</th>
            <th>Estado Devolucion</th>
            <th class="estado-documento-col">Estado Doc.</th>
            <th class="text-end actions-heading">Acciones</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.Items)
    {
        var soloVer = item.EstadoDocumento == NotaPedidoEstado.ANULADO;
        var tieneComprobante = item.ComprobanteId is not null;
        var puedeEditar = item.EstadoDocumento == NotaPedidoEstado.ACTIVO && !tieneComprobante;
        var puedeCobrar = item.EstadoDocumento == NotaPedidoEstado.ACTIVO && !tieneComprobante && item.EstadoPago != EstadoPagoNotaPedido.PAGADO;
        var puedeAnular = item.EstadoDocumento == NotaPedidoEstado.ACTIVO
            && !tieneComprobante;
        <tr>
            <td>@item.Numero</td>
            <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
            <td>@item.Cliente</td>
            <td class="text-end">S/ @item.Total.ToString("N2")</td>
            <td class="text-end">S/ @item.TotalCobrado.ToString("N2")</td>
            <td class="text-end">S/ @item.SaldoPendiente.ToString("N2")</td>
            <td class="estado-pago-col"><span class="status-badge compact @(item.EstadoPago == EstadoPagoNotaPedido.PAGADO ? "active" : item.EstadoPago == EstadoPagoNotaPedido.PAGO_PARCIAL ? "warning" : string.Empty)">@EstadoPagoTexto(item.EstadoPago)</span></td>
            <td>@item.EstadoDevolucion</td>
            <td class="estado-documento-col"><span class="status-badge compact @(item.EstadoDocumento == NotaPedidoEstado.ACTIVO ? "active" : "danger")">@EstadoDocumentoTexto(item.EstadoDocumento)</span></td>
            <td class="actions-cell">
                <div class="quote-actions">
                    <a class="icon-btn" asp-action="Details" asp-route-id="@item.NotaPedidoId" title="Ver" aria-label="Ver">V</a>
                    <form asp-action="Imprimir" method="post" class="icon-form" target="_blank">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@item.NotaPedidoId" />
                        <button type="submit" class="icon-btn" title="Imprimir / descargar PDF" aria-label="Imprimir / descargar PDF">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M6 9V3h12v6" />
                                <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" />
                                <path d="M6 14h12v8H6Z" />
                            </svg>
                        </button>
                    </form>
                    @if (!soloVer && puedeEditar)
                    {
                        <a class="icon-btn" asp-action="Edit" asp-route-id="@item.NotaPedidoId" title="Editar" aria-label="Editar">E</a>
                    }
                    @if (!soloVer && puedeCobrar)
                    {
                        <a class="icon-btn primary" asp-action="RegistrarCobro" asp-route-id="@item.NotaPedidoId" title="Registrar cobro" aria-label="Registrar cobro">$</a>
                    }
                    @if (!soloVer && puedeAnular)
                    {
                        <form asp-action="Anular" method="post" class="icon-form" onsubmit="return solicitarMotivoAnulacionNotaPedido(this, '@item.Numero', '@item.Total.ToString("N2")', '@item.TotalCobrado.ToString("N2")');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.NotaPedidoId" />
                            <input type="hidden" name="motivo" value="" />
                            <button type="submit" class="icon-btn danger" title="Anular" aria-label="Anular">X</button>
                        </form>
                    }
                </div>
            </td>
        </tr>
    }
    </tbody>
</table>

@await Html.PartialAsync("_Pager", Model)

<script>
    function solicitarMotivoAnulacionNotaPedido(form, numero, total, cobrado) {
        const mensaje = `Anular nota de pedido ${numero}\n\nTotal documento: S/ ${total}\nTotal cobrado: S/ ${cobrado}\nMonto devolucion pendiente: S/ ${cobrado}\n\nLos ingresos historicos permaneceran registrados para preservar la trazabilidad financiera.\n\nIngrese el motivo de anulacion:`;
        const motivo = prompt(mensaje);
        if (!motivo || !motivo.trim()) {
            alert('Ingrese el motivo de anulacion.');
            return false;
        }

        form.querySelector("input[name='motivo']").value = motivo.trim();
        return true;
    }
</script>
