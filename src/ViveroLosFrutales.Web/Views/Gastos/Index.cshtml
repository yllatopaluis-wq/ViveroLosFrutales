@model PagedResult<GastoListDto>
@{
    ViewData["Title"] = "Gastos";
    var today = PeruDateTime.Today;
    var firstDay = new DateTime(today.Year, today.Month, 1).ToString("yyyy-MM-dd");
    var currentDay = today.ToString("yyyy-MM-dd");
    var fechaDesde = Context.Request.Query["FechaDesde"].FirstOrDefault() ?? firstDay;
    var fechaHasta = Context.Request.Query["FechaHasta"].FirstOrDefault() ?? currentDay;
    var search = Context.Request.Query["Search"].FirstOrDefault();
    var pageSize = Context.Request.Query["PageSize"].FirstOrDefault() ?? Model.PageSize.ToString();
}
@functions {
    private static string EstadoRegistroTexto(EstadoRegistro estado) => estado == EstadoRegistro.Activo ? "Activo" : "Anulado";
    private static string EstadoRegistroClass(EstadoRegistro estado) => estado == EstadoRegistro.Activo ? "success" : "danger";
}
<section class="comprobantes-page ops-docs-page">
<form method="get" class="comprobantes-toolbar sales-docs-toolbar">
    <label class="comprobantes-search"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7" /><path d="m20 20-4-4" /></svg><input name="Search" value="@search" placeholder="Buscar categoría, tipo o descripción..." autocomplete="off" />@if (!string.IsNullOrWhiteSpace(search)) { <a class="search-clear" asp-action="Index" asp-route-FechaDesde="@fechaDesde" asp-route-FechaHasta="@fechaHasta" asp-route-PageSize="@pageSize" aria-label="Limpiar búsqueda">&times;</a> }</label>
    <label class="filter-field"><span>Desde</span><input name="FechaDesde" type="date" value="@fechaDesde" /></label>
    <label class="filter-field"><span>Hasta</span><input name="FechaHasta" type="date" value="@fechaHasta" /></label>
    <input type="hidden" name="PageSize" value="@pageSize" />
    <button class="btn-search" type="submit"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7" /><path d="m20 20-4-4" /></svg>Buscar</button>
    <button class="btn-export" type="button" id="exportGastosCsv"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3v12" /><path d="m8 11 4 4 4-4" /><path d="M5 20h14" /></svg>Exportar</button>
</form>
<div class="comprobantes-list ops-docs-list"><div class="comprobantes-head ops-docs-head"><span>Gasto</span><span>Categoría / Tipo</span><span>Importe</span><span>Medio pago</span><span>Estado</span><span>Acciones</span></div>
@if (!Model.Items.Any()) { <div class="comprobantes-empty"><strong>No hay gastos</strong><span>Ajusta los filtros o registra un nuevo gasto.</span></div> } else {
@foreach (var item in Model.Items) {
<article class="comprobante-row ops-docs-row" data-csv="@item.Fecha.ToString("dd/MM/yyyy")|@item.Categoria|@item.Descripcion|@item.MedioPago|@item.Importe.ToString("N2")|@EstadoRegistroTexto(item.Estado)">
<div class="comprobante-main"><span class="comprobante-icon @(item.Estado == EstadoRegistro.Activo ? "success" : "danger")"><svg viewBox="0 0 24 24"><path d="M6 3h9l4 4v14H6z" /><path d="M14 3v5h5M9 12h6M9 16h4" /></svg></span><span class="comprobante-copy"><strong>@item.Descripcion</strong><small>@item.Fecha.ToString("dd/MM/yyyy")</small></span></div>
<div class="comprobante-client"><strong>@item.Categoria</strong><small>Gasto</small></div>
<div class="comprobante-total">S/ @item.Importe.ToString("N2")</div>
<div class="comprobante-status"><span class="sunat-line muted">@item.MedioPago</span></div>
<div class="comprobante-sunat"><span class="pill @EstadoRegistroClass(item.Estado)">@EstadoRegistroTexto(item.Estado)</span></div>
<div class="comprobante-actions"><details class="row-actions-menu"><summary aria-label="Abrir acciones"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="5" r="1.5" /><circle cx="12" cy="12" r="1.5" /><circle cx="12" cy="19" r="1.5" /></svg></summary><div class="row-actions-panel"><a asp-action="Visualizar" asp-route-id="@item.GastoId"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6Z" /><path d="M12 9a3 3 0 1 1 0 6 3 3 0 0 1 0-6Z" /></svg> Visualizar</a>@if (item.Estado == EstadoRegistro.Activo) { <a asp-action="Edit" asp-route-id="@item.GastoId"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 20h9" /><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z" /></svg> Editar</a><form asp-action="Anular" method="post" onsubmit="return solicitarMotivoAnulacion(this);">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@item.GastoId" /><input type="hidden" name="motivo" value="" /><button type="submit" class="danger"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 6h18" /><path d="M8 6V4h8v2M19 6l-1 14H6L5 6" /><path d="M10 11v5M14 11v5" /></svg> Anular</button></form> }</div></details></div>
</article>}}
</div>@await Html.PartialAsync("_Pager", Model)</section>

<script>
    document.querySelectorAll('.row-actions-menu').forEach(menu => {
        menu.addEventListener('toggle', () => {
            if (!menu.open) return;
            document.querySelectorAll('.row-actions-menu[open]').forEach(other => { if (other !== menu) other.removeAttribute('open'); });
        });
    });
    document.addEventListener('click', event => {
        if (event.target.closest('.row-actions-menu')) return;
        document.querySelectorAll('.row-actions-menu[open]').forEach(menu => menu.removeAttribute('open'));
    });
    document.getElementById('exportGastosCsv')?.addEventListener('click', () => {
        const rows = Array.from(document.querySelectorAll('.ops-docs-row[data-csv]'));
        const header = ["Fecha","Categoria/Tipo","Descripcion","Medio pago","Importe","Estado"];
        const csvRows = [header, ...rows.map(row => row.dataset.csv.split('|'))].map(cols => cols.map(value => '"' + String(value ?? '').replaceAll('"', '""') + '"').join(','));
        const blob = new Blob([csvRows.join('\n')], { type: 'text/csv;charset=utf-8;' });
        const url = URL.createObjectURL(blob);
        const link = document.createElement('a');
        link.href = url;
        link.download = 'gastos.csv';
        link.click();
        URL.revokeObjectURL(url);
    });
</script>
<script>function solicitarMotivoAnulacion(form) { const motivo = prompt('Ingrese el motivo de anulación del gasto:'); if (motivo === null) return false; const limpio = motivo.trim(); if (!limpio) { alert('Debe ingresar el motivo de anulación.'); return false; } form.querySelector("input[name='motivo']").value = limpio; return confirm('Confirmar anulación?'); }</script>
