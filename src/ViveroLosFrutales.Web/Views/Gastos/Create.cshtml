@model GastoEditDto
@{
    var readOnly = ViewData["ReadOnly"] as bool? == true;
    ViewData["Title"] = readOnly ? "Visualizar Gasto" : Model.GastoId == 0 ? "Registrar Gasto" : "Editar Gasto";
    var categoriasGasto = ViewBag.CategoriasGasto as IReadOnlyList<CategoriaGastoOptionDto> ?? Array.Empty<CategoriaGastoOptionDto>();
    var categoriaActual = (Model.Categoria ?? string.Empty).Trim().ToUpperInvariant();
    var cuentas = Model.CuentasFinancieras ?? Array.Empty<CuentaFinancieraOptionDto>();
}

<form asp-action="Create" method="post" class="dense-form document-entry-form">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input asp-for="GastoId" type="hidden" />
    <input asp-for="Categoria" type="hidden" />
    <fieldset disabled="@readOnly" class="form-grid cols-4">
        <label>Fecha<input asp-for="Fecha" class="form-control form-control-sm" type="date" /></label>
        <label>
            Categoría
            <select asp-for="CategoriaGastoId" class="form-select form-select-sm">
                <option value="">Seleccione categoría</option>
                @if (!string.IsNullOrWhiteSpace(categoriaActual) && categoriasGasto.All(x => x.Nombre != categoriaActual))
                {
                    <option value="" selected>@categoriaActual</option>
                }
                @foreach (var categoria in categoriasGasto)
                {
                    <option value="@categoria.CategoriaGastoId" selected="@(Model.CategoriaGastoId == categoria.CategoriaGastoId || categoriaActual == categoria.Nombre)">@categoria.Nombre</option>
                }
            </select>
        </label>
        <label>Importe<input asp-for="Importe" class="form-control form-control-sm" type="number" step="0.01" /></label>
        <label>
            Medio pago
            <select asp-for="MedioPago" class="form-select form-select-sm">
                <option value="EFECTIVO">Efectivo</option>
                <option value="TRANSFERENCIA">Transferencia</option>
                <option value="YAPE">Yape</option>
                <option value="TARJETA DEBITO">Tarjeta débito</option>
                <option value="TARJETA CREDITO">Tarjeta crédito</option>
            </select>
        </label>
        <label>
            Cuenta origen
            <select asp-for="CuentaFinancieraId" class="form-select form-select-sm">
                <option value="">Caja principal</option>
                @foreach (var cuenta in cuentas)
                {
                    <option value="@cuenta.CuentaFinancieraId" data-tipo="@cuenta.Tipo" selected="@(Model.CuentaFinancieraId == cuenta.CuentaFinancieraId)">@cuenta.Nombre</option>
                }
            </select>
        </label>
        <label class="span-2">Descripción<input asp-for="Descripcion" class="form-control form-control-sm" /></label>
        <label class="span-2">Observación<input asp-for="Observacion" class="form-control form-control-sm" /></label>
    </fieldset>
    <div class="form-actions">
        @if (!readOnly)
        {
            <button class="btn btn-sm btn-primary">Guardar</button>
        }
        <a class="btn btn-sm btn-outline-secondary" asp-action="Index">Volver</a>
    </div>
</form>


@section Scripts {
    <script>window.viveroFiltrarCuentasPorMedioPago?.();</script>
}
